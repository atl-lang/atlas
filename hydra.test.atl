import * as hydra from "./hydra";

// ============================================================================
// Router tests
// ============================================================================

fn test_router_pattern_matching() -> void {
    let router = hydra.routerNew();

    let users_router = hydra.routerAdd(
        router,
        hydra.methodGet(),
        "/users/:id",
        fn(req: hydra.Request) -> hydra.Response {
            let id_opt = hydra.requestParam(req, "id");
            let id = match id_opt {
                Some(value) => value,
                None => "missing",
                _ => "missing"
            };
            return hydra.responseText(hydra.statusOk(), "user-" + id);
        }
    );

    let router2 = hydra.routerAdd(
        users_router,
        hydra.methodGet(),
        "/assets/*",
        fn(req: hydra.Request) -> hydra.Response {
            let wildcard_opt = hydra.requestParam(req, "wildcard");
            let wildcard = match wildcard_opt {
                Some(value) => value,
                None => "",
                _ => ""
            };
            return hydra.responseText(hydra.statusOk(), "asset:" + wildcard);
        }
    );

    let req = hydra.requestNew(hydra.methodGet(), "/users/42", "");
    let res1 = hydra.routerHandle(router2, req).response;
    assert_equal(res1.body, "user-42");

    let req2 = hydra.requestNew(hydra.methodGet(), "/assets/js/app.js", "");
    let res2 = hydra.routerHandle(router2, req2).response;
    assert_equal(res2.body, "asset:js/app.js");

    assert_equal(hydra.routerRouteCount(router2), 2);
}

// ============================================================================
// Middleware tests
// ============================================================================

fn test_middleware_order() -> void {
    let router = hydra.routerNew();

    let mw1: hydra.Middleware = fn(req: hydra.Request, next: hydra.Handler) -> hydra.Response {
        let res = next(req);
        return hydra.responseText(res.status, "A" + res.body);
    };

    let mw2: hydra.Middleware = fn(req: hydra.Request, next: hydra.Handler) -> hydra.Response {
        let res = next(req);
        return hydra.responseText(res.status, "B" + res.body);
    };

    let router2 = hydra.routerUse(router, mw1);
    let router3 = hydra.routerUse(router2, mw2);

    let router4 = hydra.routerAdd(
        router3,
        hydra.methodGet(),
        "/",
        fn(_req: hydra.Request) -> hydra.Response {
            return hydra.responseText(hydra.statusOk(), "handler");
        }
    );

    let req = hydra.requestNew(hydra.methodGet(), "/", "");
    let res = hydra.routerHandle(router4, req).response;

    // mw1 wraps mw2 wraps handler => A + (B + handler)
    assert_equal(res.body, "ABhandler");
}

// ============================================================================
// Request/Response tests
// ============================================================================

fn test_request_response_basics() -> void {
    let req = hydra.requestNew(hydra.methodPost(), "/submit?count=3", "payload");
    let query_opt = hydra.requestQuery(req, "count");
    let query = match query_opt {
        Some(value) => value,
        None => "",
        _ => ""
    };

    assert_equal(query, "3");

    let res = hydra.responseJson(hydra.statusCreated(), record { ok: true, count: 3 });
    let header_opt = hash_map_get(res.headers, "Content-Type");
    let header = assert_some(header_opt);
    assert_contains([header], "application/json; charset=utf-8");

    let status_line = hydra.renderStatusLine(res.status);
    assert_equal(status_line, "HTTP/1.1 201 Created");

    // Generic + trait bound rendering
    assert_equal(hydra.renderAll(["A", "B"]), "AB");
    assert_equal(hydra.renderAll([1, 2, 3]), "123");
}

// ============================================================================
// Static file tests
// ============================================================================

fn test_static_file_serving() -> void {
    let temp_dir = fsTmpDir();
    let static_root = path_join(temp_dir, "hydra_static");
    fsMkdirp(static_root);

    let file_path = path_join(static_root, "hello.txt");
    write_file(file_path, "Hello Hydra");

    let router = hydra.routerNew();
    let router2 = hydra.routerAdd(
        router,
        hydra.methodGet(),
        "/static/*",
        hydra.staticFileHandler(static_root)
    );

    let req = hydra.requestNew(hydra.methodGet(), "/static/hello.txt", "");
    let res = hydra.routerHandle(router2, req).response;

    assert_equal(res.body, "Hello Hydra");
    assert_equal(hydra.statusCode(res.status), 200);
}

// ============================================================================
// Template rendering tests
// ============================================================================

fn test_template_rendering() -> void {
    let template = "Hello {{name}}
Welcome to {{site}}";
    let data = hash_map_new();
    hash_map_put(data, "name", "Ada");
    hash_map_put(data, "site", "Hydra");

    let rendered = hydra.renderTemplateString(template, data);
    assert_contains([rendered], "Hello Ada");
    assert_contains([rendered], "Welcome to Hydra");

    let temp_dir = fsTmpDir();
    let file_path = path_join(temp_dir, "template.txt");
    write_file(file_path, "Hi {{name}}");

    let rendered_file = hydra.renderTemplateFile(file_path, data);
    assert_equal(rendered_file, "Hi Ada");
}

// ============================================================================
// Session tests
// ============================================================================

fn test_sessions_persist() -> void {
    let router = hydra.routerNew();

    let router2 = hydra.routerAdd(
        router,
        hydra.methodGet(),
        "/visit",
        fn(req: hydra.Request) -> hydra.Response {
            let count_opt = hash_map_get(req.session, "count");
            let mut count = match count_opt {
                Some(value) => value,
                None => 0,
                _ => 0
            };
            count += 1;
            hash_map_put(req.session, "count", count);
            return hydra.responseText(hydra.statusOk(), str(count));
        }
    );

    // First request creates a session
    let req1 = hydra.requestNew(hydra.methodGet(), "/visit", "");
    let res1 = hydra.routerHandle(router2, req1);
    let response1 = res1.response;

    assert_equal(response1.body, "1");

    let cookie_opt = hash_map_get(response1.headers, "Set-Cookie");
    let cookie = assert_some(cookie_opt);
    assert_contains([cookie], "sid=");

    // Second request with same session id
    let session_id = substring(cookie, 4, len(cookie));
    let req2 = hydra.requestWithHeader(
        hydra.requestNew(hydra.methodGet(), "/visit", ""),
        "Cookie",
        "sid=" + session_id
    );

    let res2 = hydra.routerHandle(res1.router, req2);
    let response2 = res2.response;
    assert_equal(response2.body, "2");
}

// ============================================================================
// Assertion coverage tests (use all 13 assertions)
// ============================================================================

fn test_assertion_coverage() -> void {
    assert(true, "basic assert");
    assert_false(false, "basic assert_false");

    assert_equal(2 + 2, 4);
    assert_not_equal("hydra", "python");

    let ok_res: Result<number, string> = Ok(5);
    let err_res: Result<number, string> = Err("bad");
    assert_equal(assert_ok(ok_res), 5);
    assert_equal(assert_err(err_res), "bad");

    let some_opt: Option<string> = Some("present");
    let none_opt: Option<string> = None();
    assert_equal(assert_some(some_opt), "present");
    assert_none(none_opt);

    assert_contains(["a", "b", "c"], "b");
    let empty_list: string[] = [];
    assert_empty(empty_list);
    assert_length([1, 2, 3], 3);

    // Error assertions accept Atlas callables and stdlib/native functions.
    assert_throws(dateTimeFromTimestamp);
    assert_no_throw(dateTimeNow);
}

// ============================================================================
// Exception handling tests
// ============================================================================

fn will_throw() -> void {
    let arr = [1, 2, 3];
    let _x = arr[99];
}

fn test_exception_handling() -> void {
    assert_throws(will_throw);
}
