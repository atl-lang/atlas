#!/bin/bash
# atlas-track — Token-safe tracking CLI for AI agents
# Usage: atlas-track <command> [args]

set -euo pipefail

# Resolve symlinks to find real script location
SOURCE="${BASH_SOURCE[0]}"
while [[ -L "$SOURCE" ]]; do
    DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"
    SOURCE="$(readlink "$SOURCE")"
    [[ $SOURCE != /* ]] && SOURCE="$DIR/$SOURCE"
done
SCRIPT_DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"

# Source library files
source "$SCRIPT_DIR/lib/common.sh"
source "$SCRIPT_DIR/lib/queries.sh"
source "$SCRIPT_DIR/lib/session.sh"
source "$SCRIPT_DIR/lib/issues.sh"
source "$SCRIPT_DIR/lib/decisions.sh"
source "$SCRIPT_DIR/lib/mode.sh"
source "$SCRIPT_DIR/lib/maintenance.sh"

# Verify database exists
if [[ ! -f "$DB" ]]; then
    echo "ERROR: Database not found at $DB"
    exit 1
fi

usage() {
    cat << 'EOF'
atlas-track — Token-safe CLI for AI agent continuity

ORIENTATION (no session required):
  context                          # Ultra-compact dashboard: issues, CI, block, last session
  in-progress                      # What's being worked on right now (check before claiming)

SESSION:
  go opus                          # THE command: init session + full sitrep
  sitrep                           # Status only (no session start)
  done S-001 success "Sum" "Next"  # End session (BLOCKED if unclosed issues)

ISSUES:
  issues [P0|P1|P2|component]      # List open+in_progress issues with titles (max 5)
  issue H-001                      # Full detail (no truncation)
  add "Title" P0|P1|P2 "problem"   # Create issue, returns H-XXX
  update H-001 field value         # Update: priority|component|title|problem
  claim H-001                      # Mark in_progress (do this before starting work)
  fix H-001 "cause" "fix"          # Close + capture root cause (min 10 chars each)
  fix-batch H-001,H-002 "c" "f"    # Close multiple with same cause/fix
  search "keyword"                 # Find by keyword (title+problem) — shows component+status
  link H-001 blocks H-002          # Link issues (blocks|blocked-by|related)
  links H-001                      # Show relationships
  history H-001                    # Change history
  my-issues                        # Your work this session
  reopen H-001                     # Reopen closed issue
  abandon H-001 "reason"           # Release in_progress back to open
  components                       # List valid components + counts

DECISIONS (source of truth — not MEMORY.md):
  decisions [component|all]        # List active decisions (all = no cap, show everything)
  decision D-001                   # Full detail (no truncation)
  add-decision "Title" comp "Rule" "Rationale"  # Log new decision
  update-decision D-001 rule "new rule text"    # Amend rule or rationale text
  supersede D-001 D-002            # Mark D-001 superseded by D-002
  deprecate D-001 "reason"         # Mark deprecated

BLOCKS:
  blocks                           # Block progress with names
  block 8                          # Block detail + AC (also accepts: block B8)
  phase-done B8                    # Increment phases_done +1 (MANDATORY after every phase commit)
  complete-block B8 "notes"        # Mark block complete (MANDATORY when all phases done)

WHAT TO WORK ON:
  next                             # Smart triage: groups by root cause, chains, delete-first flags

CI:
  ci-status                        # Last CI run results + failed tests
  mark-ci-pass "reason"            # Mark CI as passing (use after verifying fixes manually)
  run-ci                           # Trigger full suite (~10-20 min)

MISC:
  sessions                         # Recent sessions
  session S-001                    # Session detail
  status                           # One-line mode/block/P0 status
  unblock / block-work             # Toggle development mode

MAINTENANCE (auto-runs on go):
  health                           # Quick DB health check
  gc                               # Close stale sessions + release orphans
  gc --aggressive                  # + archive old issues, vacuum DB
EOF
    exit 0
}

# Main dispatch
case "${1:-}" in
    # Orientation (no session needed)
    context)    cmd_context ;;
    in-progress) cmd_in_progress ;;

    # Session lifecycle
    go)         cmd_go "${2:-opus}" "${3:-}" ;;
    init)       cmd_init "${2:-opus}" "${3:-}" ;;
    sitrep)     cmd_sitrep ;;
    claim)      cmd_claim "${2:?'Issue ID required'}" ;;
    fix)        cmd_fix "${2:?'Issue ID required'}" "${3:?'Root cause required'}" "${4:?'Fix applied required'}" ;;
    my-issues)  cmd_my_issues ;;
    done)       cmd_done "${2:?'Session ID required'}" "${3:?'Outcome required'}" "${4:?'Summary required'}" "${5:-}" ;;

    # Issues
    add)        cmd_add_issue "${2:?'Title required'}" "${3:?'Priority (P0/P1/P2) required'}" "${4:?'Problem description required'}" ;;
    update)     cmd_update_issue "${2:?'Issue ID required'}" "${3:?'Field required'}" "${4:?'Value required'}" ;;
    abandon)    cmd_abandon "${2:?'Issue ID required'}" "${3:-}" ;;
    reopen)     cmd_reopen "${2:?'Issue ID required'}" ;;
    search)     cmd_search_issues "${2:?'Keyword required'}" ;;
    fix-batch)  cmd_fix_batch "${2:?'Issue IDs required (comma-separated)'}" "${3:?'Root cause required'}" "${4:?'Fix required'}" ;;
    link)       cmd_link_issues "${2:?'Source issue required'}" "${3:?'Relation required'}" "${4:?'Target issue required'}" ;;
    links)      cmd_issue_links "${2:?'Issue ID required'}" ;;
    history)    cmd_history "${2:?'Issue ID required'}" ;;
    components) cmd_components ;;
    open-issue) cmd_open_issue "${2:?}" "${3:?}" "${4:?}" "${5:?}" "${6:?}" "${7:?}" ;;

    # Decisions
    add-decision)    cmd_add_decision "${2:?}" "${3:?}" "${4:?}" "${5:-}" ;;
    update-decision) cmd_update_decision "${2:?'Decision ID required'}" "${3:?'Field required (rule|rationale|title|component)'}" "${4:?'New value required'}" ;;
    supersede)       cmd_supersede "${2:?}" "${3:?}" ;;
    deprecate)       cmd_deprecate "${2:?}" "${3:-}" ;;

    # Queries
    next)       cmd_next ;;
    status)     cmd_status ;;
    issues)     cmd_issues "${2:-}" ;;
    decisions)  cmd_decisions "${2:-}" ;;
    blocks)         cmd_blocks ;;
    phase-done)     cmd_phase_done "${2:?'Block number required (e.g. B8)'}" ;;
    complete-block) cmd_complete_block "${2:?'Block number required (e.g. B8)'}" "${3:-}" ;;
    sessions)   cmd_sessions ;;
    issue)      cmd_issue_detail "${2:?'Issue ID required'}" ;;
    decision)   cmd_decision_detail "${2:?'Decision ID required'}" ;;
    session)    cmd_session_detail "${2:?'Session ID required'}" ;;
    block)      cmd_block_detail "${2:?'Block number required (e.g. 8 or B8)'}" ;;

    # Mode
    unblock)    cmd_unblock ;;
    block-work) cmd_block_work ;;

    # CI
    run-ci)     echo "Running full CI suite (this takes 10-20 minutes)..."
                "$SCRIPT_DIR/ci-runner.sh" ;;
    ci-status)  cmd_ci_status ;;
    mark-ci-pass) cmd_mark_ci_pass "${2:-manually verified}" ;;

    # Maintenance
    gc)         cmd_gc "${2:---normal}" ;;
    health)     cmd_health ;;

    # Legacy aliases
    start-session) cmd_start_session "${2:-opus}" "${3:-}" ;;
    end-session)   cmd_end_session "${2:?}" "${3:?}" "${4:?}" "${5:-}" ;;
    close-issue)   cmd_close_issue "${2:?}" "${3:?}" "${4:?}" "${5:?}" ;;

    -h|--help|help|"") usage ;;
    *)          echo "Unknown command: $1"; usage ;;
esac
