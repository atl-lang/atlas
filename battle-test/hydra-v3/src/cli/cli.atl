import { load_registry, save_registry } from "../config/registry";
import { default_server_config_json, default_server_command_args } from "../config/defaults";
import { scan_all } from "../discovery/scanner";
import { resolve_conflicts } from "../discovery/merger";
import { state_load } from "../state/manager";

fn join_args(args: string[]) -> string {
    if (len(args) == 0) {
        return "";
    }
    return join(args, " ");
}

export fn execute(args: string[], registry_path: string, state_dir: string) -> Result<string, string> {
    if (len(args) == 0) {
        return Err("no command provided");
    }
    let cmd = args[0];
    match cmd {
        "status" => {
            if (len(args) < 2) {
                return Err("status requires server name");
            }
            let name = args[1];
            let state = state_load(state_dir, name);
            match state {
                Ok(value) => { return Ok(unwrap(stringifyJson(value))); },
                Err(err) => { return Err(err); }
            };
        },
        "discover" => {
            let discoveries = scan_all();
            let resolved = resolve_conflicts(discoveries);
            return Ok(unwrap(stringifyJson(toJSON(resolved))));
        },
        "list" => {
            let reg = load_registry(registry_path);
            match reg {
                Ok(value) => { return Ok(unwrap(stringifyJson(value))); },
                Err(err) => { return Err(err); }
            };
        },
        "add" => {
            if (len(args) < 3) {
                return Err("add requires name and command");
            }
            let name = args[1];
            let command = join_args(slice(args, 2, len(args)));
            let reg = load_registry(registry_path);
            match reg {
                Ok(registry) => {
                    let mut servers = registry["servers"];
                    if (servers == null) {
                        servers = toJSON(record {});
                    }
                    if (jsonHas(servers, name)) {
                        return Err("server already exists");
                    }
                    let mut server = default_server_config_json();
                    server["command"] = command;
                    server["args"] = toJSON(default_server_command_args(command));
                    servers[name] = server;
                    registry["servers"] = servers;
                    let _ignored = save_registry(registry_path, registry);
                    return Ok("added " + name);
                }
                Err(err) => { return Err(err); }
            };
        },
        "remove" => {
            if (len(args) < 2) {
                return Err("remove requires name");
            }
            let name = args[1];
            let reg = load_registry(registry_path);
            match reg {
                Ok(registry) => {
                    if (registry["servers"] == null) {
                        return Err("no servers configured");
                    }
                    let mut servers = registry["servers"];
                    if (jsonHas(servers, name)) {
                        servers[name] = null;
                    }
                    registry["servers"] = servers;
                    let _ignored = save_registry(registry_path, registry);
                    return Ok("removed " + name);
                }
                Err(err) => { return Err(err); }
            };
        },
        "run" => {
            if (len(args) < 2) {
                return Err("run requires server name");
            }
            let name = args[1];
            return Ok("run " + name);
        },
        _ => { return Err("unknown command: " + cmd); }
    };
}
