import { now_seconds, seconds_since } from "../common/time";
import { classify_chunk } from "../sanitizer/sanitizer";
import { queue_new, queue_push, queue_pop, queue_size } from "./queue";
import { build_error_response, build_log_message, parse_jsonrpc } from "../protocol/jsonrpc";
import { recorder_record_request, recorder_record_response } from "../recorder/recorder";
import { metrics_record_request, metrics_record_queue_wait } from "../metrics/collector";

enum ProxyState {
    Stopped,
    Starting,
    Running,
    Failed
}

type QueueEntry = { payload: string, timestamp: number };
type QueueState = { max_size: number, ttl_seconds: number, entries: QueueEntry[] };
type RecorderState = { enabled: bool, include_request_bodies: bool, include_response_bodies: bool, redact_patterns: string[], redact_replacement: string, buffer: json[], max_size: number };
type MetricsState = { requests_total: number, requests_success: number, requests_failed: number, restarts_total: number, queue_waits_total: number, latencies_ms: number[], queue_waits_ms: number[], restart_reasons: HashMap<string, number>, start_time: number };
type ProxyOutput = { core: ProxyCore, recorder: RecorderState, metrics: MetricsState, outgoing: string[] };
type FlushOutput = { core: ProxyCore, metrics: MetricsState, outgoing: string[] };

struct ProxyCore {
    state: ProxyState,
    queue: QueueState,
    last_restart_reason: string,
    last_error: string,
    start_time: number,
    restarts_in_window: number
}

export fn proxy_new(queue_size: number, queue_ttl: number) -> ProxyCore {
    return ProxyCore {
        state: ProxyState::Stopped,
        queue: queue_new(queue_size, queue_ttl),
        last_restart_reason: "",
        last_error: "",
        start_time: now_seconds(),
        restarts_in_window: 0
    };
}

export fn proxy_status(core: ProxyCore) -> { state: string, queue_size: number, last_restart_reason: string, last_error: string, uptime_seconds: number, restarts_in_window: number, can_recover: bool } {
    let can_recover = core.state == ProxyState::Failed;
    return record {
        state: proxy_state_string(core.state),
        queue_size: queue_size(core.queue),
        last_restart_reason: core.last_restart_reason,
        last_error: core.last_error,
        uptime_seconds: seconds_since(core.start_time),
        restarts_in_window: core.restarts_in_window,
        can_recover: can_recover
    };
}

fn proxy_state_string(state: ProxyState) -> string {
    return match state {
        ProxyState::Stopped => "stopped",
        ProxyState::Starting => "starting",
        ProxyState::Running => "running",
        ProxyState::Failed => "failed"
    };
}

export fn proxy_start(core: ProxyCore) -> ProxyCore {
    if (core.state == ProxyState::Running) {
        return core;
    }
    return ProxyCore {
        state: ProxyState::Running,
        queue: core.queue,
        last_restart_reason: core.last_restart_reason,
        last_error: core.last_error,
        start_time: now_seconds(),
        restarts_in_window: core.restarts_in_window
    };
}

export fn proxy_stop(core: ProxyCore) -> ProxyCore {
    return ProxyCore {
        state: ProxyState::Stopped,
        queue: core.queue,
        last_restart_reason: core.last_restart_reason,
        last_error: core.last_error,
        start_time: core.start_time,
        restarts_in_window: core.restarts_in_window
    };
}

export fn proxy_route_client_message(
    core: ProxyCore,
    payload: string,
    recorder: RecorderState,
    metrics: MetricsState
) -> ProxyOutput {
    let chunk_type = classify_chunk(payload);
    match chunk_type {
        "jsonrpc" => {
            let parsed = parse_jsonrpc(payload);
            match parsed {
                Ok(msg) => {
                    let updated_rec = recorder_record_request(recorder, "client", msg);
                    let updated_metrics = metrics_record_request(metrics, 0, true);
                    let q = queue_push(core.queue, payload);
                    let updated_core = ProxyCore {
                        state: core.state,
                        queue: q,
                        last_restart_reason: core.last_restart_reason,
                        last_error: core.last_error,
                        start_time: core.start_time,
                        restarts_in_window: core.restarts_in_window
                    };
                    return record { core: updated_core, recorder: updated_rec, metrics: updated_metrics, outgoing: [] };
                },
                Err(err) => {
                    let err_msg = build_error_response(null, -32600, err);
                    let output = unwrap(stringifyJson(err_msg));
                    return record { core: core, recorder: recorder, metrics: metrics_record_request(metrics, 0, false), outgoing: [output] };
                }
            };
        },
        "empty" => { return record { core: core, recorder: recorder, metrics: metrics, outgoing: [] }; },
        _ => {
            let log_msg = build_log_message("warn", "discarded non-jsonrpc output");
            let output = unwrap(stringifyJson(log_msg));
            return record { core: core, recorder: recorder, metrics: metrics, outgoing: [output] };
        }
    };
}

export fn proxy_handle_child_message(
    core: ProxyCore,
    payload: string,
    recorder: RecorderState,
    metrics: MetricsState
) -> ProxyOutput {
    let chunk_type = classify_chunk(payload);
    match chunk_type {
        "jsonrpc" => {
            let parsed = parse_jsonrpc(payload);
            match parsed {
                Ok(msg) => {
                    let updated_rec = recorder_record_response(recorder, "child", msg);
                    let updated_metrics = metrics_record_request(metrics, 0, true);
                    return record { core: core, recorder: updated_rec, metrics: updated_metrics, outgoing: [payload] };
                },
                Err(err) => {
                    let err_msg = build_error_response(null, -32603, err);
                    let output = unwrap(stringifyJson(err_msg));
                    return record { core: core, recorder: recorder, metrics: metrics_record_request(metrics, 0, false), outgoing: [output] };
                }
            };
        },
        "empty" => { return record { core: core, recorder: recorder, metrics: metrics, outgoing: [] }; },
        _ => {
            let log_msg = build_log_message("warn", "child emitted non-jsonrpc output");
            let output = unwrap(stringifyJson(log_msg));
            return record { core: core, recorder: recorder, metrics: metrics, outgoing: [output] };
        }
    };
}

export fn proxy_flush_queue(
    core: ProxyCore,
    metrics: MetricsState
) -> FlushOutput {
    let mut outputs: string[] = [];
    let mut queue = core.queue;
    let mut updated_metrics = metrics;
    while (queue_size(queue) > 0) {
        let res = queue_pop(queue);
        let item = res.item;
        queue = res.queue;
        match item {
            Some(payload) => {
                outputs = outputs + [payload];
                updated_metrics = metrics_record_queue_wait(updated_metrics, 0);
            },
            None() => {}
        };
    }
    let updated_core = ProxyCore {
        state: core.state,
        queue: queue,
        last_restart_reason: core.last_restart_reason,
        last_error: core.last_error,
        start_time: core.start_time,
        restarts_in_window: core.restarts_in_window
    };
    return record { core: updated_core, metrics: updated_metrics, outgoing: outputs };
}
