import { now_seconds, seconds_since } from "../common/time";

enum ServerState {
    Stopped,
    Starting,
    Running,
    Restarting,
    Failed
}

struct SupervisorState {
    cmd: string[],
    cwd: string,
    max_restarts: number,
    restart_window_seconds: number,
    state: ServerState,
    handle: Option<ProcessHandle>,
    pid: number,
    last_error: string,
    restart_times: number[],
    start_time: number
}

export fn supervisor_state_str(state: ServerState) -> string {
    return match state {
        ServerState::Stopped => "stopped",
        ServerState::Starting => "starting",
        ServerState::Running => "running",
        ServerState::Restarting => "restarting",
        ServerState::Failed => "failed"
    };
}

export fn new_supervisor(
    cmd: string[],
    cwd: string,
    max_restarts: number,
    restart_window_seconds: number
) -> SupervisorState {
    return SupervisorState {
        cmd: cmd,
        cwd: cwd,
        max_restarts: max_restarts,
        restart_window_seconds: restart_window_seconds,
        state: ServerState::Stopped,
        handle: None(),
        pid: 0,
        last_error: "",
        restart_times: [],
        start_time: 0
    };
}

export fn supervisor_start(s: SupervisorState) -> SupervisorState {
    if (s.state == ServerState::Running || s.state == ServerState::Starting) {
        return s;
    }
    if (len(s.cmd) == 0) {
        return SupervisorState {
            cmd: s.cmd,
            cwd: s.cwd,
            max_restarts: s.max_restarts,
            restart_window_seconds: s.restart_window_seconds,
            state: ServerState::Failed,
            handle: None(),
            pid: 0,
            last_error: "empty command",
            restart_times: s.restart_times,
            start_time: 0
        };
    }
    let handle = spawn_process(s.cmd);
    let pid = 0;
    return SupervisorState {
        cmd: s.cmd,
        cwd: s.cwd,
        max_restarts: s.max_restarts,
        restart_window_seconds: s.restart_window_seconds,
        state: ServerState::Running,
        handle: Some(handle),
        pid: pid,
        last_error: "",
        restart_times: s.restart_times,
        start_time: now_seconds()
    };
}

export fn supervisor_stop(s: SupervisorState) -> SupervisorState {
    return match s.handle {
        Some(handle) => {
            let _ignored = process_kill(handle, 15);
            SupervisorState {
                cmd: s.cmd,
                cwd: s.cwd,
                max_restarts: s.max_restarts,
                restart_window_seconds: s.restart_window_seconds,
                state: ServerState::Stopped,
                handle: None(),
                pid: 0,
                last_error: s.last_error,
                restart_times: s.restart_times,
                start_time: 0
            }
        },
        None() => {
            SupervisorState {
                cmd: s.cmd,
                cwd: s.cwd,
                max_restarts: s.max_restarts,
                restart_window_seconds: s.restart_window_seconds,
                state: ServerState::Stopped,
                handle: None(),
                pid: 0,
                last_error: s.last_error,
                restart_times: s.restart_times,
                start_time: 0
            }
        }
    };
}

fn filter_restart_times(times: number[], window_seconds: number) -> number[] {
    let cutoff = now_seconds() - window_seconds;
    let mut filtered: number[] = [];
    for t in times {
        if (t >= cutoff) {
            filtered = filtered + [t];
        }
    }
    return filtered;
}

export fn supervisor_restart(s: SupervisorState) -> SupervisorState {
    let now = now_seconds();
    let mut restarts = s.restart_times + [now];
    restarts = filter_restart_times(restarts, s.restart_window_seconds);
    if (len(restarts) > s.max_restarts) {
        return SupervisorState {
            cmd: s.cmd,
            cwd: s.cwd,
            max_restarts: s.max_restarts,
            restart_window_seconds: s.restart_window_seconds,
            state: ServerState::Failed,
            handle: None(),
            pid: 0,
            last_error: "crash loop detected: " + str(len(restarts)),
            restart_times: restarts,
            start_time: s.start_time
        };
    }
    let stopped = supervisor_stop(SupervisorState {
        cmd: s.cmd,
        cwd: s.cwd,
        max_restarts: s.max_restarts,
        restart_window_seconds: s.restart_window_seconds,
        state: ServerState::Restarting,
        handle: s.handle,
        pid: s.pid,
        last_error: s.last_error,
        restart_times: restarts,
        start_time: s.start_time
    });
    return supervisor_start(stopped);
}

export fn supervisor_poll(s: SupervisorState) -> SupervisorState {
    if (s.handle == None()) {
        return s;
    }
    let handle = unwrap(s.handle);
    if (process_is_running(handle)) {
        return s;
    }
    let wait_result = process_wait(handle);
    return match wait_result {
        Ok(code) => {
            let _ignored = code;
            SupervisorState {
                cmd: s.cmd,
                cwd: s.cwd,
                max_restarts: s.max_restarts,
                restart_window_seconds: s.restart_window_seconds,
                state: ServerState::Stopped,
                handle: None(),
                pid: 0,
                last_error: s.last_error,
                restart_times: s.restart_times,
                start_time: s.start_time
            }
        },
        Err(err) => {
            SupervisorState {
                cmd: s.cmd,
                cwd: s.cwd,
                max_restarts: s.max_restarts,
                restart_window_seconds: s.restart_window_seconds,
                state: ServerState::Failed,
                handle: None(),
                pid: 0,
                last_error: err,
                restart_times: s.restart_times,
                start_time: s.start_time
            }
        }
    };
}

export fn supervisor_uptime(s: SupervisorState) -> number {
    if (s.state != ServerState::Running) {
        return 0;
    }
    return seconds_since(s.start_time);
}

export fn supervisor_last_error(s: SupervisorState) -> string {
    return s.last_error;
}

export fn supervisor_pid(s: SupervisorState) -> number {
    return s.pid;
}
