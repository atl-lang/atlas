// CLI helpers (Atlas port, simplified)

export fn registry_path_from_args(args: json) -> string {
    if (args["registry"].is_null()) { return "~/.hydra/config.json"; }
    return args["registry"].as_string();
}

export fn server_name_from_args(args: json) -> Result<string, string> {
    if (args["name"].is_null()) { return Err("name is required"); }
    let name = args["name"].as_string();
    if (len(name) == 0) { return Err("name cannot be empty"); }
    return Ok(name);
}

export fn expand_home(path: string) -> string {
    if (len(path) == 0 || substring(path, 0, 1) != "~") {
        return path;
    }
    let home = getEnv("HOME");
    if (home.is_null()) {
        home = getEnv("USERPROFILE");
    }
    if (home.is_null()) { return path; }
    return pathJoin(home.as_string(), substring(path, 1, len(path)));
}
