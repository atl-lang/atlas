// Tool definitions (Atlas port)

export fn tool_definition(name: string) -> Result<json, string> {
    if (name == "hydra_restart") {
        return Ok({ name: "hydra_restart", description: "Manually restart the supervised MCP server.", input_schema: { type: "object", properties: { reason: { type: "string" } } } });
    }
    if (name == "hydra_status") {
        return Ok({ name: "hydra_status", description: "Get current Hydra supervisor status.", input_schema: { type: "object", properties: {} } });
    }
    if (name == "hydra_logs") {
        return Ok({ name: "hydra_logs", description: "Retrieve recent child stderr logs.", input_schema: { type: "object", properties: { lines: { type: "number" } } } });
    }
    if (name == "hydra_metrics") {
        return Ok({ name: "hydra_metrics", description: "Get Hydra proxy metrics.", input_schema: { type: "object", properties: {} } });
    }
    if (name == "hydra_force_restart") {
        return Ok({ name: "hydra_force_restart", description: "Force restart even if FAILED.", input_schema: { type: "object", properties: { confirm: { type: "boolean" } }, required: ["confirm"] } });
    }
    return Ok(null);
}
