// Basic struct expression test
// Structs compile to HashMaps at runtime

fn main() -> void {
    print("=== Struct Expression Test ===");
    print("");
    
    // Test 1: Basic struct expression
    print("Test 1: Basic struct expression");
    let user = User { name: "Alice", age: 30 };
    let name_result = hashMapGet(user, "name");
    let name = unwrap(name_result);
    print("  Name: " + name);
    print("  ✓ Struct created and accessed");
    print("");
    
    // Test 2: Struct with number field
    print("Test 2: Struct with number field");
    let point = Point { x: 10, y: 20 };
    let x_result = hashMapGet(point, "x");
    let x = unwrap(x_result);
    print("  X: " + str(x));
    print("  ✓ Number field works");
    print("");
    
    // Test 3: Nested struct (struct containing array)
    print("Test 3: Struct with nested array");
    let config = Config { 
        name: "server",
        ports: [8080, 8443]
    };
    let ports_result = hashMapGet(config, "ports");
    let ports = unwrap(ports_result);
    print("  Ports count: " + str(len(ports)));
    print("  ✓ Nested array works");
    print("");
    
    // Test 4: toJSON with struct
    print("Test 4: Serialize struct to JSON");
    let data = Data { key: "value", count: 42 };
    let json = toJSON(data);
    print("  JSON: " + json);
    print("  ✓ toJSON works with struct");
    print("");
    
    // Test 5: Empty struct
    print("Test 5: Empty struct");
    let empty = Empty {};
    let size = hashMapSize(empty);
    print("  Size: " + str(size));
    print("  ✓ Empty struct works");
    print("");
    
    print("=== All Struct Tests Passed ===");
}

main();
