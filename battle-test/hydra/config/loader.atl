// Config loader (Atlas port)
// Source: /Users/proxikal/dev/projects/hydra/internal/config/loader.go

import { default_registry, default_server_config } from "./config";
import { substitute_env_vars_in_config } from "./envsubst";

fn expand_home(path: string) -> string {
    if (len(path) > 0 && substring(path, 0, 1) == "~") {
        let home = getEnv("HOME");
        if (!home.is_null()) {
            return pathJoin(home.as_string(), substring(path, 1, len(path)));
        }
    }
    return path;
}

export fn load_registry(path: string) -> Result<json, string> {
    if (len(path) == 0) { return Err("registry path cannot be empty"); }
    let p = expand_home(path);

    if (!fsIsFile(p)) {
        // Return defaults
        return default_registry();
    }

    let data = readFile(p);
    let parsed = parseJSON(data)?;

    // Ensure servers object exists
    if (parsed["servers"].is_null()) {
        let obj = { version: parsed["version"], defaults: parsed["defaults"], servers: {} };
        let encoded = toJSON(obj);
        let fixed = parseJSON(encoded)?;
        return Ok(fixed);
    }

    return Ok(parsed);
}

export fn load_server_config(path: string) -> Result<json, string> {
    let p = expand_home(path);
    if (!fsIsFile(p)) {
        return Ok(null);
    }
    let data = readFile(p);
    let parsed = parseJSON(data)?;
    return Ok(parsed);
}

fn choose_string(src: json, field: string, fallback: string) -> string {
    if (!src[field].is_null()) {
        let val = src[field].as_string();
        if (len(val) > 0) { return val; }
    }
    return fallback;
}

fn choose_number(src: json, field: string, fallback: number) -> number {
    if (!src[field].is_null()) {
        let val = src[field].as_number();
        if (val != 0) { return val; }
    }
    return fallback;
}

fn choose_bool(src: json, field: string, fallback: bool) -> bool {
    if (!src[field].is_null()) {
        return src[field].as_bool();
    }
    return fallback;
}

fn choose_array(src: json, field: string, fallback: array) -> array {
    if (!src[field].is_null()) {
        return src[field];
    }
    return fallback;
}

export fn merge_server_config(dst: json, src: json) -> Result<json, string> {
    if (src.is_null()) { return Ok(dst); }

    let merged = {
        command: choose_string(src, "command", dst["command"].is_null() ? "" : dst["command"].as_string()),
        args: choose_array(src, "args", dst["args"].is_null() ? [] : dst["args"]),
        cwd: choose_string(src, "cwd", dst["cwd"].is_null() ? "" : dst["cwd"].as_string()),
        env_file: choose_string(src, "env_file", dst["env_file"].is_null() ? "" : dst["env_file"].as_string()),
        environment: src["environment"].is_null() ? dst["environment"] : src["environment"],
        watch: {
            enabled: choose_bool(src["watch"], "enabled", dst["watch"]["enabled"].as_bool()),
            paths: choose_array(src["watch"], "paths", dst["watch"]["paths"]),
            extensions: choose_array(src["watch"], "extensions", dst["watch"]["extensions"]),
            ignore_files: choose_array(src["watch"], "ignore_files", dst["watch"]["ignore_files"]),
            ignore: choose_array(src["watch"], "ignore", dst["watch"]["ignore"])
        },
        behavior: {
            debounce_ms: choose_number(src["behavior"], "debounce_ms", dst["behavior"]["debounce_ms"].as_number()),
            restart_delay_ms: choose_number(src["behavior"], "restart_delay_ms", dst["behavior"]["restart_delay_ms"].as_number()),
            max_restarts: choose_number(src["behavior"], "max_restarts", dst["behavior"]["max_restarts"].as_number()),
            graceful_shutdown_ms: choose_number(src["behavior"], "graceful_shutdown_ms", dst["behavior"]["graceful_shutdown_ms"].as_number()),
            restart_window_seconds: choose_number(src["behavior"], "restart_window_seconds", dst["behavior"]["restart_window_seconds"].as_number()),
            pre_restart_command: choose_string(src["behavior"], "pre_restart_command", dst["behavior"]["pre_restart_command"].is_null() ? "" : dst["behavior"]["pre_restart_command"].as_string())
        },
        injectable_tools: {
            enabled: choose_bool(src["injectable_tools"], "enabled", dst["injectable_tools"]["enabled"].as_bool()),
            tools: choose_array(src["injectable_tools"], "tools", dst["injectable_tools"]["tools"]),
            on_collision: choose_string(src["injectable_tools"], "on_collision", dst["injectable_tools"]["on_collision"].as_string())
        },
        recorder: {
            enabled: choose_bool(src["recorder"], "enabled", dst["recorder"]["enabled"].as_bool()),
            buffer_size: choose_number(src["recorder"], "buffer_size", dst["recorder"]["buffer_size"].as_number()),
            include_request_bodies: choose_bool(src["recorder"], "include_request_bodies", dst["recorder"]["include_request_bodies"].as_bool()),
            include_response_bodies: choose_bool(src["recorder"], "include_response_bodies", dst["recorder"]["include_response_bodies"].as_bool()),
            export_on_crash: choose_bool(src["recorder"], "export_on_crash", dst["recorder"]["export_on_crash"].as_bool()),
            export_path: choose_string(src["recorder"], "export_path", dst["recorder"]["export_path"].as_string())
        },
        security: {
            redact_patterns: choose_array(src["security"], "redact_patterns", dst["security"]["redact_patterns"]),
            redact_replacement: choose_string(src["security"], "redact_replacement", dst["security"]["redact_replacement"].as_string())
        }
    };

    let encoded = toJSON(merged);
    let parsed = parseJSON(encoded)?;
    return Ok(parsed);
}

export fn resolve_server(server_name: string, local_override_path: string) -> Result<json, string> {
    let registry = load_registry("~/.hydra/config.json")?;
    let server_cfg = registry["servers"][server_name];
    if (server_cfg.is_null()) {
        return Err("server not found in registry: " + server_name);
    }

    let final = default_server_config()?;
    let merged = merge_server_config(final, server_cfg)?;

    if (len(local_override_path) > 0) {
        let local = load_server_config(local_override_path)?;
        if (!local.is_null()) {
            let merged2 = merge_server_config(merged, local)?;
            let substituted = substitute_env_vars_in_config(merged2)?;
            return Ok(substituted);
        }
    }

    let substituted = substitute_env_vars_in_config(merged)?;
    return Ok(substituted);
}

export fn validate_config(cfg: json) -> Result<null, string> {
    if (cfg["command"].is_null() || len(cfg["command"].as_string()) == 0) {
        return Err("command is required");
    }
    if (cfg["behavior"]["max_restarts"].as_number() < 0) { return Err("max_restarts cannot be negative"); }
    if (cfg["behavior"]["debounce_ms"].as_number() < 0) { return Err("debounce_ms cannot be negative"); }
    if (cfg["behavior"]["restart_window_seconds"].as_number() < 0) { return Err("restart_window_seconds cannot be negative"); }

    let on_collision = cfg["injectable_tools"]["on_collision"].as_string();
    if (on_collision != "error" && on_collision != "warn" && on_collision != "disable_hydra_tool" && on_collision != "") {
        return Err("invalid injectable_tools.on_collision: " + on_collision);
    }

    if (cfg["recorder"]["buffer_size"].as_number() < 0) { return Err("recorder.buffer_size cannot be negative"); }

    return Ok(null);
}
