// Proxy test helpers (Atlas port, simplified)
// Source: hydra/internal/proxy/test_helpers.go (not present; helper utilities)

import { new_options } from "./types";
import { new_proxy } from "./proxy";

export fn new_test_proxy() -> Result<json, string> {
    let opts = new_options(100, 30, "error")?;
    return new_proxy(opts);
}

export fn sample_initialize_request() -> string {
    return "{\"jsonrpc\":\"2.0\",\"id\":1,\"method\":\"initialize\",\"params\":{}}";
}

export fn sample_tools_response() -> string {
    return "{\"jsonrpc\":\"2.0\",\"id\":1,\"result\":{\"tools\":[]}}";
}
