// Test match as expression (not with return statements)

fn test_match_expression() -> bool {
    let json_obj = { test: true };
    let json_str: string = toJSON(json_obj);
    let result: Result<json, string> = parseJSON(json_str);

    // Match returns a value - don't use return inside!
    let is_valid: bool = match result {
        Ok(data) => true,
        Err(_) => false
    };

    return is_valid;
}

fn main() -> void {
    print("=== Match Expression Test ===");
    print("");

    let result: bool = test_match_expression();

    if (result) {
        print("✓ Match expression works correctly");
    }

    print("");
    print("=== Test Complete ===");
}

main();
