// Metrics types (Atlas port) - json-based

export fn empty_snapshot() -> Result<json, string> {
    let obj = {
        requests_total: 0,
        requests_success: 0,
        requests_failed: 0,
        restarts_total: 0,
        queue_waits_total: 0,
        avg_latency_ms: 0,
        max_latency_ms: 0,
        avg_queue_wait_ms: 0,
        max_queue_wait_ms: 0
    };
    let encoded = toJSON(obj);
    let parsed = parseJSON(encoded)?;
    return Ok(parsed);
}
