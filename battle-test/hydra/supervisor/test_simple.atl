// Simple supervisor test
import { new_supervisor, start_process, get_state_name } from "./supervisor_simple";

fn main() -> void {
    print("=== Simple Supervisor Test ===");
    print("");

    // Create supervisor
    let cmd: string = "echo";
    let supervisor: object = new_supervisor(cmd);

    print("Initial state: " + get_state_name(supervisor));
    print("");

    // Start process
    let result: Result<object, string> = start_process(supervisor, cmd);

    match result {
        Ok(updated) => {
            print("Final state: " + get_state_name(updated));
            print("✓ Supervisor test passed");
        },
        Err(e) => {
            print("✗ Error: " + e);
        }
    }

    print("");
    print("=== Test Complete ===");
}

main();
