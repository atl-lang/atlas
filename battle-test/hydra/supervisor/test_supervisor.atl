// Test Supervisor
import {
    new_supervisor,
    start_process,
    restart_process,
    stop_process,
    is_running,
    is_failed,
    get_state_name
} from "./supervisor";

fn main() -> void {
    print("=== Supervisor Tests ===");
    print("");

    // Test 1: Create supervisor
    print("Test 1: Create Supervisor");
    let cmd: string = "echo";
    let args: array = ["Hello from MCP server"];
    let supervisor: object = new_supervisor(cmd, args);

    print("  Initial state: " + get_state_name(supervisor));
    if (get_state_name(supervisor) == "STOPPED") {
        print("  ✓ Supervisor created in STOPPED state");
    }
    print("");

    // Test 2: Start process
    print("Test 2: Start Process");
    let start_result: Result<object, string> = start_process(supervisor);

    match start_result {
        Ok(running_supervisor) => {
            print("  State after start: " + get_state_name(running_supervisor));

            if (is_running(running_supervisor)) {
                print("  ✓ Process started successfully");
            }

            // Test 3: Stop process
            print("");
            print("Test 3: Stop Process");
            let stopped: object = stop_process(running_supervisor);
            print("  State after stop: " + get_state_name(stopped));
            if (get_state_name(stopped) == "STOPPED") {
                print("  ✓ Process stopped successfully");
            }
        },
        Err(e) => {
            print("  ✗ Failed to start: " + e);
        }
    }

    print("");
    print("=== Tests Complete ===");
}

main();
