// Test exec with full path
fn main() -> void {
    print("=== Exec with Full Path ===");

    // Test 1: /bin/echo
    print("Test 1: /bin/echo hello");
    let result: object = exec("/bin/echo hello");
    print("  Type: " + typeof(result));
    print("");

    print("=== Test Complete ===");
}

main();
