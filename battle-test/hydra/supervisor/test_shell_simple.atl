// Test shell function
fn main() -> void {
    print("=== Shell Test ===");

    // Test 1: Simple command
    print("Test 1: echo hello");
    let output: string = shell("echo hello");
    print("  output:");
    print(output);
    print("  ✓ shell works");
    print("");

    // Test 2: pwd
    print("Test 2: pwd");
    let pwd: string = shell("pwd");
    print("  pwd: " + pwd);
    print("  ✓ pwd works");
    print("");

    print("=== Tests Complete ===");
}

main();
