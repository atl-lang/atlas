// 03_option.atlas
// Tests: Option<T> with Some/None, match on Option, chaining Option through fns.
// Fn returning Option<number> (None for invalid input).

fn safe_sqrt(borrow x: number) : Option<number> {
    if x < 0 {
        return None();
    }
    // Integer approximation via iteration
    let mut i: number = 0;
    while i * i <= x {
        i = i + 1;
    }
    return Some(i - 1);
}

fn safe_divide(borrow a: number, borrow b: number) : Option<number> {
    if b == 0 {
        return None();
    }
    return Some(a / b);
}

fn option_to_string(borrow opt: Option<number>) : string {
    return match opt {
        Some(v) => "Some(" + str(v) + ")",
        None => "None",
    };
}

fn option_or(borrow opt: Option<number>, borrow default: number) : number {
    return match opt {
        Some(v) => v,
        None => default,
    };
}

fn chain_divide(borrow a: number, borrow b: number, borrow c: number) : Option<number> {
    let first: Option<number> = safe_divide(a, b);
    return match first {
        Some(v) => safe_divide(v, c),
        None => None(),
    };
}

// Basic Some/None
let maybe_num: Option<number> = Some(42);
let no_num: Option<number> = None();

print("maybe_num: " + option_to_string(maybe_num));
print("no_num: " + option_to_string(no_num));

// sqrt tests
let sqrt9: Option<number> = safe_sqrt(9);
let sqrt_neg: Option<number> = safe_sqrt(-4);
let sqrt25: Option<number> = safe_sqrt(25);

print("sqrt(9): " + option_to_string(sqrt9));
print("sqrt(-4): " + option_to_string(sqrt_neg));
print("sqrt(25): " + option_to_string(sqrt25));

// divide tests
let div_ok: Option<number> = safe_divide(100, 4);
let div_zero: Option<number> = safe_divide(100, 0);

print("100/4: " + option_to_string(div_ok));
print("100/0: " + option_to_string(div_zero));

// option_or default
let val_a: number = option_or(div_ok, -1);
let val_b: number = option_or(div_zero, -1);

print("option_or(100/4, -1): " + str(val_a));
print("option_or(100/0, -1): " + str(val_b));

// Chained options
let chain_ok: Option<number> = chain_divide(100, 5, 4);
let chain_fail: Option<number> = chain_divide(100, 0, 4);

print("chain(100/5/4): " + option_to_string(chain_ok));
print("chain(100/0/4): " + option_to_string(chain_fail));

// Final result: unwrapped value or default
let result: number = option_or(chain_ok, 0);
print(result);
