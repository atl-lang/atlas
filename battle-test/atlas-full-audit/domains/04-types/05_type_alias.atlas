// 05_type_alias.atlas
// Tests: type alias for primitive, fn type alias, array type alias.

type Score = number;
type Name = string;
type Scores = number[];
type Scorer = (string) -> number;
type Predicate = (number) -> bool;
type NumberPair = number[];

fn score_player(borrow name: string) -> Score {
    return len(name) * 10;
}

fn apply_scorer(borrow scorer: Scorer, borrow name: Name) -> Score {
    return scorer(name);
}

fn filter_scores(borrow scores: Scores, borrow pred: Predicate) -> Scores {
    return filter(scores, pred);
}

fn sum_scores(borrow scores: Scores) -> Score {
    return reduce(scores, fn(borrow acc: number, borrow x: number) -> number {
        return acc + x;
    }, 0);
}

fn make_pair(borrow a: number, borrow b: number) -> NumberPair {
    return [a, b];
}

// Use type aliases
let player_name: Name = "Atlas";
let my_score: Score = score_player(player_name);

print("score for 'Atlas': " + str(my_score));

// Scorer alias
let custom_scorer: Scorer = fn(borrow name: string) -> number {
    return len(name) * 5 + 100;
};

let s1: Score = apply_scorer(score_player, "Bob");
let s2: Score = apply_scorer(custom_scorer, "Bob");

print("score_player('Bob'): " + str(s1));
print("custom_scorer('Bob'): " + str(s2));

// Scores array alias
let all_scores: Scores = [80, 95, 60, 72, 88, 45, 91];

let passing: Predicate = fn(borrow x: number) -> bool { return x >= 70; };
let high_scores: Scores = filter_scores(all_scores, passing);

print("total scores: " + str(len(all_scores)));
print("passing (>=70): " + str(len(high_scores)));
print("sum all: " + str(sum_scores(all_scores)));
print("sum passing: " + str(sum_scores(high_scores)));

// NumberPair
let pair: NumberPair = make_pair(42, 58);
print("pair sum: " + str(pair[0] + pair[1]));

// Final result
let result: Score = sum_scores(high_scores);
print(result);
