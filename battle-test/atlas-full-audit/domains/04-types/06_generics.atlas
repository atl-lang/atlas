// 06_generics.atlas
// Tests: generic fn with type parameter, generic applied to number and string.

fn identity<T>(own x: T) : T {
    return x;
}

fn first<T>(borrow arr: T[]) : T {
    return arr[0];
}

fn last<T>(borrow arr: T[]) : T {
    return arr[len(arr) - 1];
}

fn wrap<T>(borrow x: T) : T[] {
    return [x];
}

fn swap_pair<T>(borrow pair: T[]) : T[] {
    let a: T = pair[0];
    let b: T = pair[1];
    return [b, a];
}

// identity with different concrete types
let num_id: number = identity(42);
let str_id: string = identity("hello");
let bool_id: bool = identity(true);

print("identity(42): " + str(num_id));
print("identity('hello'): " + str_id);
print("identity(true): " + str(bool_id));

// first / last
let nums: number[] = [10, 20, 30, 40, 50];
let words: string[] = ["alpha", "beta", "gamma"];

print("first(nums): " + str(first(nums)));
print("last(nums): " + str(last(nums)));
print("first(words): " + first(words));
print("last(words): " + last(words));

// wrap
let wrapped_num: number[] = wrap(99);
let wrapped_str: string[] = wrap("atlas");

print("wrap(99): " + str(wrapped_num[0]));
print("wrap('atlas'): " + wrapped_str[0]);

// swap_pair
let num_pair: number[] = [1, 2];
let swapped_nums: number[] = swap_pair(num_pair);

let str_pair: string[] = ["first", "second"];
let swapped_strs: string[] = swap_pair(str_pair);

print("swap_pair([1,2]): " + str(swapped_nums[0]) + ", " + str(swapped_nums[1]));
print("swap_pair(['first','second']): " + swapped_strs[0] + ", " + swapped_strs[1]);

// Final result: identity applied to a computed number
let result: number = identity(first(nums) + last(nums));
print(result);
