// 05_async_error.atlas
// Tests: async fn with error conditions, early return on error, Future type checks

// Async fn that returns a Result — success path
async fn safe_divide(borrow a: number, borrow b: number) : Result<number, string> {
    if b == 0 {
        return Err("division by zero");
    }
    return Ok(a / b);
}

// Await async fn returning Result — success
let div_ok: Result<number, string> = await safe_divide(100, 4);
let div_ok_out: string = match div_ok {
    Ok(v) => "ok: " + str(v),
    Err(e) => "error: " + e
};
print(div_ok_out);

// Await async fn returning Result — error path
let div_err: Result<number, string> = await safe_divide(100, 0);
let div_err_out: string = match div_err {
    Ok(v) => "ok: " + str(v),
    Err(e) => "error: " + e
};
print(div_err_out);

// Async fn with early return on condition
async fn find_positive(own n: number) : number {
    if n < 0 {
        return 0;
    }
    return n;
}

let pos: number = await find_positive(42);
print(pos);

let clamped: number = await find_positive(-7);
print(clamped);

// Awaiting a legitimate Future created by futureResolve
let resolved: number = await futureResolve(77);
print(resolved);

// Async fn is Future type before await
let pending = safe_divide(10, 2);
print(typeof(pending));
