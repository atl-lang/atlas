// 03_parallel_all.atlas
// Tests: futureAll with multiple resolved futures, access results by index

// futureAll with three resolved futures
let f1 = futureResolve(10);
let f2 = futureResolve(20);
let f3 = futureResolve(30);

let results = await futureAll([f1, f2, f3]);

// Access individual results by index
let r0: number = results[0];
let r1: number = results[1];
let r2: number = results[2];

print(r0);
print(r1);
print(r2);

// Sum all parallel results
let total: number = r0 + r1 + r2;
print(total);

// futureAll with two futures
let fa = futureResolve(100);
let fb = futureResolve(200);
let two_results = await futureAll([fa, fb]);
let sum2: number = two_results[0] + two_results[1];
print(sum2);

// futureAll with single future
let single = await futureAll([futureResolve(42)]);
print(single[0]);

// futureAll with empty array
let empty_results = await futureAll([]);
print(len(empty_results));
