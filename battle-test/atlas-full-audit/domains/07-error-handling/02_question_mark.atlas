// 02_question_mark.atlas
// Tests: ? operator for early-return propagation through chained fallible functions

fn validate(borrow n: number) : Result<number, string> {
    if n <= 0 {
        return Err("must be positive");
    }
    return Ok(n);
}

fn transform(borrow n: number) : Result<number, string> {
    if n > 1000 {
        return Err("too large");
    }
    return Ok(n * 2);
}

fn format_result(borrow n: number) : Result<string, string> {
    return Ok("value=" + str(n));
}

fn pipeline(borrow n: number) : Result<string, string> {
    let v: number = validate(n)?;
    let t: number = transform(v)?;
    let s: string = format_result(t)?;
    return Ok(s);
}

// Valid input — propagates through all three steps
let success: Result<string, string> = pipeline(21);
let success_out: string = match success {
    Ok(v) => v,
    Err(e) => "error: " + e
};
print(success_out);

// Invalid: fails at validate step
let fail_validate: Result<string, string> = pipeline(-3);
let fail_v_out: string = match fail_validate {
    Ok(v) => v,
    Err(e) => "error: " + e
};
print(fail_v_out);

// Invalid: fails at transform step (too large)
let fail_transform: Result<string, string> = pipeline(600);
let fail_t_out: string = match fail_transform {
    Ok(v) => v,
    Err(e) => "error: " + e
};
print(fail_t_out);
