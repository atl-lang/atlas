// 03_option_chain.atlas
// Tests: Option<T> with Some/None, match, chaining.
// FRICTION: 'return' inside match arm is syntax error — must use if/else pattern.

fn find_user(borrow id: number) -> Option<string> {
    if id == 1 { return Some("Alice"); }
    if id == 2 { return Some("Bob"); }
    return None;
}

fn greet_user(borrow id: number) -> string {
    let user: Option<string> = find_user(id);
    // WORKAROUND: cannot 'return' inside match arm
    // Natural: match user { Some(n) => "hello, " + n, None => return "not found" }
    let found = match user {
        Some(_) => true,
        None => false
    };
    if !found {
        return "user not found";
    }
    let name = match user { Some(n) => n, None => "" };
    return "hello, " + name + "!";
}

print(greet_user(1));
print(greet_user(2));
print(greet_user(99));

// Direct match on Option
let opt1: Option<number> = Some(42);
let opt2: Option<number> = None;

let v1 = match opt1 { Some(v) => v, None => 0 };
let v2 = match opt2 { Some(v) => v, None => -1 };

print("some: " + str(v1));
print("none default: " + str(v2));
