// 01_result_match.atlas
// Tests: Result<T,E> construction, match on Ok/Err, nested match.
// FRICTION: 'return' inside match arm is a syntax error in Atlas.
//           Cannot write: Err(e) => return "error"
//           Must split into separate match or use if/else.
// FRICTION: let x: string = match ... fails — must use let x = match ...

fn parse_positive(n: number) -> Result<number, string> {
    if n <= 0 {
        return Err("must be positive, got " + str(n));
    }
    return Ok(n);
}

fn double_positive(n: number) -> Result<number, string> {
    let r: Result<number, string> = parse_positive(n);
    // WORKAROUND: cannot use 'return' in match arm — use match + local var
    let ok = match r {
        Ok(v) => true,
        Err(_) => false
    };
    if !ok {
        let msg = match r {
            Ok(_) => "",
            Err(e) => e
        };
        return Err(msg);
    }
    let v = match r { Ok(n) => n, Err(_) => 0 };
    return Ok(v * 2);
}

// Test positive input
let r1: Result<number, string> = parse_positive(42);
let out1 = match r1 {
    Ok(v) => "ok: " + str(v),
    Err(e) => "err: " + e
};
print(out1);

// Test negative input
let r2: Result<number, string> = parse_positive(-5);
let out2 = match r2 {
    Ok(v) => "ok: " + str(v),
    Err(e) => "err: " + e
};
print(out2);

// Double positive
let r3: Result<number, string> = double_positive(21);
let out3 = match r3 { Ok(v) => "doubled: " + str(v), Err(e) => "err: " + e };
print(out3);

let r4: Result<number, string> = double_positive(-3);
let out4 = match r4 { Ok(v) => "doubled: " + str(v), Err(e) => "fail: " + e };
print(out4);
