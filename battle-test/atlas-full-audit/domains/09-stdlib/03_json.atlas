// 03_json.atlas
// Tests: parseJSON, jsonGetString, jsonGetNumber, jsonGetBool, toJSON round-trip.
// FRICTION: parseJSON returns Result<json, string> — must unwrap.
//           Natural: let data: json = parseJSON(raw);  <- FAILS
//           Required: let data = unwrap(parseJSON(raw));

let raw: string = "{\"name\": \"Alice\", \"age\": 30, \"active\": true}";

// parseJSON returns Result<json, string> — unwrap required
let data = unwrap(parseJSON(raw));

// Extract fields via typed accessors (all return Option<T>)
let name_opt: Option<string> = jsonGetString(data, "name");
let age_opt: Option<number> = jsonGetNumber(data, "age");

let name_val = match name_opt { Some(s) => s, None => "unknown" };
let age_val = match age_opt { Some(n) => n, None => 0 };

print("name: " + name_val);
print("age: " + str(age_val));

// toJSON round-trip
let serialized: string = toJSON(data);
print("serialized len > 0: " + str(len(serialized) > 0));

// Parse a JSON array
let arr_raw: string = "[1, 2, 3]";
let arr_data = unwrap(parseJSON(arr_raw));
print("array parsed: " + typeof(arr_data));

// Invalid JSON — match on Err
let bad: Result<json, string> = parseJSON("not valid json");
let bad_ok = match bad { Ok(_) => true, Err(_) => false };
print("invalid json parsed: " + str(bad_ok));
