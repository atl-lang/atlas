// 04_file_io.atlas
// Tests: writeFileAsync + readFileAsync round-trip.
// Writes to /tmp/atlas_battle_09.txt, reads back, verifies content.
// Top-level await is used (no wrapping async fn needed).

let path: string = "/tmp/atlas_battle_09.txt";
let content: string = "Hello from Atlas battle test 09!";

// Write file
await writeFileAsync(path, content);
print("write: ok");

// Read file back
let read_back: string = await readFileAsync(path);
print("read: " + read_back);

// Verify round-trip
let matched: bool = read_back == content;
print("match: " + str(matched));

// Write multi-line content
let multi: string = "line one\nline two\nline three";
await writeFileAsync(path, multi);
let multi_back: string = await readFileAsync(path);
print("multi-line read: " + multi_back);

// Final result: the read-back content
print(read_back);
