// 02_math_functions.atlas
// Tests: abs, floor, ceil, round, sqrt, pow, min, max, PI.
// FRICTION: sqrt() returns Result<number, string> — must unwrap.
//           Natural: let x = sqrt(16); // FAILS — typechecker sees Result
//           Required: let x = unwrap(sqrt(16));
// FRICTION: 'clamp' variable conflicts with prelude builtin — renamed fn.

print("abs(-7): " + str(abs(-7)));
print("abs(3): " + str(abs(3)));
print("floor(3.7): " + str(floor(3.7)));
print("ceil(3.2): " + str(ceil(3.2)));
print("round(3.5): " + str(round(3.5)));
print("round(3.4): " + str(round(3.4)));

// sqrt returns Result<number, string> — must unwrap
let sqrt16 = unwrap(sqrt(16));
print("sqrt(16): " + str(sqrt16));

let sqrt2 = unwrap(sqrt(2));
print("sqrt(2) approx: " + str(floor(sqrt2 * 1000) / 1000));

print("pow(2,10): " + str(pow(2, 10)));
print("pow(3,3): " + str(pow(3, 3)));
print("min(5,3): " + str(min(5, 3)));
print("max(5,3): " + str(max(5, 3)));

// PI
let area: number = PI * 5 * 5;
print("circle area r=5: " + str(floor(area)));

// Distance formula (Pythagorean)
let dist = unwrap(sqrt(3 * 3 + 4 * 4));
print("distance 3-4-5: " + str(dist));

// Clamped value — function renamed to avoid prelude 'clamp' conflict
fn clamp_to_range(x: number, lo: number, hi: number) -> number {
    return max(lo, min(hi, x));
}
print("clamped 150: " + str(clamp_to_range(150, 0, 100)));
print("clamped -5: " + str(clamp_to_range(-5, 0, 100)));
