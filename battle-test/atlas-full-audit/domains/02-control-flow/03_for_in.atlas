// 03_for_in.atlas
// Tests: for-in over array literal, named array, building array in loop.
// FRICTION: Variable named 'concat' conflicts with prelude builtin 'concat'.
//           Must rename to avoid AT1012 shadow error.
// FRICTION: No nested for-in over T[][] — simulated with separate row arrays.
// LIMITATION: No range syntax (for i in 0..n) — must use while loop for index iteration.

// for-in over array literal
let mut total: number = 0;
for n in [1, 2, 3, 4, 5] {
    total = total + n;
}
print("sum 1-5: " + str(total));

// for-in over named array
let fruits: string[] = ["apple", "banana", "cherry"];
let mut combined: string = "";   // renamed from 'concat' (prelude conflict)
for fruit in fruits {
    combined = combined + fruit + " ";
}
print("fruits: " + trim(combined));

// Building array in loop
let mut squares: number[] = [];
let nums: number[] = [1, 2, 3, 4, 5];
for n in nums {
    squares = arrayPush(squares, n * n);
}
print("squares len: " + str(len(squares)));
print("first square: " + str(squares[0]));
print("last square: " + str(squares[4]));

// Simulated 2D iteration (separate row arrays — no T[][] support)
let row1: number[] = [1, 2, 3];
let row2: number[] = [4, 5, 6];
let row3: number[] = [7, 8, 9];

let mut flat_sum: number = 0;
for v in row1 { flat_sum = flat_sum + v; }
for v in row2 { flat_sum = flat_sum + v; }
for v in row3 { flat_sum = flat_sum + v; }
print("flat sum: " + str(flat_sum));

// String array processing
let words: string[] = ["the", "quick", "brown", "fox"];
let mut upper_words: string[] = [];
for w in words {
    upper_words = arrayPush(upper_words, toUpperCase(w));
}
print("upper count: " + str(len(upper_words)));
print("first upper: " + upper_words[0]);
