// 02_while_loop.atlas
// Tests: while loop, break, continue
// Computes sum of even numbers 0..20 using continue to skip odds
// Expected final print: 110

let mut i: number = 0;
let mut sum: number = 0;

while i <= 20 {
    // Skip odd numbers
    if i % 2 != 0 {
        i = i + 1;
        continue;
    }
    sum = sum + i;
    i = i + 1;
}

print("sum of evens 0..20: " + str(sum));

// Test break: find first number > 50 in a sequence
let mut n: number = 0;
let mut found: number = -1;
while n < 100 {
    n = n + 7;
    if n > 50 {
        found = n;
        break;
    }
}
print("first multiple-of-7 > 50: " + str(found));

// Nested while
let mut outer: number = 0;
let mut inner_sum: number = 0;
while outer < 3 {
    let mut inner: number = 0;
    while inner < 3 {
        inner_sum = inner_sum + 1;
        inner = inner + 1;
    }
    outer = outer + 1;
}
print("3x3 iterations: " + str(inner_sum));

print(sum);
