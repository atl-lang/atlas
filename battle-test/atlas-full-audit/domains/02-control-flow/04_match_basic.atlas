// 04_match_basic.atlas
// Tests: match on number, match on string, wildcard _, match with guard

// Match on number
let code: number = 2;
let code_name: string = match code {
    1 => "one",
    2 => "two",
    3 => "three",
    _ => "unknown"
};
print("code 2: " + code_name);

// Match on string
let lang: string = "atlas";
let verdict: string = match lang {
    "rust" => "systems",
    "python" => "scripting",
    "atlas" => "ai-first",
    _ => "other"
};
print("lang verdict: " + verdict);

// Wildcard only
let x: number = 99;
let category: string = match x {
    0 => "zero",
    _ => "nonzero"
};
print("99 category: " + category);

// Match used as expression in let
let val: number = 42;
let label: string = match val {
    42 => "the answer",
    0 => "zero",
    _ => "something else"
};
print("val label: " + label);

// Match with guard (if condition in arm)
let n: number = 15;
let size: string = match n {
    x if x < 0 => "negative",
    x if x == 0 => "zero",
    x if x < 10 => "small",
    x if x < 100 => "medium",
    _ => "large"
};
print("15 size: " + size);

// Final result
let result: string = size + " | " + label + " | " + verdict;
print(result);
