// 03_hashset.atlas
// Tests: hashSetNew, hashSetAdd, hashSetHas, hashSetRemove, hashSetSize.
// FRICTION: hashSetHas returns 'any' from typechecker — cannot use in bool condition directly.
//           Must use toString() comparison or str() conversion.
// FRICTION: hashSetNew() result must be 'let mut' for CoW rebind.

let values: number[] = [1, 2, 3, 2, 4, 1, 5, 3, 2];

let mut seen: any = hashSetNew();
let mut unique: number[] = [];

for v in values {
    // hashSetHas returns any — convert to bool via str() check
    let has_v: string = str(hashSetHas(seen, v));
    if has_v == "false" {
        seen = hashSetAdd(seen, v);
        unique = arrayPush(unique, v);
    }
}

print("original len: " + str(len(values)));
print("unique len: " + str(len(unique)));
print("set size: " + str(hashSetSize(seen)));

// Direct add/has
let mut s: any = hashSetNew();
s = hashSetAdd(s, "apple");
s = hashSetAdd(s, "banana");
s = hashSetAdd(s, "apple");

print("set items: " + str(hashSetSize(s)));
print("has apple: " + str(hashSetHas(s, "apple")));
print("has cherry: " + str(hashSetHas(s, "cherry")));

// hashSetRemove returns the updated set (CoW, like hashSetAdd) — rebind to update
s = hashSetRemove(s, "banana");
print("after remove: " + str(hashSetSize(s)));
