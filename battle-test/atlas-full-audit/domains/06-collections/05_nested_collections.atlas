// 05_nested_collections.atlas
// Tests: array of structs, HashMap of arrays.
// BUG FOUND: Multi-line struct array literals fail (parser error).
//            Must keep struct constructors on single lines in array literals.
// FRICTION: hashMapGet returns Option<T> — must unwrap with match or unwrap().

struct Player { name: string, score: number }

// BUG WORKAROUND: inline struct constructors (multi-line fails with parse error)
let players: Player[] = [Player { name: "Alice", score: 42 }, Player { name: "Bob", score: 35 }, Player { name: "Carol", score: 58 }];

let mut player_total: number = 0;
for p in players {
    player_total = player_total + p.score;
}
print("player total: " + str(player_total));
print("player count: " + str(len(players)));
print("first player: " + players[0].name);

// HashMap of arrays (teams : scores)
let mut teams = hashMapNew();
let alpha_scores: number[] = [10, 20, 30];
let beta_scores: number[] = [15, 25];

teams = hashMapPut(teams, "alpha", alpha_scores);
teams = hashMapPut(teams, "beta", beta_scores);
print("team count: " + str(hashMapSize(teams)));

// Retrieve and sum
let alpha: number[] = unwrap(hashMapGet(teams, "alpha"));
let beta: number[] = unwrap(hashMapGet(teams, "beta"));

let mut alpha_sum: number = 0;
for s in alpha { alpha_sum = alpha_sum + s; }

let mut beta_sum: number = 0;
for s in beta { beta_sum = beta_sum + s; }

print("alpha sum: " + str(alpha_sum));
print("beta sum: " + str(beta_sum));
print("grand total: " + str(alpha_sum + beta_sum));
