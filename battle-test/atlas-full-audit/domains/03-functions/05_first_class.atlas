// 05_first_class.atlas
// Tests: fn stored in variable, fn in array, fn as return value, fn type as struct field.

struct Transformer {
    name: string,
    func: (number) -> number,
}

fn make_transformer(name: string, f: (number) -> number) -> Transformer {
    return Transformer { name: name, func: f };
}

fn run_transformer(t: Transformer, x: number) -> number {
    return t.func(x);
}

fn get_doubler() -> (number) -> number {
    return fn(x: number) -> number { return x * 2; };
}

fn get_squarer() -> (number) -> number {
    return fn(x: number) -> number { return x * x; };
}

fn get_negator() -> (number) -> number {
    return fn(x: number) -> number { return -x; };
}

// Fns stored in variables
let double: (number) -> number = get_doubler();
let square: (number) -> number = get_squarer();
let negate: (number) -> number = get_negator();

print("double(5): " + str(double(5)));
print("square(5): " + str(square(5)));
print("negate(5): " + str(negate(5)));

// Fns in an array — apply each to input value
let fns: ((number) -> number)[] = [double, square, negate];
let input: number = 6;
let mut acc: number = 0;
forEach(fns, fn(f: (number) -> number) -> void {
    let val: number = f(input);
    print("fn(" + str(input) + ") = " + str(val));
});

// Struct with fn field
let t1: Transformer = make_transformer("double", double);
let t2: Transformer = make_transformer("square", square);

print("transformer '" + t1.name + "' on 8: " + str(run_transformer(t1, 8)));
print("transformer '" + t2.name + "' on 8: " + str(run_transformer(t2, 8)));

// Accumulate results: apply each transformer to 10 and sum
let transformers: Transformer[] = [t1, t2];
let result: number = reduce(transformers, fn(acc: number, t: Transformer) -> number {
    return acc + t.func(10);
}, 0);

print("sum of transformers on 10: " + str(result));
print(result);
