// 05_first_class.atlas
// Tests: fn stored in variable, fn in array, fn as return value.
// Note: fn as struct field + dispatch blocked by H-172 (typechecker bug) — tested via array instead.

fn get_doubler() -> (number) -> number {
    return fn(borrow x: number) -> number { return x * 2; };
}

fn get_squarer() -> (number) -> number {
    return fn(borrow x: number) -> number { return x * x; };
}

fn get_negator() -> (number) -> number {
    return fn(borrow x: number) -> number { return -x; };
}

// Fns stored in variables
let double: (number) -> number = get_doubler();
let square: (number) -> number = get_squarer();
let negate: (number) -> number = get_negator();

print("double(5): " + str(double(5)));
print("square(5): " + str(square(5)));
print("negate(5): " + str(negate(5)));

// Fns in an array — apply each to input value
let fns: ((number) -> number)[] = [double, square, negate];
forEach(fns, fn(borrow f: (number) -> number) -> void {
    let val: number = f(6);
    print("fn(6) = " + str(val));
});

// Factory function pattern — HOF returning fn
fn make_adder(own n: number) -> (number) -> number {
    return fn(borrow x: number) -> number { return x + n; };
}
let add10: (number) -> number = make_adder(10);
let add100: (number) -> number = make_adder(100);
print("add10(5): " + str(add10(5)));
print("add100(42): " + str(add100(42)));

// Apply fns via reduce
let nums: number[] = [1, 2, 3];
let total: number = reduce(nums, fn(borrow acc: number, borrow x: number) -> number {
    return acc + double(x);
}, 0);
print("sum of doubled [1,2,3]: " + str(total));
print(total);
