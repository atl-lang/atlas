// 01_named_fn.atlas
// Tests: named fn, multiple params, return type, early return, void return.
// FRICTION: Function named 'clamp' conflicts with prelude builtin 'clamp'.
//           Must rename to avoid AT1012 shadow error.

fn add(own a: number, borrow b: number) : number {
    return a + b;
}

fn multiply(own a: number, borrow b: number) : number {
    return a * b;
}

fn greet(borrow name: string) : string {
    return "Hello, " + name + "!";
}

fn is_positive(own n: number) : bool {
    return n > 0;
}

fn early_exit(borrow n: number) : string {
    if n < 0 {
        return "negative";
    }
    if n == 0 {
        return "zero";
    }
    return "positive";
}

// clamp renamed to avoid prelude conflict
fn clamp_value(own x: number, own lo: number, own hi: number) : number {
    if x < lo { return lo; }
    if x > hi { return hi; }
    return x;
}

fn print_separator() : void {
    print("---");
    return;
}

print(str(add(3, 4)));
print(str(multiply(6, 7)));
print(greet("Atlas"));
print(str(is_positive(-5)));
print(early_exit(-1));
print(early_exit(0));
print(early_exit(42));
print(str(clamp_value(150, 0, 100)));
print(str(clamp_value(-10, 0, 100)));
print(str(clamp_value(50, 0, 100)));
print_separator();
print("done");
