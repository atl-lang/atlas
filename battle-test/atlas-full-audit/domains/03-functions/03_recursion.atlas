// 03_recursion.atlas
// Tests: recursive fn with base case, factorial (tree recursion style),
//        fibonacci (tree recursion), and sum (tail-call style accumulator).

fn factorial(own n: number) -> number {
    if n <= 1 {
        return 1;
    }
    return n * factorial(n - 1);
}

fn fibonacci(borrow n: number) -> number {
    if n <= 0 {
        return 0;
    }
    if n == 1 {
        return 1;
    }
    return fibonacci(n - 1) + fibonacci(n - 2);
}

// Tail-call style with accumulator
fn sum_to(borrow n: number, own acc: number) -> number {
    if n <= 0 {
        return acc;
    }
    return sum_to(n - 1, acc + n);
}

fn power(own base: number, borrow exp: number) -> number {
    if exp == 0 {
        return 1;
    }
    return base * power(base, exp - 1);
}

let fact5: number = factorial(5);
let fact10: number = factorial(10);
let fib10: number = fibonacci(10);
let fib15: number = fibonacci(15);
let sum100: number = sum_to(100, 0);
let pow2_8: number = power(2, 8);

print("factorial(5): " + str(fact5));
print("factorial(10): " + str(fact10));
print("fibonacci(10): " + str(fib10));
print("fibonacci(15): " + str(fib15));
print("sum_to(100): " + str(sum100));
print("power(2, 8): " + str(pow2_8));

// Final result: fibonacci(10) = 55
print(fib10);
