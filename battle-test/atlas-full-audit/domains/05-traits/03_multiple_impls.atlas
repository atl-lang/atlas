// 03_multiple_impls.atlas
// Tests: one struct implementing multiple traits, multiple structs implementing the same trait

trait Area {
    fn area(self) : number;
}

trait Perimeter {
    fn perimeter(self) : number;
}

struct Rectangle {
    width: number,
    height: number,
}

struct Circle {
    radius: number,
}

impl Area for Rectangle {
    fn area(self) : number {
        return self.width * self.height;
    }
}

impl Perimeter for Rectangle {
    fn perimeter(self) : number {
        return 2 * (self.width + self.height);
    }
}

impl Area for Circle {
    fn area(self) : number {
        // Pi approximated as 3.14159
        return 3.14159 * self.radius * self.radius;
    }
}

impl Perimeter for Circle {
    fn perimeter(self) : number {
        return 2 * 3.14159 * self.radius;
    }
}

let rect = Rectangle { width: 5, height: 3 };
let circ = Circle { radius: 4 };

print("rect area: " + str(rect.area()));
print("rect perimeter: " + str(rect.perimeter()));
print("circle area: " + str(circ.area()));
print("circle perimeter: " + str(circ.perimeter()));
