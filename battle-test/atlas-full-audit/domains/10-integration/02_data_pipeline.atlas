// 02_data_pipeline.atlas
// Integration: structs + filter/map/reduce + stats.
// BUG: Multi-line struct array literals fail — single-line required.
// FRICTION: Struct field access inside reduce callback may have type issues;
//           used for-in as safe alternative for aggregate operations.

struct Record { name: string, score: number, active: bool }

// Single-line struct constructors required (multi-line = parse error)
let records: Record[] = [Record { name: "Alice", score: 92, active: true }, Record { name: "Bob", score: 45, active: false }, Record { name: "Carol", score: 78, active: true }, Record { name: "Dave", score: 61, active: false }, Record { name: "Eve", score: 85, active: true }, Record { name: "Frank", score: 33, active: false }];

// Filter active
let active: Record[] = filter(records, fn(borrow r: Record) -> bool { return r.active; });
print("active count: " + str(len(active)));

// Sum scores of active via for-in (reduce with struct field access may have type issues)
let mut total_score: number = 0;
let mut max_score: number = 0;
let mut min_score: number = 9999;

for r in active {
    total_score = total_score + r.score;
    if r.score > max_score { max_score = r.score; }
    if r.score < min_score { min_score = r.score; }
}

let avg_score: number = floor(total_score / len(active));
print("total: " + str(total_score));
print("avg: " + str(avg_score));
print("max: " + str(max_score));
print("min: " + str(min_score));

// Names of active records
let active_names: string[] = map(active, fn(borrow r: Record) -> string { return r.name; });
let names_str: string = join(active_names, ", ");
print("active: " + names_str);
