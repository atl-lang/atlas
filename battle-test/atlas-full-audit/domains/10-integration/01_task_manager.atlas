// 01_task_manager.atlas
// Integration: structs + enums (if/else) + arrays + Result + match + filter/map.
// BUG: Struct[] cannot be passed to function parameters — typechecker sees ?[].
//      Workaround: do array operations at top level instead of inside functions.
// BUG: return match user_enum { ... } in functions fails — use if/else.
// BUG: Multi-line struct array literals fail — kept single-line.

struct Task { id: number, title: string, done: bool, priority: number }

fn make_task(borrow id: number, borrow title: string, borrow pri: number) -> Task {
    return Task { id: id, title: title, done: false, priority: pri };
}

// Build task list at top level (avoid struct[] fn params due to typechecker bug)
let mut tasks: Task[] = [];
tasks = arrayPush(tasks, make_task(1, "Write docs", 1));
tasks = arrayPush(tasks, make_task(2, "Fix bug", 2));
tasks = arrayPush(tasks, make_task(3, "Deploy", 2));
tasks = arrayPush(tasks, make_task(4, "Review PR", 1));
tasks = arrayPush(tasks, make_task(5, "Update deps", 0));

print("total tasks: " + str(len(tasks)));

// Complete tasks 1 and 3 via map
tasks = map(tasks, fn(borrow t: Task) -> Task {
    if t.id == 1 || t.id == 3 {
        return Task { id: t.id, title: t.title, done: true, priority: t.priority };
    }
    return t;
});

// Count pending via filter
let pending: Task[] = filter(tasks, fn(borrow t: Task) -> bool { return !t.done; });
let done_count: number = len(tasks) - len(pending);

print("pending: " + str(len(pending)));
print("done: " + str(done_count));
print("first pending: " + pending[0].title);
print("first pending priority: " + str(pending[0].priority));

// High priority pending (priority >= 2)
let high_pri: Task[] = filter(pending, fn(borrow t: Task) -> bool { return t.priority >= 2; });
print("high priority pending: " + str(len(high_pri)));
