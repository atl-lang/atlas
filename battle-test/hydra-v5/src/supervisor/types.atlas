// supervisor/types.atlas
// Server state machine and configuration types

// ServerState represents the current state of a supervised process
enum ServerState {
    Stopped,      // No child process
    Starting,     // Child spawned, waiting for initialize
    Running,      // Child healthy, initialized
    Restarting,   // Child terminated, new process starting
    Failed,       // Crash loop detected
}

// String returns the string representation of ServerState
fn server_state_to_string(state: ServerState) -> string {
    return match state {
        ServerState::Stopped => "stopped",
        ServerState::Starting => "starting",
        ServerState::Running => "running",
        ServerState::Restarting => "restarting",
        ServerState::Failed => "failed",
    };
}

// RestartPolicy configures restart behavior
struct RestartPolicy {
    debounce_ms: number,              // delay before restart triggered
    restart_delay_ms: number,         // delay before spawning new process
    max_restarts: number,             // max restarts in window
    graceful_shutdown_ms: number,     // grace period for clean shutdown
    restart_window_seconds: number,   // window for counting restarts
    pre_restart_command: string,      // optional command to run before restart
}

// Default restart policy for development
fn default_restart_policy() -> RestartPolicy {
    return RestartPolicy {
        debounce_ms: 500,
        restart_delay_ms: 100,
        max_restarts: 5,
        graceful_shutdown_ms: 3000,
        restart_window_seconds: 60,
        pre_restart_command: "",
    };
}
