// transport/transport.atlas
// Transport interface for stdio communication with child processes

// Protocol represents the message framing type
enum Protocol {
    Unknown,
    NDJSON,     // Newline Delimited JSON
    LSP,        // Content-Length: <len>\r\n\r\n
}

// Transport manages low-level read/write with child process
trait Transport {
    // Read returns the next complete message payload
    // Blocks until a message is available or connection closes
    fn read(self) -> Result<string, string>;

    // Write sends a payload to the child process
    // Automatically adds framing based on detected protocol
    fn write(self, payload: string) -> Result<string, string>;

    // Close shuts down the transport and releases resources
    fn close(self) -> Result<string, string>;

    // DetectProtocol waits for first message to sniff protocol
    fn detect_protocol(self, timeout_ms: number) -> Result<Protocol, string>;
}

// StdioTransport implements Transport using stdin/stdout
struct StdioTransport {
    protocol: Protocol,
    buffer: string[],
    closed: bool,
}

impl Transport for StdioTransport {
    fn read(self) -> Result<string, string> {
        if self.closed {
            return Err("transport closed");
        }
        // FRICTION: No access to stdin/stdout from Atlas
        // This is a blocker for real I/O implementation
        return Err("stdio read not implemented");
    }

    fn write(self, payload: string) -> Result<string, string> {
        if self.closed {
            return Err("transport closed");
        }
        // FRICTION: No access to stdin/stdout from Atlas
        return Err("stdio write not implemented");
    }

    fn close(self) -> Result<string, string> {
        return Ok("closed");
    }

    fn detect_protocol(self, timeout_ms: number) -> Result<Protocol, string> {
        // FRICTION: No timeout/timer mechanism in Atlas stdlib
        return Ok(Protocol::NDJSON);
    }
}

// Convert protocol to string
fn protocol_to_string(p: Protocol) -> string {
    return match p {
        Protocol::Unknown => "unknown",
        Protocol::NDJSON => "ndjson",
        Protocol::LSP => "lsp",
    };
}
