// recorder/recorder.atlas
// Session traffic recording

struct RecorderEntry {
    direction: string,      // "client" or "child"
    message_type: string,   // "request" or "response"
    payload: string,
    timestamp_ms: number,
}

trait Recorder {
    fn record_request(self, direction: string, payload: string) -> string;
    fn record_response(self, direction: string, payload: string) -> string;
    fn save_to_file(self, path: string) -> Result<string, string>;
}

struct BufferRecorder {
    enabled: bool,
    buffer_size: number,
    entries: RecorderEntry[],
}

impl Recorder for BufferRecorder {
    fn record_request(self, direction: string, payload: string) -> string {
        if !self.enabled {
            return "disabled";
        }
        return "recorded";
    }

    fn record_response(self, direction: string, payload: string) -> string {
        if !self.enabled {
            return "disabled";
        }
        return "recorded";
    }

    fn save_to_file(self, path: string) -> Result<string, string> {
        // FRICTION: No file I/O API in Atlas
        return Err("save_to_file not implemented");
    }
}

fn new_buffer_recorder(buffer_size: number, enabled: bool) -> BufferRecorder {
    let empty_entries: RecorderEntry[] = [];
    return BufferRecorder {
        enabled: enabled,
        buffer_size: buffer_size,
        entries: empty_entries,
    };
}
