// Minimal test

fn test1() -> void {
    print("Test 1: Basic string operations");
    let msg: string = "Hello World";
    print(msg);
}

fn test2() -> void {
    print("Test 2: String concatenation");
    let a: string = "Hello";
    let b: string = "World";
    let c: string = a + " " + b;
    print(c);
}

fn test3() -> void {
    print("Test 3: Object creation");
    let obj: object = {
        name: "test",
        value: 42
    };
    print("Object created");
}

test1();
test2();
test3();
