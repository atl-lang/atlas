// Test exec function
fn main() -> void {
    print("=== Exec Test ===");

    // Test 1: Simple command
    print("Test 1: echo hello");
    let result: object = exec("echo hello");
    print("  stdout: " + result.stdout);
    print("  exit_code: " + str(result.exit_code));
    print("  ✓ exec works");
    print("");

    // Test 2: Command with arguments
    print("Test 2: ls -la");
    let ls_result: object = exec("ls -la");
    print("  exit_code: " + str(ls_result.exit_code));
    print("  ✓ exec with args works");
    print("");

    print("=== Tests Complete ===");
}

main();
