// CLI validate (Atlas port, simplified)
// Source: hydra/internal/cli/validate.go

import { load_registry, validate_config } from "../config/loader";
import { registry_path_from_args, server_name_from_args } from "./pathutil";

export fn cmd_validate(args: json) -> Result<json, string> {
    let reg_path = registry_path_from_args(args);
    let reg = load_registry(reg_path)?;
    if (args["name"].is_null()) {
        return Err("name is required (Atlas cannot iterate registry servers yet)");
    }
    let name = server_name_from_args(args)?;
    let srv = reg["servers"][name];
    if (srv.is_null()) { return Err("server not found: " + name); }
    let _ = validate_config(srv)?;
    return Ok({ name: name, valid: true });
}
