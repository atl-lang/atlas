// CLI init bootstrap (Atlas port, simplified)
// Source: hydra/internal/cli/init_bootstrap.go

import { configure_claude } from "../bootstrap/claude";
import { configure_cline } from "../bootstrap/cline";
import { configure_cursor } from "../bootstrap/cursor";
import { configure_claude_cli } from "../bootstrap/claude_cli";
import { configure_continue } from "../bootstrap/continue";
import { configure_cursor_composer } from "../bootstrap/cursor_composer";

export fn cmd_init_bootstrap(args: json) -> Result<json, string> {
    if (args["client"].is_null()) { return Err("client is required"); }
    let client = args["client"].as_string();
    let path = args["path"].is_null() ? "" : args["path"].as_string();
    let registry = args["registry"].is_null() ? "~/.hydra/config.json" : args["registry"].as_string();
    let dry_run = args["dry_run"].is_null() ? false : args["dry_run"].as_bool();

    if (client == "claude") { configure_claude(path, registry, dry_run)?; return Ok({ ok: true }); }
    if (client == "cline") { configure_cline(path, registry, dry_run)?; return Ok({ ok: true }); }
    if (client == "cursor") { configure_cursor(path, registry, dry_run)?; return Ok({ ok: true }); }
    if (client == "claude-cli") { configure_claude_cli(path, registry, dry_run)?; return Ok({ ok: true }); }
    if (client == "continue") { configure_continue(path, registry, dry_run)?; return Ok({ ok: true }); }
    if (client == "cursor-composer") { configure_cursor_composer(path, registry, dry_run)?; return Ok({ ok: true }); }

    return Err("unknown client: " + client);
}
