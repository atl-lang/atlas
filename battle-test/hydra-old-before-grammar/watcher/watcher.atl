// Watcher (Atlas port, simplified)

export fn new_watcher(paths: array, ignore: array) -> Result<json, string> {
    let obj = { paths: paths, ignore: ignore, events: [] };
    let encoded = toJSON(obj);
    let parsed = parseJSON(encoded)?;
    return Ok(parsed);
}

// Add a synthetic event
export fn push_event(watcher: json, path: string, kind: string) -> Result<json, string> {
    let ev = { path: path, kind: kind };
    let events = watcher["events"] + [ev];
    let obj = { paths: watcher["paths"], ignore: watcher["ignore"], events: events };
    let encoded = toJSON(obj);
    let parsed = parseJSON(encoded)?;
    return Ok(parsed);
}

export fn drain_events(watcher: json) -> Result<array, string> {
    return Ok(watcher["events"]);
}
