// Registry management (Atlas port)
// Source: /Users/proxikal/dev/projects/hydra/internal/config/registry.go

// Save registry to disk
export fn save_registry(registry: hashmap, path: string) -> Result<null, string> {
    let mut p = path;
    if (len(p) > 0 && substring(p, 0, 1) == "~") {
        let home = getEnv("HOME");
        if (!home.is_null()) {
            p = pathJoin(home.as_string(), substring(p, 1, len(p)));
        }
    }

    let dir = pathDirname(p);
    let _ = createDir(dir);

    let json_str = toJSON(registry);
    let pretty = prettifyJSON(json_str, 2);
    writeFile(p, pretty);
    return Ok(null);
}

// Add or update a server in registry
export fn add_server(registry: hashmap, name: string, cfg: hashmap) -> hashmap {
    let servers_opt = hashMapGet(registry, "servers");
    let servers = match servers_opt {
        Some(val) => val,
        None => hashMapNew()
    };

    let updated_servers = hashMapPut(servers, name, cfg);
    let updated_registry = hashMapPut(registry, "servers", updated_servers);
    return updated_registry;
}

// Remove server; returns [updated_registry, removed]
export fn remove_server(registry: hashmap, name: string) -> array {
    let servers_opt = hashMapGet(registry, "servers");
    let servers = match servers_opt {
        Some(val) => val,
        None => hashMapNew()
    };

    let has = hashMapHas(servers, name);
    let result = hashMapRemove(servers, name);
    // remove returns [Option<Value>, modified HashMap]
    let updated_servers = result[1];
    let updated_registry = hashMapPut(registry, "servers", updated_servers);
    return [updated_registry, has];
}

// List server names
export fn list_servers(registry: hashmap) -> array {
    let servers_opt = hashMapGet(registry, "servers");
    let servers = match servers_opt {
        Some(val) => val,
        None => hashMapNew()
    };
    return hashMapKeys(servers);
}
