// Cursor Composer bootstrap (Atlas port)
// Source: hydra/internal/bootstrap/cursor_composer.go

import { configure_generic_mcp } from "./generic";
import { detect_client_config_path } from "./pathutil";

export fn configure_cursor_composer(path: string, registry_path: string, dry_run: bool) -> Result<null, string> {
    let p = path;
    if (len(p) == 0) {
        p = detect_client_config_path("cursor-composer")?;
    }
    return configure_generic_mcp(p, registry_path, dry_run, "cursor-composer");
}
