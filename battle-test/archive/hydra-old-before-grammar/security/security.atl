// Security facade (Atlas port)

import { new_redactor, redact } from "./redact";
import { new_rate_limiter, allow, reset } from "./ratelimit";
import { limit_response } from "./sizelimit";

export fn redact_string(content: string, patterns: array, replacement: string) -> string {
    let red = new_redactor(replacement)?;
    return redact(red, content, patterns);
}

export fn rate_allow(rate: number, interval_seconds: number, state: json) -> Result<array, string> {
    let rl = state.is_null() ? new_rate_limiter(rate, interval_seconds)? : state;
    return allow(rl);
}

export fn size_limit(result_json: string, max_kb: number) -> string {
    return limit_response(result_json, max_kb);
}
