// StateStore - Session State Persistence
//
// Manages session state storage using Atlas file I/O
// Works with JSON strings - use parseJSON() and toJSON() in calling code

// Create a state store path for a session
export fn new_store(borrow session_id: string) -> string {
    return ".hydra/sessions/" + session_id + ".json";
}

// Ensure directory exists for state store
fn ensure_dir() -> void {
    // Check if directory exists
    let dir_path: string = ".hydra/sessions";
    let exists: bool = fsIsDir(dir_path);

    if (!exists) {
        // Create directory
        createDir(dir_path);
    }
}

// Save state to disk (takes JSON string)
export fn save_state(borrow store_path: string, borrow json_str: string) -> bool {
    // Ensure directory exists
    ensure_dir();

    // Write to file
    writeFile(store_path, json_str);

    return true;
}

// Load state from disk (returns JSON string)
export fn load_state(borrow store_path: string) -> string {
    // Read file
    let content: string = readFile(store_path);
    return content;
}

// Check if state exists
export fn has_state(borrow store_path: string) -> bool {
    return fsIsFile(store_path);
}

// Clear state (write empty object)
export fn clear_state(borrow store_path: string) -> bool {
    let empty: string = "{}";
    writeFile(store_path, empty);
    return true;
}

// Delete state file
export fn delete_state(borrow store_path: string) -> bool {
    removeFile(store_path);
    return true;
}
