// Supervisor - Process Lifecycle Management (json-based)
// Source: /Users/proxikal/dev/projects/hydra/internal/supervisor/process.go

// NOTE: Atlas exec() is synchronous; no async process monitoring.

export fn state_stopped() -> string { return "STOPPED"; }
export fn state_starting() -> string { return "STARTING"; }
export fn state_running() -> string { return "RUNNING"; }
export fn state_restarting() -> string { return "RESTARTING"; }
export fn state_failed() -> string { return "FAILED"; }

export fn new_supervisor_state(borrow max_restarts: number, borrow restart_window_seconds: number) -> Result<json, string> {
    let obj = {
        state: state_stopped(),
        restart_count: 0,
        max_restarts: max_restarts,
        restart_window_seconds: restart_window_seconds,
        last_exit_code: -1,
        restart_times: [],
        start_time_ms: 0
    };
    let encoded = toJSON(obj);
    let parsed = parseJSON(encoded)?;
    return Ok(parsed);
}

// Execute command synchronously
export fn execute_command(borrow command: array) -> Result<json, string> {
    return exec(command);
}

export fn check_success(borrow output: json) -> bool {
    // Expect { exitCode: number, stdout: string, stderr: string }
    if (output["exitCode"].is_null()) { return false; }
    return output["exitCode"].as_number() == 0;
}

// Restart loop (synchronous) - best effort
export fn run_with_retry(borrow command: array, borrow max_attempts: number) -> bool {
    let mut succeeded = false;
    for (let mut i = 0; i < max_attempts; i = i + 1) {
        let out = execute_command(command);
        match out {
            Ok(data) => {
                if (check_success(data)) { succeeded = true; break; }
            },
            Err(_) => {}
        }
    }
    return succeeded;
}

export fn start_supervisor(borrow command: array, borrow max_restarts: number, borrow restart_window_seconds: number) -> Result<string, string> {
    let out = execute_command(command);
    match out {
        Ok(data) => {
            if (check_success(data)) { return Ok(state_running()); }
        },
        Err(_) => {}
    }

    let restarted = run_with_retry(command, max_restarts);
    if (restarted) { return Ok(state_running()); }
    return Ok(state_failed());
}
