// Test exec with array arguments
fn main() -> void {
    print("=== Exec Array Test ===");

    // Test 1: echo with arguments
    print("Test 1: echo with args");
    let cmd: array = ["echo", "Hello", "World"];
    let result: Result<json, string> = exec(cmd);

    let success: bool = match result {
        Ok(_) => true,
        Err(_) => false
    };

    if (success) {
        print("  ✓ exec succeeded");

        let output: json = match result {
            Ok(data) => data,
            Err(_) => null
        };

        let stdout_val: json = output.stdout;
        print("  stdout: " + stdout_val);
    }
    print("");

    print("=== Test Complete ===");
}

main();
