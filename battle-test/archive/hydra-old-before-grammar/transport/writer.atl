// Transport Writer for Hydra Atlas (json-based)

import { protocol_lsp, protocol_ndjson } from "./types";

export fn format_lsp(borrow payload: string) -> string {
    let content_length = len(payload);
    let header = "Content-Length: " + str(content_length) + "\r\n\r\n";
    return header + payload;
}

export fn format_ndjson(borrow payload: string) -> string {
    if (len(payload) == 0 || !endsWith(payload, "\n")) {
        return payload + "\n";
    }
    return payload;
}

export fn format_message(borrow payload: string, borrow protocol: string) -> Result<string, string> {
    if (protocol == protocol_lsp()) {
        return Ok(format_lsp(payload));
    }
    if (protocol == protocol_ndjson()) {
        return Ok(format_ndjson(payload));
    }
    return Err("Unknown protocol");
}

export fn validate_jsonrpc(borrow payload: string) -> Result<null, string> {
    if (!isValidJSON(payload)) {
        return Err("Invalid JSON");
    }

    let obj = parseJSON(payload)?;

    if (obj["jsonrpc"].is_null()) {
        return Err("Missing 'jsonrpc' field");
    }

    if (obj["jsonrpc"].as_string() != "2.0") {
        return Err("Unsupported jsonrpc version: " + obj["jsonrpc"].as_string());
    }

    let has_method = !obj["method"].is_null();
    let has_result = !obj["result"].is_null();
    let has_error = !obj["error"].is_null();

    if (!has_method && !has_result && !has_error) {
        return Err("Message must have 'method', 'result', or 'error'");
    }

    return Ok(null);
}
