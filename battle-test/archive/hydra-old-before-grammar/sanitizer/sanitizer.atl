// Sanitizer - Stdio Filtering
//
// Filters out noise from stdout/stderr to keep JSON-RPC stream clean

// Check if line looks like JSON-RPC
export fn is_jsonrpc_line(line: string) -> bool {
    let trimmed: string = trim(line);

    // Must start with {
    if (len(trimmed) == 0) {
        return false;
    }

    let first_char: string = substring(trimmed, 0, 1);
    if (first_char != "{") {
        return false;
    }

    // Try to parse as JSON
    let result: Result<json, string> = parseJSON(trimmed);

    // Match as expression - returns bool
    let is_valid: bool = match result {
        Ok(data) => true,
        Err(_) => false
    };

    return is_valid;
}

// Check if line is noise (should be filtered)
export fn is_noise_line(line: string) -> bool {
    let trimmed: string = trim(line);

    if (len(trimmed) == 0) {
        return true;
    }

    // Common noise patterns
    if (startsWith(trimmed, "[DEBUG]")) { return true; }
    if (startsWith(trimmed, "[INFO]")) { return true; }
    if (startsWith(trimmed, "[WARN]")) { return true; }
    if (startsWith(trimmed, "Warning:")) { return true; }
    if (startsWith(trimmed, "Error:")) { return true; }
    if (startsWith(trimmed, "at ")) { return true; }

    return false;
}

// Filter a line: return true if should keep
export fn should_keep_line(line: string) -> bool {
    // If it's valid JSON-RPC, keep it
    if (is_jsonrpc_line(line)) {
        return true;
    }

    // If it's noise, drop it
    if (is_noise_line(line)) {
        return false;
    }

    // Unknown: keep by default
    return true;
}

// Filter multiple lines
export fn filter_output(output: string) -> string {
    let lines: array = split(output, "\n");
    let mut result: string = "";
    let mut first: bool = true;

    for line in lines {
        if (should_keep_line(line)) {
            if (!first) {
                result = result + "\n";
            }
            result = result + line;
            first = false;
        }
    }

    return result;
}
