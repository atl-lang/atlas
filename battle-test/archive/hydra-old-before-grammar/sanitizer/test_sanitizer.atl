// Test Sanitizer
import {
    is_jsonrpc_line,
    is_noise_line,
    should_keep_line,
    filter_output
} from "./sanitizer";

fn main() -> void {
    print("=== Sanitizer Tests ===");
    print("");

    // Test 1: JSON-RPC detection
    print("Test 1: JSON-RPC Detection");
    let jsonrpc: string = "{\"jsonrpc\":\"2.0\",\"method\":\"initialize\",\"id\":1}";

    if (is_jsonrpc_line(jsonrpc)) {
        print("  ✓ JSON-RPC line detected correctly");
    }
    print("");

    // Test 2: Noise detection
    print("Test 2: Noise Detection");
    let debug: string = "[DEBUG] Some debug message";
    let info: string = "[INFO] Server starting";

    let is_debug_noise: bool = is_noise_line(debug);
    let is_info_noise: bool = is_noise_line(info);

    if (is_debug_noise) {
        print("  ✓ DEBUG noise detected");
    }
    if (is_info_noise) {
        print("  ✓ INFO noise detected");
    }
    print("");

    // Test 3: Line filtering
    print("Test 3: Line Filtering");
    let good_line: string = "{\"jsonrpc\":\"2.0\",\"result\":true}";
    let bad_line: string = "[DEBUG] Internal state";

    if (should_keep_line(good_line)) {
        print("  ✓ JSON-RPC line kept");
    }
    if (!should_keep_line(bad_line)) {
        print("  ✓ Noise line filtered");
    }
    print("");

    // Test 4: Multi-line filtering
    print("Test 4: Multi-line Filtering");
    let mixed: string = "[DEBUG] Starting\n{\"jsonrpc\":\"2.0\"}\n[INFO] Done";
    let filtered: string = filter_output(mixed);

    print("  Input lines: 3");
    print("  Output: " + filtered);
    print("  ✓ Multi-line filtering works");
    print("");

    print("=== Tests Complete ===");
}

main();
