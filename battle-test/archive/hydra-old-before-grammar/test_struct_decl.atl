// Test struct declarations + expressions together
// Note: Declarations are parsed but don't add runtime type checking yet

// Struct declaration (parses, provides documentation)
struct User {
    name: string,
    age: number,
    active: bool
}

struct Point {
    x: number,
    y: number
}

struct Config {
    host: string,
    port: number,
    debug: bool
}

fn main() -> void {
    print("=== Struct Declaration + Expression Test ===");
    print("");
    
    // Test 1: User struct
    print("Test 1: User struct");
    let user = User { name: "Bob", age: 25, active: true };
    print("  User: " + toJSON(user));
    print("  ✓ User created");
    print("");
    
    // Test 2: Point struct  
    print("Test 2: Point struct");
    let p1 = Point { x: 0, y: 0 };
    let p2 = Point { x: 10, y: 20 };
    print("  P1: " + toJSON(p1));
    print("  P2: " + toJSON(p2));
    print("  ✓ Points created");
    print("");
    
    // Test 3: Config struct
    print("Test 3: Config struct");
    let cfg = Config { 
        host: "localhost",
        port: 8080,
        debug: false
    };
    print("  Config: " + toJSON(cfg));
    print("  ✓ Config created");
    print("");
    
    // Test 4: Access fields
    print("Test 4: Access struct fields");
    let host = unwrap(hashMapGet(cfg, "host"));
    let port = unwrap(hashMapGet(cfg, "port"));
    print("  Host: " + host);
    print("  Port: " + str(port));
    print("  ✓ Field access works");
    print("");
    
    print("=== All Tests Passed ===");
}

main();
