// State manager (Atlas port, simplified)

export fn new_manager(borrow state_dir: string) -> Result<json, string> {
    let obj = { state_dir: state_dir };
    let encoded = toJSON(obj);
    let parsed = parseJSON(encoded)?;
    return Ok(parsed);
}

export fn save_state(borrow mgr: json, borrow server_name: string, borrow pid: number, borrow metrics_snapshot: json) -> Result<null, string> {
    let dir = mgr["state_dir"].as_string();
    let _ = createDir(dir);
    let state = { server_name: server_name, pid: pid, metrics: metrics_snapshot };
    let json_str = prettifyJSON(toJSON(state), 2);
    let path = pathJoin(dir, server_name + ".json");
    writeFile(path, json_str);
    return Ok(null);
}

export fn load_state(borrow mgr: json, borrow server_name: string) -> Result<json, string> {
    let path = pathJoin(mgr["state_dir"].as_string(), server_name + ".json");
    let data = readFile(path);
    let parsed = parseJSON(data)?;
    return Ok(parsed);
}

export fn delete_state(borrow mgr: json, borrow server_name: string) -> Result<null, string> {
    let path = pathJoin(mgr["state_dir"].as_string(), server_name + ".json");
    if (fsIsFile(path)) { removeFile(path); }
    return Ok(null);
}
