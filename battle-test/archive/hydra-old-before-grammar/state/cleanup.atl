// State cleanup (Atlas port, simplified)
// Source: hydra/internal/state/cleanup.go

// Without process APIs, we cannot validate PIDs. This function only validates
// JSON state file readability and returns Ok even if no cleanup is possible.
export fn cleanup_stale_states(borrow state_dir: string) -> Result<null, string> {
    if (!fsIsDir(state_dir)) { return Ok(null); }
    let entries = readDir(state_dir);
    for name in entries {
        let path = pathJoin(state_dir, name.as_string());
        if (fsIsFile(path)) {
            let data = readFile(path);
            if (!isValidJSON(data)) {
                // Remove corrupted state files as a best-effort cleanup.
                removeFile(path);
            }
        }
    }
    return Ok(null);
}
