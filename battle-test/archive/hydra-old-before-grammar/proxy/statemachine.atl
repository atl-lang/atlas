// State machine (Atlas port) - simplified

export fn handle_initialize_response(borrow proxy: json) -> Result<json, string> {
    let obj = {
        state: "RUNNING",
        queue: proxy["queue"],
        last_error: proxy["last_error"],
        last_restart_reason: proxy["last_restart_reason"],
        started_ms: proxy["started_ms"],
        crash_export_path: proxy["crash_export_path"],
        crash_export_enabled: proxy["crash_export_enabled"]
    };
    let encoded = toJSON(obj);
    let parsed = parseJSON(encoded)?;
    return Ok(parsed);
}
