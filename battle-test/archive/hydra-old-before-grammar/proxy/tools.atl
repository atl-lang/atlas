// Tool merge logic (Atlas port)

import { err_collision } from "./proxy_errors";

// Merge tools lists
export fn merge_tools(borrow child_tools: array, borrow hydra_tools: array, borrow on_collision: string) -> Result<array, string> {
    if (on_collision != "" && on_collision != "error" && on_collision != "warn" && on_collision != "disable_hydra_tool") {
        return Err("invalid collision policy: " + on_collision);
    }

    // Build set of child tool names
    let mut merged = [];
    let mut child_set = [];
    for name in child_tools { child_set = child_set + [name]; }

    // Add hydra tools if no collision
    for tool in hydra_tools {
        let tname = tool["name"].is_null() ? tool.as_string() : tool["name"].as_string();
        let exists = indexOf(toJSON(child_set), "\"" + tname + "\"") != -1;
        if (exists) {
            if (on_collision == "error") {
                return Err(err_collision() + ": " + tname);
            }
            if (on_collision == "warn") {
                continue;
            }
            if (on_collision == "disable_hydra_tool") {
                continue;
            }
        }
        merged = merged + [tool];
    }

    // Add child tools
    for name in child_tools {
        merged = merged + [{ name: name }];
    }

    return Ok(merged);
}
