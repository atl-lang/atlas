// Restart queue (Atlas port)
// Source: /Users/proxikal/dev/projects/hydra/internal/proxy/queue.go

// NOTE: No time API; TTL is ignored.

export fn new_queue(borrow max: number, borrow ttl_seconds: number) -> json {
    let cap = max;
    if (cap <= 0) { cap = 1; }
    let obj = { max: cap, ttl_seconds: ttl_seconds, buf: [] };
    let encoded = toJSON(obj);
    let parsed = parseJSON(encoded)?;
    return parsed;
}

export fn enqueue(borrow queue: json, borrow id: json, borrow payload: string) -> Result<json, string> {
    let buf = queue["buf"];
    if (len(buf) >= queue["max"].as_number()) {
        return Err("restart queue full");
    }
    let item = { id: id, payload: payload };
    let new_buf = buf + [item];
    let obj = { max: queue["max"], ttl_seconds: queue["ttl_seconds"], buf: new_buf };
    let encoded = toJSON(obj);
    let parsed = parseJSON(encoded)?;
    return Ok(parsed);
}

export fn drain(borrow queue: json) -> Result<array, string> {
    let buf = queue["buf"];
    // TTL ignored
    return Ok(buf);
}

export fn size(borrow queue: json) -> number {
    return len(queue["buf"]);
}
