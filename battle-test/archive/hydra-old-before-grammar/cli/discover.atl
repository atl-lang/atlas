// CLI discover (Atlas port, simplified)
// Source: hydra/internal/cli/discover.go

import { scan_paths } from "../discovery/scanner";

export fn cmd_discover(borrow args: json) -> Result<json, string> {
    if (args["paths"].is_null()) { return Err("paths array is required"); }
    let paths = args["paths"];
    let results = scan_paths(paths)?;
    return Ok({ results: results });
}
