// CLI status (Atlas port, simplified)
// Source: hydra/internal/cli/status.go

import { new_manager, load_state } from "../state/manager";

export fn cmd_status(borrow args: json) -> Result<json, string> {
    if (args["name"].is_null()) { return Err("name is required"); }
    let name = args["name"].as_string();
    let dir = args["state_dir"].is_null() ? ".hydra/state" : args["state_dir"].as_string();
    let mgr = new_manager(dir)?;
    let st = load_state(mgr, name)?;
    return Ok(st);
}
