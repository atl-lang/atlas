// CLI run (Atlas port, simplified)
// Source: hydra/internal/cli/run.go

import { execute_command } from "../supervisor/supervisor";
import { resolve_server } from "../config/loader";

export fn cmd_run(borrow args: json) -> Result<json, string> {
    if (!args["command"].is_null()) {
        let cmd = args["command"];
        return execute_command(cmd);
    }

    if (args["name"].is_null()) { return Err("name or command required"); }
    let name = args["name"].as_string();
    let cfg = resolve_server(name, "")?;
    if (cfg["command"].is_null()) { return Err("command missing in config"); }
    let cmd = [cfg["command"].as_string()];
    if (!cfg["args"].is_null()) { cmd = cmd + cfg["args"]; }
    let out = execute_command(cmd)?;
    return Ok(out);
}
