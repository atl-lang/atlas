// CLI root (Atlas port, simplified)

import { cmd_add } from "./add";
import { cmd_discover } from "./discover";
import { cmd_edit } from "./edit";
import { cmd_export } from "./export";
import { cmd_init } from "./init";
import { cmd_init_bootstrap } from "./init_bootstrap";
import { cmd_inspect } from "./inspect";
import { cmd_list } from "./list";
import { cmd_logs } from "./logs";
import { cmd_ps } from "./ps";
import { cmd_recover } from "./recover";
import { cmd_remove } from "./remove";
import { cmd_restart } from "./restart";
import { cmd_run } from "./run";
import { cmd_status } from "./status";
import { cmd_tune } from "./tune";
import { cmd_uninit } from "./uninit";
import { cmd_validate } from "./validate";

export fn execute_args(args: json) -> Result<json, string> {
    if (args["command"].is_null()) { return Err("command is required"); }
    let cmd = args["command"].as_string();

    if (cmd == "add") { return cmd_add(args); }
    if (cmd == "discover") { return cmd_discover(args); }
    if (cmd == "edit") { return cmd_edit(args); }
    if (cmd == "export") { return cmd_export(args); }
    if (cmd == "init") { return cmd_init(args); }
    if (cmd == "init-bootstrap") { return cmd_init_bootstrap(args); }
    if (cmd == "inspect") { return cmd_inspect(args); }
    if (cmd == "list") { return cmd_list(args); }
    if (cmd == "logs") { return cmd_logs(args); }
    if (cmd == "ps") { return cmd_ps(args); }
    if (cmd == "recover") { return cmd_recover(args); }
    if (cmd == "remove") { return cmd_remove(args); }
    if (cmd == "restart") { return cmd_restart(args); }
    if (cmd == "run") { return cmd_run(args); }
    if (cmd == "status") { return cmd_status(args); }
    if (cmd == "tune") { return cmd_tune(args); }
    if (cmd == "uninit") { return cmd_uninit(args); }
    if (cmd == "validate") { return cmd_validate(args); }

    return Err("unknown command: " + cmd);
}

export fn execute() -> Result<json, string> {
    return Err("use execute_args(args) in Atlas port");
}
