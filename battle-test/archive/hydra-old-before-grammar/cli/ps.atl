// CLI ps (Atlas port, simplified)
// Source: hydra/internal/cli/ps.go

export fn cmd_ps(borrow args: json) -> Result<json, string> {
    let dir = args["state_dir"].is_null() ? ".hydra/state" : args["state_dir"].as_string();
    if (!fsIsDir(dir)) { return Ok({ entries: [] }); }
    let entries = readDir(dir);
    let mut results = [];
    for name in entries {
        let path = pathJoin(dir, name.as_string());
        if (fsIsFile(path)) {
            let data = readFile(path);
            if (isValidJSON(data)) {
                let parsed = parseJSON(data)?;
                results = results + [parsed];
            }
        }
    }
    return Ok({ entries: results });
}
