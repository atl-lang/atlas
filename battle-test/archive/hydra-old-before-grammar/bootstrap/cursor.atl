// Cursor bootstrap (Atlas port)
// Source: hydra/internal/bootstrap/cursor.go

import { configure_generic_mcp } from "./generic";
import { detect_client_config_path } from "./pathutil";

export fn configure_cursor(borrow path: string, borrow registry_path: string, borrow dry_run: bool) -> Result<null, string> {
    let p = path;
    if (len(p) == 0) {
        p = detect_client_config_path("cursor")?;
    }
    return configure_generic_mcp(p, registry_path, dry_run, "cursor");
}
