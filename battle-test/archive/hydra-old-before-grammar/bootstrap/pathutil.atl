// Bootstrap path utilities (Atlas port, simplified)
// Source: hydra/internal/bootstrap/pathutil.go

export fn expand_home(borrow path: string) -> string {
    if (len(path) == 0 || substring(path, 0, 1) != "~") {
        return path;
    }
    let home = getEnv("HOME");
    if (home.is_null()) {
        home = getEnv("USERPROFILE");
    }
    if (home.is_null()) {
        return path;
    }
    return pathJoin(home.as_string(), substring(path, 1, len(path)));
}

fn home_dir() -> string {
    let home = getEnv("HOME");
    if (!home.is_null()) { return home.as_string(); }
    let userprofile = getEnv("USERPROFILE");
    if (!userprofile.is_null()) { return userprofile.as_string(); }
    return "";
}

fn first_existing(borrow candidates: array) -> string {
    for p in candidates {
        if (fsIsFile(p)) { return p; }
    }
    if (len(candidates) > 0) { return candidates[0]; }
    return "";
}

export fn config_file_exists(borrow path: string) -> bool {
    return fsIsFile(path);
}

export fn detect_client_config_path(borrow client: string) -> Result<string, string> {
    if (client == "claude") { return Ok(detect_claude_desktop_path()); }
    if (client == "cline") { return Ok(detect_cline_path()); }
    if (client == "cursor") { return Ok(detect_cursor_path()); }
    if (client == "claude-cli") { return Ok(detect_claude_cli_path()); }
    if (client == "continue") { return Ok(detect_continue_path()); }
    if (client == "cursor-composer") { return Ok(detect_cursor_composer_path()); }
    return Err("unknown client: " + client);
}

fn detect_claude_desktop_path() -> string {
    let home = home_dir();
    let candidates = [
        pathJoin(home, "Library/Application Support/Claude/claude_desktop_config.json"),
        pathJoin(home, "AppData/Roaming/Claude/claude_desktop_config.json"),
        pathJoin(home, ".config/Claude/claude_desktop_config.json")
    ];
    return first_existing(candidates);
}

fn detect_cline_path() -> string {
    let home = home_dir();
    let vscode = pathJoin(home, ".vscode/extensions");
    if (fsIsDir(vscode)) {
        return pathJoin(home, ".vscode/mcp_settings.json");
    }
    return pathJoin(home, ".vscodium/mcp_settings.json");
}

fn detect_cursor_path() -> string {
    let home = home_dir();
    let candidates = [
        pathJoin(home, "Library/Application Support/Cursor/User/globalStorage/mcp_settings.json"),
        pathJoin(home, "AppData/Roaming/Cursor/User/globalStorage/mcp_settings.json"),
        pathJoin(home, ".config/Cursor/User/globalStorage/mcp_settings.json")
    ];
    return first_existing(candidates);
}

fn detect_claude_cli_path() -> string {
    let home = home_dir();
    return pathJoin(home, ".config/claude-cli/mcp_config.json");
}

fn detect_continue_path() -> string {
    let home = home_dir();
    return pathJoin(home, ".continue/config.json");
}

fn detect_cursor_composer_path() -> string {
    let home = home_dir();
    let candidates = [
        pathJoin(home, "Library/Application Support/Cursor/mcp_config.json"),
        pathJoin(home, "AppData/Roaming/Cursor/mcp_config.json"),
        pathJoin(home, ".config/Cursor/mcp_config.json")
    ];
    return first_existing(candidates);
}
