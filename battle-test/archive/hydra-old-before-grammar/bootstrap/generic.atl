// Bootstrap generic MCP config (Atlas port, simplified)
// Source: hydra/internal/bootstrap/generic.go

import { load_registry } from "../config/loader";
import { expand_home } from "./pathutil";

fn write_backup(borrow path: string, borrow data: string) -> Result<null, string> {
    let backup = path + ".hydra.bak";
    if (fsIsFile(backup)) {
        return Err("backup already exists at " + backup + " (run uninit first)");
    }
    writeFile(backup, data);
    return Ok(null);
}

export fn configure_generic_mcp(borrow path: string, borrow registry_path: string, borrow dry_run: bool, borrow client: string) -> Result<null, string> {
    let p = expand_home(path);
    let reg_p = expand_home(registry_path);

    let reg = load_registry(reg_p)?;

    if (!fsIsFile(p)) {
        return Err("read " + client + " config: file not found");
    }

    let data = readFile(p);
    let cfg = parseJSON(data)?;

    if (cfg["mcpServers"].is_null()) {
        return Err("no mcpServers found in " + client + " config");
    }

    if (dry_run) {
        return Ok(null);
    }

    let _ = write_backup(p, data)?;

    // NOTE: Atlas JSON does not provide object key iteration yet, so we cannot
    // rewrite all MCP server entries. We preserve config as-is and ensure registry
    // is at least present on disk for follow-up steps.
    if (len(reg_p) > 0) {
        let pretty = prettifyJSON(toJSON(reg), 2);
        writeFile(reg_p, pretty);
    }

    let updated = prettifyJSON(toJSON(cfg), 2);
    writeFile(p, updated);
    return Ok(null);
}
