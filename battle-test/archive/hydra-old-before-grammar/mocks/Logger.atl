// Logger mock (Atlas port, simplified)
// Source: hydra/internal/mocks/Logger.go

export fn new_logger() -> json {
    return { entries: [] };
}

fn append_entry(borrow logger: json, borrow level: string, borrow msg: string) -> json {
    let entries = logger["entries"].is_null() ? [] : logger["entries"];
    let entry = { level: level, msg: msg };
    let updated = entries + [entry];
    return { entries: updated };
}

export fn log_debug(borrow logger: json, borrow msg: string) -> json { return append_entry(logger, "debug", msg); }
export fn log_info(borrow logger: json, borrow msg: string) -> json { return append_entry(logger, "info", msg); }
export fn log_warn(borrow logger: json, borrow msg: string) -> json { return append_entry(logger, "warn", msg); }
export fn log_error(borrow logger: json, borrow msg: string) -> json { return append_entry(logger, "error", msg); }
