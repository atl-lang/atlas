let STATE_STOPPED = "stopped";
let STATE_STARTING = "starting";
let STATE_RUNNING = "running";
let STATE_RESTARTING = "restarting";
let STATE_FAILED = "failed";

fn now_seconds() -> number {
    return dateTimeToTimestamp(dateTimeNow());
}

fn serialize_cmd(cmd: string[]) -> string {
    return join(cmd, "\n");
}

fn deserialize_cmd(raw: string) -> string[] {
    if raw == "" {
        return slice([""], 0, 0);
    }
    return split(raw, "\n");
}

fn get_num(store: HashMap<string, string>, key: string) -> number {
    let mut raw = "";
    let has_key: bool = hash_map_has(store, key);
    if has_key {
        raw = unwrap(hash_map_get(store, key));
    }
    if raw == "" {
        return 0;
    }
    return unwrap(parse_float(raw));
}

fn set_num(store: HashMap<string, string>, key: string, value: number) -> HashMap<string, string> {
    return hash_map_put(store, key, str(value));
}

fn get_str(store: HashMap<string, string>, key: string) -> string {
    let has_key: bool = hash_map_has(store, key);
    if has_key {
        return unwrap(hash_map_get(store, key));
    }
    return "";
}

fn set_str(store: HashMap<string, string>, key: string, value: string) -> HashMap<string, string> {
    return hash_map_put(store, key, value);
}

fn split_lines(value: string) -> string[] {
    let mut parts: string[] = slice([""], 0, 0);
    if value != "" {
        parts = split(value, "\n");
    }
    return parts;
}

fn join_lines(parts: string[]) -> string {
    if len(parts) == 0 {
        return "";
    }
    return join(parts, "\n");
}

export fn new_supervisor(cmd: string[], max_restarts: number, restart_window_seconds: number) -> HashMap<string, string> {
    let mut s = hash_map_new();
    s = set_str(s, "cmd", serialize_cmd(cmd));
    s = set_num(s, "max_restarts", max_restarts);
    s = set_num(s, "restart_window", restart_window_seconds);
    s = set_str(s, "state", STATE_STOPPED);
    s = set_str(s, "pid", "0");
    s = set_str(s, "last_error", "");
    s = set_str(s, "restart_times", "");
    s = set_str(s, "start_time", "0");
    return s;
}

export fn supervisor_start(s: HashMap<string, string>) -> HashMap<string, string> {
    if get_str(s, "state") == STATE_RUNNING || get_str(s, "state") == STATE_STARTING {
        return s;
    }

    let cmd_raw = get_str(s, "cmd");
    let cmd = deserialize_cmd(cmd_raw);
    if len(cmd) == 0 {
        let mut failed = set_str(s, "state", STATE_FAILED);
        failed = set_str(failed, "last_error", "empty command");
        return failed;
    }

    let mut updated = set_str(s, "state", STATE_STARTING);
    let pid = spawn_process(cmd);
    updated = set_str(updated, "pid", str(pid));
    updated = set_num(updated, "start_time", now_seconds());
    updated = set_str(updated, "state", STATE_RUNNING);
    updated = set_str(updated, "last_error", "");
    return updated;
}

export fn supervisor_stop(s: HashMap<string, string>) -> HashMap<string, string> {
    let pid = get_num(s, "pid");
    if pid == 0 {
        return set_str(s, "state", STATE_STOPPED);
    }
    let _ignored = process_kill(pid, 15);
    let mut updated = set_str(s, "pid", "0");
    updated = set_str(updated, "state", STATE_STOPPED);
    return updated;
}

export fn supervisor_poll(s: HashMap<string, string>) -> HashMap<string, string> {
    let pid = get_num(s, "pid");
    if pid == 0 {
        return s;
    }
    let res = process_wait(pid);
    match res {
        Ok(value) => {
            let _ignored = value;
            let mut updated = set_str(s, "pid", "0");
            updated = set_str(updated, "state", STATE_STOPPED);
            return updated;
        },
        Err(msg) => {
            if msg != "still running" {
                let mut updated = set_str(s, "last_error", msg);
                updated = set_str(updated, "state", STATE_FAILED);
                return updated;
            }
        },
    };
    return s;
}

export fn supervisor_record_restart(s: HashMap<string, string>) -> HashMap<string, string> {
    let now = now_seconds();
    let raw = get_str(s, "restart_times");
    let times = split_lines(raw);
    let mut recent: string[] = slice([""], 0, 0);
    for t in times {
        let ts = unwrap(parse_float(t));
        if now - ts <= get_num(s, "restart_window") {
            recent = array_push(recent, t);
        }
    }
    recent = array_push(recent, str(now));
    let mut updated = set_str(s, "restart_times", join_lines(recent));

    if len(recent) > get_num(s, "max_restarts") {
        updated = set_str(updated, "state", STATE_FAILED);
        updated = set_str(updated, "last_error", "crash loop detected");
    }
    return updated;
}

export fn supervisor_restart(s: HashMap<string, string>) -> HashMap<string, string> {
    let s2 = supervisor_record_restart(s);
    if get_str(s2, "state") == STATE_FAILED {
        return s2;
    }
    let stopped = supervisor_stop(s2);
    return supervisor_start(stopped);
}

export fn supervisor_uptime(s: HashMap<string, string>) -> number {
    if get_str(s, "state") != STATE_RUNNING {
        return 0;
    }
    return now_seconds() - get_num(s, "start_time");
}

fn supervisor_fake_running(s: HashMap<string, string>) -> HashMap<string, string> {
    let mut updated = set_str(s, "state", STATE_RUNNING);
    updated = set_num(updated, "start_time", now_seconds());
    return updated;
}

fn test_supervisor_start_and_uptime() -> bool {
    let sup = new_supervisor(["/bin/echo", "hi"], 3, 60);
    let started = supervisor_fake_running(sup);
    assert_equal(get_str(started, "state"), STATE_RUNNING);
    assert_equal(supervisor_uptime(started) >= 0, true);
    let _ignored = supervisor_stop(started);
    return true;
}

fn test_supervisor_crash_loop() -> bool {
    let sup = new_supervisor(["/bin/echo", "hi"], 1, 60);
    let s1 = supervisor_record_restart(sup);
    let s2 = supervisor_record_restart(s1);
    assert_equal(get_str(s2, "state"), STATE_FAILED);
    return true;
}
