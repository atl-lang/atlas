// StateStore is encoded as a string-only map to avoid unsupported record field access.
// Keys:
// - "initialize" => JSON string (or empty)
// - "subs" => newline-delimited URIs
// - "sub_ids" => newline-delimited "uri=id" entries

type StateStore = HashMap<string, string>;

fn store_get(borrow store: StateStore, borrow key: string) -> string {
    let has_key: bool = hash_map_has(store, key);
    if has_key {
        return unwrap(hash_map_get(store, key));
    }
    return "";
}

fn store_set(borrow store: StateStore, borrow key: string, borrow value: string) -> StateStore {
    return hash_map_put(store, key, value);
}

fn split_lines(borrow value: string) -> string[] {
    let mut parts: string[] = slice([""], 0, 0);
    let has_value: bool = value != "";
    if has_value {
        parts = split(value, "\n");
    }
    return parts;
}

fn join_lines(borrow parts: string[]) -> string {
    let is_empty: bool = len(parts) == 0;
    if is_empty {
        return "";
    }
    return join(parts, "\n");
}

export fn new_state_store() -> StateStore {
    let mut store = hash_map_new();
    store = store_set(store, "initialize", "");
    store = store_set(store, "subs", "");
    store = store_set(store, "sub_ids", "");
    return store;
}

export fn state_set_initialize(own store: StateStore, borrow params: json) -> StateStore {
    let updated = store_set(store, "initialize", to_json(params));
    return updated;
}

export fn state_get_initialize(borrow store: StateStore) -> json {
    let raw = store_get(store, "initialize");
    let has_value: bool = raw != "";
    if !has_value {
        return unwrap(parse_json("null"));
    }
    return unwrap(parse_json(raw));
}

export fn state_add_subscription(own store: StateStore, borrow uri: string) -> StateStore {
    let raw = store_get(store, "subs");
    let parts: string[] = split_lines(raw);
    let mut exists = false;
    for p in parts {
        if p == uri {
            exists = true;
        }
    }
    if !exists {
        let updated = array_push(parts, uri);
        let updated_store = store_set(store, "subs", join_lines(updated));
        return updated_store;
    }
    return store;
}

export fn state_remove_subscription(own store: StateStore, borrow uri: string) -> StateStore {
    let raw = store_get(store, "subs");
    let parts: string[] = split_lines(raw);
    let mut filtered: string[] = slice([""], 0, 0);
    for p in parts {
        if p != uri {
            filtered = array_push(filtered, p);
        }
    }
    let updated = store_set(store, "subs", join_lines(filtered));
    return updated;
}

export fn state_get_subscriptions(borrow store: StateStore) -> string[] {
    let raw = store_get(store, "subs");
    return split_lines(raw);
}

export fn state_update_subscription_id(own store: StateStore, borrow uri: string, borrow id: string) -> StateStore {
    let raw = store_get(store, "sub_ids");
    let parts: string[] = split_lines(raw);
    let mut updated: string[] = slice([""], 0, 0);
    let mut found = false;
    for p in parts {
        let matches_uri: bool = starts_with(p, uri + "=");
        if matches_uri {
            updated = array_push(updated, uri + "=" + id);
            found = true;
        } else {
            updated = array_push(updated, p);
        }
    }
    if !found {
        updated = array_push(updated, uri + "=" + id);
    }
    let updated_store = store_set(store, "sub_ids", join_lines(updated));
    return updated_store;
}

export fn state_clear(own store: StateStore) -> StateStore {
    let mut updated = store_set(store, "initialize", "");
    updated = store_set(updated, "subs", "");
    updated = store_set(updated, "sub_ids", "");
    return updated;
}

fn test_state_store_initialize() -> bool {
    let store = new_state_store();
    let msg = unwrap(parse_json("{\"jsonrpc\":\"2.0\"}"));
    let updated = state_set_initialize(store, msg);
    assert_equal(json_as_string(state_get_initialize(updated)["jsonrpc"]), "2.0");
    return true;
}

fn test_state_store_subscriptions() -> bool {
    let store = new_state_store();
    let updated = state_add_subscription(store, "file:///a");
    let updated2 = state_add_subscription(updated, "file:///b");
    let keys = state_get_subscriptions(updated2);
    assert_equal(len(keys), 2);
    let updated3 = state_update_subscription_id(updated2, "file:///a", "1");
    assert_equal(len(state_get_subscriptions(updated3)), 2);
    let updated4 = state_remove_subscription(updated3, "file:///b");
    assert_equal(len(state_get_subscriptions(updated4)), 1);
    return true;
}

fn test_state_store_clear() -> bool {
    let store = new_state_store();
    let updated = state_add_subscription(store, "file:///a");
    let cleared = state_clear(updated);
    assert_equal(len(state_get_subscriptions(cleared)), 0);
    assert_equal(json_is_null(state_get_initialize(cleared)), true);
    return true;
}
