let CHUNK_EMPTY = "empty";
let CHUNK_JSONRPC = "jsonrpc";
let CHUNK_POLLUTION = "pollution";

export fn classify_chunk(borrow chunk: string) -> string {
    let trimmed: string = trim(chunk);
    let is_empty: bool = len(trimmed) == 0;
    if is_empty {
        return CHUNK_EMPTY;
    }
    let valid: bool = is_valid_json(trimmed);
    if !valid {
        return CHUNK_POLLUTION;
    }
    let is_array: bool = starts_with(trimmed, "[");
    if is_array {
        return CHUNK_JSONRPC;
    }
    let parsed = unwrap(parse_json(trimmed));
    let ver = parsed["jsonrpc"];
    let has_ver: bool = !json_is_null(ver);
    if has_ver {
        let ver_str = json_as_string(ver);
        if ver_str == "2.0" {
            return CHUNK_JSONRPC;
        }
    }
    return CHUNK_POLLUTION;
}

export fn validate_utf8(borrow data: string) -> string {
    // Atlas strings are UTF-8; if invalid bytes are present upstream,
    // the runtime already normalized. No-op here.
    return data;
}

fn test_classify_empty() -> bool {
    assert_equal(classify_chunk(""), CHUNK_EMPTY);
    assert_equal(classify_chunk("   \n"), CHUNK_EMPTY);
    return true;
}

fn test_classify_invalid_json() -> bool {
    assert_equal(classify_chunk("{not json}"), CHUNK_POLLUTION);
    return true;
}

fn test_classify_jsonrpc_object() -> bool {
    let msg = "{\"jsonrpc\":\"2.0\",\"id\":1,\"method\":\"ping\"}";
    assert_equal(classify_chunk(msg), CHUNK_JSONRPC);
    return true;
}

fn test_classify_jsonrpc_array() -> bool {
    let msg = "[{\"jsonrpc\":\"2.0\"}]";
    assert_equal(classify_chunk(msg), CHUNK_JSONRPC);
    return true;
}

fn test_classify_valid_json_non_rpc() -> bool {
    let msg = "{\"foo\":\"bar\"}";
    assert_equal(classify_chunk(msg), CHUNK_POLLUTION);
    return true;
}
