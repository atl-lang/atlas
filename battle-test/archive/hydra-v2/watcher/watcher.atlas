fn should_ignore(path: string, ignore: string[]) -> bool {
    let base = pathBasename(path);
    for pat in ignore {
        if base == pat {
            return true;
        }
    }
    return false;
}

export fn watcher_snapshot(paths: string[], ignore: string[]) -> HashMap<string, number> {
    let mut snapshot = hash_map_new();
    for root in paths {
        let entries = read_dir(root);
        for name in entries {
            let full = path_join(root, name);
            if should_ignore(full, ignore) {
                continue;
            }
            let info = file_info(full);
            let is_file: bool = json_as_bool(info["isFile"]);
            if is_file {
                let mtime = json_as_number(info["modified"]);
                snapshot = hash_map_put(snapshot, full, mtime);
            }
        }
    }
    return snapshot;
}

export fn watcher_diff(borrow old_snapshot: HashMap<string, number>, borrow new_snapshot: HashMap<string, number>) -> string[] {
    let mut changed: string[] = slice([""], 0, 0);
    let keys: string[] = hash_map_keys(new_snapshot);
    for key in keys {
        let missing: bool = !hash_map_has(old_snapshot, key);
        if missing {
            changed = array_push(changed, key);
        } else {
            let old_val = unwrap(hash_map_get(old_snapshot, key));
            let new_val = unwrap(hash_map_get(new_snapshot, key));
            let different: bool = old_val != new_val;
            if different {
                changed = array_push(changed, key);
            }
        }
    }
    return changed;
}

fn test_watcher_diff_new_file() -> bool {
    let old = hash_map_new();
    let mut new = hash_map_new();
    new = hash_map_put(new, "a.txt", 10);
    let diff = watcher_diff(old, new);
    assert_equal(len(diff), 1);
    assert_equal(diff[0], "a.txt");
    return true;
}

fn test_watcher_diff_modified_file() -> bool {
    let mut old = hash_map_new();
    let mut new = hash_map_new();
    old = hash_map_put(old, "a.txt", 1);
    new = hash_map_put(new, "a.txt", 2);
    let diff = watcher_diff(old, new);
    assert_equal(len(diff), 1);
    return true;
}
