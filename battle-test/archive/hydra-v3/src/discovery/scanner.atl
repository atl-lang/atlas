import { detect_client_config_path } from "../bootstrap/pathutil";

type Discovery = { client: string, config_path: string, confidence: number, servers: number };

export fn scan_all() -> Discovery[] {
    let clients: string[] = ["claude", "cline", "cursor", "claude-cli", "continue", "cursor-composer"];
    let mut discoveries: Discovery[] = [];
    for client in clients {
        let discovery_result = scan_client(client);
        match discovery_result {
            Ok(discovery) => { discoveries = discoveries + [discovery]; },
            Err(_) => {}
        };
    }
    return discoveries;
}

export fn scan_client(borrow client: string) -> Result<Discovery, string> {
    let path_result = detect_client_config_path(client);
    match path_result {
        Ok(path) => {
            let mut confidence = 0;
            let mut servers = 0;
            if (file_exists(path)) {
                confidence = 0.5;
                let contents = read_file(path);
                match contents {
                    Ok(text) => {
                        let parsed = parseJson(text);
                        match parsed {
                            Ok(value) => {
                                confidence = 0.8;
                                if (jsonHas(value, "mcpServers")) {
                                    servers = 1;
                                    confidence = 1.0;
                                }
                            },
                            Err(_) => {}
                        };
                    },
                    Err(_) => {}
                };
            }
            return Ok(record { client: client, config_path: path, confidence: confidence, servers: servers });
        },
        Err(err) => { return Err(err); }
    };
}
