import { load_registry, save_registry } from "../config/registry";
import { default_server_config_json } from "../config/defaults";

type Discovery = { client: string, config_path: string, confidence: number, servers: number };

export fn resolve_conflicts(
    discoveries: Discovery[]
) -> Discovery[] {
    let mut map: HashMap<string, Discovery> = hash_map_new();
    for d in discoveries {
        let existing = hash_map_get(map, d.client);
        match existing {
            Some(current) => {
                if (d.confidence > current.confidence) {
                    map = hashMapSet(map, d.client, d);
                }
            },
            None() => { map = hashMapSet(map, d.client, d); }
        };
    }
    let mut result: Discovery[] = [];
    for key in hash_map_keys(map) {
        result = result + [unwrap(hash_map_get(map, key))];
    }
    return result;
}

export fn merge_into_registry(
    discoveries: Discovery[],
    registry_path: string
) -> Result<number, string> {
    let registry_result = load_registry(registry_path);
    match registry_result {
        Ok(registry) => {
            let mut updated = registry;
            let mut servers = registry["servers"];
            if (servers == null) {
                servers = to_json(record {});
            }
            let mut added = 0;
            for d in discoveries {
                if (d.confidence < 0.5) {
                    continue;
                }
                let name = d.client + "-server";
                if (jsonHas(servers, name)) {
                    continue;
                }
                servers[name] = default_server_config_json();
                added = added + 1;
            }
            updated["servers"] = servers;
            let _saved = save_registry(registry_path, updated);
            return Ok(added);
        },
        Err(err) => { return Err(err); }
    };
}
