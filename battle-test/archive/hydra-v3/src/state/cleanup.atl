import { state_list_all, state_delete } from "./manager";

export fn cleanup_stale(state_dir: string) -> Result<string[], string> {
    let list_result = state_list_all(state_dir);
    match list_result {
        Ok(states) => {
            let mut removed: string[] = [];
            for state in states {
                let pid = num(state["pid"]);
                if (pid <= 0) {
                    let name = str(state["server_name"]);
                    let _ignored = state_delete(state_dir, name);
                    removed = removed + [name];
                }
            }
            return Ok(removed);
        },
        Err(err) => { return Err(err); }
    };
}
