import { now_iso } from "../common/time";
import { ends_with } from "../common/strings";

export fn state_save(
    borrow state_dir: string,
    borrow server_name: string,
    borrow pid: number,
    borrow metrics_snapshot: json) -> Result<null, string> {
    let _mkdir = create_dir(state_dir);
    let payload = record {
        server_name: server_name,
        pid: pid,
        start_time: now_iso(),
        last_updated: now_iso(),
        metrics: metrics_snapshot
    };
    let json_payload = to_json(payload);
    let text = unwrap(stringifyJson(json_payload));
    let path = path_join([state_dir, server_name + ".json"]);
    return write_file(path, text);
}

export fn state_load(borrow state_dir: string, borrow server_name: string) -> Result<json, string> {
    let path = path_join([state_dir, server_name + ".json"]);
    let contents = read_file(path);
    match contents {
        Ok(text) => { return parseJson(text); },
        Err(err) => { return Err(err); }
    };
}

export fn state_delete(borrow state_dir: string, borrow server_name: string) -> Result<null, string> {
    let path = path_join([state_dir, server_name + ".json"]);
    if (!file_exists(path)) {
        return Ok(null);
    }
    return remove_file(path);
}

export fn state_list_all(borrow state_dir: string) -> Result<json[], string> {
    let _mkdir = create_dir(state_dir);
    let entries_result = read_dir(state_dir);
    match entries_result {
        Ok(entries) => {
            let mut states: json[] = [];
            for entry in entries {
                if (ends_with(entry, ".json")) {
                    let name = slice(entry, 0, len(entry) - 5);
                    let state = state_load(state_dir, name);
                    match state {
                        Ok(value) => { states = states + [value]; },
                        Err(_) => {}
                    };
                }
            }
            return Ok(states);
        },
        Err(err) => { return Err(err); }
    };
}
