// Simple file watcher wrapper.

export fn watch_once(borrow path: string) -> Result<{ kind: string, path: string }, string> {
    let watcher = watchPath(path);
    let event = awaitAsync(watcher);
    if (event == null) {
        return Err("watcher returned null");
    }
    let kind = str(event["kind"]);
    let event_path = str(event["path"]);
    return Ok(record { kind: kind, path: event_path });
}
