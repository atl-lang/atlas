import { default_registry_json } from "./defaults";

export fn load_registry(path: string) -> Result<json, string> {
    if (!file_exists(path)) {
        return Ok(default_registry_json());
    }
    let contents_result = read_file(path);
    match contents_result {
        Ok(contents) => {
            if (trim(contents) == "") {
                return Ok(default_registry_json());
            }
            let parsed = parseJson(contents);
            match parsed {
                Ok(value) => { return Ok(value); },
                Err(err) => { return Err("invalid registry json: " + err); }
            };
        },
        Err(err) => { return Err(err); }
    };
}

export fn save_registry(path: string, payload: json) -> Result<null, string> {
    let text_result = stringifyJson(payload);
    match text_result {
        Ok(text) => { return write_file(path, text); },
        Err(err) => { return Err(err); }
    };
}
