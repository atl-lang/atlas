import { now_seconds } from "../common/time";

type MetricsState = {
    requests_total: number,
    requests_success: number,
    requests_failed: number,
    restarts_total: number,
    queue_waits_total: number,
    latencies_ms: number[],
    queue_waits_ms: number[],
    restart_reasons: HashMap<string, number>,
    start_time: number
};

export fn new_collector() -> MetricsState {
    return record {
        requests_total: 0,
        requests_success: 0,
        requests_failed: 0,
        restarts_total: 0,
        queue_waits_total: 0,
        latencies_ms: [],
        queue_waits_ms: [],
        restart_reasons: hash_map_new(),
        start_time: now_seconds()
    };
}

fn percentiles(borrow values: number[], borrow pct: number) -> number {
    if (len(values) == 0) {
        return 0;
    }
    let sorted = sort(values);
    let idx = num(len(sorted) - 1) * pct;
    let index = floor(idx);
    return sorted[index];
}

fn average(borrow values: number[]) -> number {
    if (len(values) == 0) {
        return 0;
    }
    let mut total = 0;
    for v in values {
        total = total + v;
    }
    return total / num(len(values));
}

fn max_value(borrow values: number[]) -> number {
    if (len(values) == 0) {
        return 0;
    }
    let mut current = values[0];
    for v in values {
        if (v > current) {
            current = v;
        }
    }
    return current;
}

export fn metrics_record_request(
    borrow state: MetricsState,
    borrow duration_ms: number,
    borrow success: bool) -> MetricsState {
    let mut successes = state.requests_success;
    let mut failures = state.requests_failed;
    if (success) {
        successes = successes + 1;
    } else {
        failures = failures + 1;
    }
    return record {
        requests_total: state.requests_total + 1,
        requests_success: successes,
        requests_failed: failures,
        restarts_total: state.restarts_total,
        queue_waits_total: state.queue_waits_total,
        latencies_ms: state.latencies_ms + [duration_ms],
        queue_waits_ms: state.queue_waits_ms,
        restart_reasons: state.restart_reasons,
        start_time: state.start_time
    };
}

export fn metrics_record_queue_wait(
    borrow state: MetricsState,
    borrow duration_ms: number) -> MetricsState {
    return record {
        requests_total: state.requests_total,
        requests_success: state.requests_success,
        requests_failed: state.requests_failed,
        restarts_total: state.restarts_total,
        queue_waits_total: state.queue_waits_total + 1,
        latencies_ms: state.latencies_ms,
        queue_waits_ms: state.queue_waits_ms + [duration_ms],
        restart_reasons: state.restart_reasons,
        start_time: state.start_time
    };
}

export fn metrics_record_restart(
    borrow state: MetricsState,
    borrow reason: string) -> MetricsState {
    let mut reasons = state.restart_reasons;
    let existing = hash_map_get(reasons, reason);
    match existing {
        Some(value) => { reasons = hashMapSet(reasons, reason, value + 1); },
        None() => { reasons = hashMapSet(reasons, reason, 1); }
    };
    return record {
        requests_total: state.requests_total,
        requests_success: state.requests_success,
        requests_failed: state.requests_failed,
        restarts_total: state.restarts_total + 1,
        queue_waits_total: state.queue_waits_total,
        latencies_ms: state.latencies_ms,
        queue_waits_ms: state.queue_waits_ms,
        restart_reasons: reasons,
        start_time: state.start_time
    };
}

export fn metrics_snapshot(borrow state: MetricsState) -> {
    requests_total: number,
    requests_success: number,
    requests_failed: number,
    restarts_total: number,
    queue_waits_total: number,
    avg_latency_ms: number,
    p50_latency_ms: number,
    p95_latency_ms: number,
    p99_latency_ms: number,
    max_latency_ms: number,
    avg_queue_wait_ms: number,
    max_queue_wait_ms: number,
    start_time: number,
    uptime_seconds: number,
    restart_reasons: HashMap<string, number>
} {
    let avg_latency = average(state.latencies_ms);
    let max_latency = max_value(state.latencies_ms);
    let avg_queue = average(state.queue_waits_ms);
    let max_queue = max_value(state.queue_waits_ms);
    return record {
        requests_total: state.requests_total,
        requests_success: state.requests_success,
        requests_failed: state.requests_failed,
        restarts_total: state.restarts_total,
        queue_waits_total: state.queue_waits_total,
        avg_latency_ms: avg_latency,
        p50_latency_ms: percentiles(state.latencies_ms, 0.50),
        p95_latency_ms: percentiles(state.latencies_ms, 0.95),
        p99_latency_ms: percentiles(state.latencies_ms, 0.99),
        max_latency_ms: max_latency,
        avg_queue_wait_ms: avg_queue,
        max_queue_wait_ms: max_queue,
        start_time: state.start_time,
        uptime_seconds: now_seconds() - state.start_time,
        restart_reasons: state.restart_reasons
    };
}

export fn metrics_health_breakdown(borrow state: MetricsState) -> { uptime_stability: number, error_rate: number, response_latency: number, queue_depth: number, restart_frequency: number } {
    let uptime = now_seconds() - state.start_time;
    let mut uptime_score = 0;
    if (uptime > 3600) {
        uptime_score = 100;
    } else {
        uptime_score = num(uptime / 36);
    }
    let mut err_rate = 0;
    if (state.requests_total == 0) {
        err_rate = 0;
    } else {
        err_rate = (state.requests_failed / state.requests_total) * 100;
    }
    let error_score = 100 - min(err_rate, 100);
    let latency = average(state.latencies_ms);
    let mut latency_score = 0;
    if (latency <= 100) {
        latency_score = 100;
    } else {
        latency_score = max(0, 100 - (latency / 10));
    }
    let mut queue_score = 0;
    if (average(state.queue_waits_ms) <= 10) {
        queue_score = 100;
    } else {
        queue_score = max(0, 100 - average(state.queue_waits_ms));
    }
    let mut restart_score = 0;
    if (state.restarts_total == 0) {
        restart_score = 100;
    } else {
        restart_score = max(0, 100 - state.restarts_total * 5);
    }
    return record {
        uptime_stability: uptime_score,
        error_rate: error_score,
        response_latency: latency_score,
        queue_depth: queue_score,
        restart_frequency: restart_score
    };
}

export fn metrics_health_score(borrow state: MetricsState) -> number {
    let breakdown = metrics_health_breakdown(state);
    let score = breakdown.uptime_stability * 0.30
        + breakdown.error_rate * 0.25
        + breakdown.response_latency * 0.20
        + breakdown.queue_depth * 0.15
        + breakdown.restart_frequency * 0.10;
    return floor(score);
}
