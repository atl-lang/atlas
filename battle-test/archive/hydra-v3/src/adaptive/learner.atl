import { now_seconds } from "../common/time";

type Observation = { timestamp: number, event: string, context: HashMap<string, json> };
type Learner = { observations: Observation[] };
type Suggestion = { parameter: string, current: number, suggested: number, confidence: number, reason: string };

export fn new_learner() -> Learner {
    return record { observations: [] };
}

export fn learner_observe(
    borrow learner: Learner,
    borrow event: string,
    borrow context: HashMap<string, json>) -> Learner {
    let obs = record { timestamp: now_seconds(), event: event, context: context };
    return record { observations: learner.observations + [obs] };
}

fn count_event(borrow observations: Observation[], borrow target: string) -> number {
    let mut count = 0;
    for obs in observations {
        if (obs.event == target) {
            count = count + 1;
        }
    }
    return count;
}

export fn learner_analyze(
    borrow learner: Learner,
    borrow snapshot: { restarts_total: number, borrow avg_latency_ms: number, borrow avg_queue_wait_ms: number },
    borrow config: HashMap<string, number>) -> Suggestion[] {
    let mut suggestions: Suggestion[] = [];

    let max_restarts = unwrapOr(hash_map_get(config, "max_restarts"), 0);
    if (max_restarts > 0) {
        let restarts_observed = count_event(learner.observations, "restart");
        if (restarts_observed >= 5 && snapshot.restarts_total > 0) {
            let utilization = snapshot.restarts_total / max_restarts;
            if (utilization < 0.5) {
                let mut suggested = floor(snapshot.restarts_total * 1.5);
                if (suggested < 3) {
                    suggested = 3;
                }
                if (suggested < max_restarts) {
                    let confidence = min(1, restarts_observed / 8);
                    suggestions = suggestions + [record {
                        parameter: "max_restarts",
                        current: max_restarts,
                        suggested: suggested,
                        confidence: confidence,
                        reason: "Restart count consistently below threshold"
                    }];
                }
            }
        }
    }

    let queue_size = unwrapOr(hash_map_get(config, "queue_size"), 0);
    if (queue_size > 0) {
        let queue_full = count_event(learner.observations, "queue_full");
        if (queue_full >= 10) {
            let suggested = floor(queue_size * 1.5);
            let confidence = min(1, queue_full / 30);
            suggestions = suggestions + [record {
                parameter: "queue_size",
                current: queue_size,
                suggested: suggested,
                confidence: confidence,
                reason: "Queue frequently near capacity"
            }];
        }
    }

    let debounce_ms = unwrapOr(hash_map_get(config, "debounce_ms"), 0);
    if (debounce_ms > 0) {
        let high_latency = count_event(learner.observations, "high_latency");
        if (high_latency > 5) {
            let suggested = debounce_ms * 2;
            let confidence = min(1, high_latency / 15);
            suggestions = suggestions + [record {
                parameter: "debounce_ms",
                current: debounce_ms,
                suggested: suggested,
                confidence: confidence,
                reason: "Latency spikes correlate with restarts"
            }];
        }
    }

    let crash_loops = count_event(learner.observations, "crash_loop");
    if (crash_loops > 0) {
        let delay = unwrapOr(hash_map_get(config, "restart_delay_ms"), 0);
        let suggested = delay + 500;
        let confidence = min(1, crash_loops / 5);
        suggestions = suggestions + [record {
            parameter: "restart_delay_ms",
            current: delay,
            suggested: suggested,
            confidence: confidence,
            reason: "Crash loops detected"
        }];
    }

    return suggestions;
}
