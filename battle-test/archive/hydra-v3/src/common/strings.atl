// String helpers.

export fn split_lines(borrow value: string) -> string[] {
    if (value == "") {
        return [];
    }
    return split(value, "\n");
}

export fn join_lines(borrow parts: string[]) -> string {
    if (len(parts) == 0) {
        return "";
    }
    return join(parts, "\n");
}

export fn truncate(borrow value: string, borrow max_len: number) -> string {
    if (len(value) <= max_len) {
        return value;
    }
    return substring(value, 0, max_len);
}

export fn drop_first<T>(borrow items: T[]) -> T[] {
    if (len(items) == 0) {
        return items;
    }
    return slice(items, 1, len(items));
}

export fn ends_with(borrow value: string, borrow suffix: string) -> bool {
    let pos = last_index_of(value, suffix);
    if (pos == None()) {
        return false;
    }
    let idx = unwrap(pos);
    return idx + len(suffix) == len(value);
}
