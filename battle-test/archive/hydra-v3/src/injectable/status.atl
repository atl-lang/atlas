export fn build_status_response(
    borrow server_name: string,
    borrow snapshot: { state: string, borrow pid: number, borrow uptime_seconds: number, borrow restarts_in_window: number, borrow last_restart_reason: string, borrow last_error: string, borrow queue_size: number, borrow can_recover: bool },
    borrow behavior: { max_restarts: number, borrow restart_window_seconds: number }) -> json {
    let payload = record {
        state: snapshot.state,
        server_name: server_name,
        pid: snapshot.pid,
        uptime_seconds: snapshot.uptime_seconds,
        restarts_in_window: snapshot.restarts_in_window,
        max_restarts: behavior.max_restarts,
        restart_window_seconds: behavior.restart_window_seconds,
        last_restart_reason: snapshot.last_restart_reason,
        last_error: snapshot.last_error,
        queue_size: snapshot.queue_size,
        can_recover: snapshot.can_recover
    };
    return to_json(payload);
}
