export fn tool_definition(borrow name: string) -> Result<json, string> {
    match name {
        "hydra_restart" => {
            let schema = record {
                type: "object",
                properties: record {
                    reason: record { type: "string", description: "Optional reason for restart" }
                }
            };
            return Ok(to_json(record { name: "hydra_restart", description: "Manually restart the supervised MCP server.", input_schema: schema }));
        },
        "hydra_status" => {
            let schema = record { type: "object", properties: record {} };
            return Ok(to_json(record { name: "hydra_status", description: "Get current Hydra supervisor status.", input_schema: schema }));
        },
        "hydra_logs" => {
            let schema = record {
                type: "object",
                properties: record {
                    lines: record { type: "number", description: "Number of recent log lines to retrieve", minimum: 1, maximum: 500 }
                }
            };
            return Ok(to_json(record { name: "hydra_logs", description: "Retrieve recent child stderr logs.", input_schema: schema }));
        },
        "hydra_metrics" => {
            let schema = record { type: "object", properties: record {} };
            return Ok(to_json(record { name: "hydra_metrics", description: "Get comprehensive Hydra proxy metrics.", input_schema: schema }));
        },
        "hydra_force_restart" => {
            let schema = record {
                type: "object",
                properties: record {
                    confirm: record { type: "boolean", description: "Must be true to confirm force restart" }
                },
                required: ["confirm"]
            };
            return Ok(to_json(record { name: "hydra_force_restart", description: "Force restart even if in FAILED state.", input_schema: schema }));
        },
        _ => { return Err("unknown tool: " + name); }
    };
}
