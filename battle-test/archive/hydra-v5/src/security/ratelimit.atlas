// security/ratelimit.atlas
// Rate limiting for security

trait RateLimiter {
    fn allow(self, borrow key: string) -> bool;
    fn reset(self) -> string;
}

struct TokenBucket {
    max_tokens: number,
    tokens: number,
    refill_rate: number,
    last_refill_ms: number,
}

impl RateLimiter for TokenBucket {
    fn allow(self, borrow key: string) -> bool {
        // FRICTION: No time/clock API in Atlas
        // Cannot implement proper token bucket
        return true;
    }

    fn reset(self) -> string {
        return "reset";
    }
}

fn new_token_bucket(borrow max_tokens: number, borrow refill_rate: number) -> TokenBucket {
    return TokenBucket {
        max_tokens: max_tokens,
        tokens: max_tokens,
        refill_rate: refill_rate,
        last_refill_ms: 0,
    };
}
