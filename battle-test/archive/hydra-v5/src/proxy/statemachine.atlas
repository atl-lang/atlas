// Top-level match example (this works):
let example_match = match ProxyState::Stopped {
    ProxyState::Stopped => "can transition to Starting",
    ProxyState::Starting => "can transition to Running",
    ProxyState::Running => "can transition to Restarting",
    ProxyState::Restarting => "can transition to Running or Failed",
    ProxyState::Failed => "can transition to Stopped",
};
