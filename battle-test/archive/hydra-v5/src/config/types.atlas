// config/types.atlas
// Configuration types for server management

// Defaults holds system-wide default values for all servers
struct Defaults {
    debounce_ms: number,                     // file watcher debounce
    graceful_shutdown_ms: number,            // grace period for shutdown
    max_output_size_kb: number,              // max response size
    log_rate_limit_per_second: number,       // logging rate limit
    restart_queue_max_messages: number,      // max queued messages during restart
    restart_queue_ttl_seconds: number,       // message TTL in queue
    restart_timeout_seconds: number,         // timeout for restart completion
}

// Default values for development
fn default_defaults() -> Defaults {
    return Defaults {
        debounce_ms: 500,
        graceful_shutdown_ms: 3000,
        max_output_size_kb: 10240,
        log_rate_limit_per_second: 100,
        restart_queue_max_messages: 100,
        restart_queue_ttl_seconds: 30,
        restart_timeout_seconds: 10,
    };
}

// WatchConfig configures file watching for hot-reload
struct WatchConfig {
    enabled: bool,
    paths: string[],          // directories to watch
    extensions: string[],     // file extensions to watch (.go, .ts, etc.)
    ignore_files: string[],   // specific files to ignore
    ignore: string[],         // ignore patterns
}

// Default watch config (disabled)
fn default_watch_config() -> WatchConfig {
    let empty_paths: string[] = [];
    let empty_extensions: string[] = [];
    let empty_ignore: string[] = [];
    return WatchConfig {
        enabled: false,
        paths: empty_paths,
        extensions: empty_extensions,
        ignore_files: empty_ignore,
        ignore: empty_ignore,
    };
}

// BehaviorConfig controls restart and crash loop behavior
struct BehaviorConfig {
    debounce_ms: number,
    restart_delay_ms: number,
    max_restarts: number,
    graceful_shutdown_ms: number,
    restart_window_seconds: number,
    pre_restart_command: string,
}

// InjectableToolsConfig configures hydra_* tool injection
struct InjectableToolsConfig {
    enabled: bool,
    tools: string[],          // list of tool names
    on_collision: string,     // "ignore" or "merge"
}

// RecorderConfig configures traffic recorder
struct RecorderConfig {
    enabled: bool,
    buffer_size: number,
    include_request_bodies: bool,
    include_response_bodies: bool,
    export_on_crash: bool,
    export_path: string,
}

// SecurityConfig holds redaction patterns and replacement
struct SecurityConfig {
    redact_patterns: string[],
    redact_replacement: string,
}

// ServerConfig represents a single MCP server configuration
struct ServerConfig {
    command: string,
    args: string[],
    cwd: string,
    env_file: string,
    environment: HashMap<string, string>,
    watch: WatchConfig,
    behavior: BehaviorConfig,
    injectable_tools: InjectableToolsConfig,
    recorder: RecorderConfig,
    security: SecurityConfig,
}

// Default server configuration
fn default_server_config() -> ServerConfig {
    let empty_args: string[] = [];
    // FRICTION: Cannot initialize HashMap with {} literal
    // Must use hashMapNew() to create empty HashMap
    let empty_env = hashMapNew();
    let empty_tools: string[] = [];
    let empty_patterns: string[] = [];

    return ServerConfig {
        command: "",
        args: empty_args,
        cwd: "",
        env_file: "",
        environment: empty_env,
        watch: default_watch_config(),
        behavior: BehaviorConfig {
            debounce_ms: 500,
            restart_delay_ms: 100,
            max_restarts: 5,
            graceful_shutdown_ms: 3000,
            restart_window_seconds: 60,
            pre_restart_command: "",
        },
        injectable_tools: InjectableToolsConfig {
            enabled: false,
            tools: empty_tools,
            on_collision: "ignore",
        },
        recorder: RecorderConfig {
            enabled: false,
            buffer_size: 50,
            include_request_bodies: true,
            include_response_bodies: true,
            export_on_crash: false,
            export_path: "",
        },
        security: SecurityConfig {
            redact_patterns: empty_patterns,
            redact_replacement: "[REDACTED]",
        },
    };
}

// Registry represents the global Hydra configuration (~/.hydra/config.json)
struct Registry {
    version: string,
    defaults: Defaults,
    servers: HashMap<string, ServerConfig>,
}

// Default registry
fn default_registry() -> Registry {
    // FRICTION: Cannot initialize HashMap with {} literal
    // Must use hashMapNew() to create empty HashMap
    let empty_servers = hashMapNew();
    return Registry {
        version: "1.0",
        defaults: default_defaults(),
        servers: empty_servers,
    };
}
