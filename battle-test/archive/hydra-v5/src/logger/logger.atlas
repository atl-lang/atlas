// logger/logger.atlas
// Logger trait for structured logging

// FRICTION: Atlas requires all functions/methods to have return values
// There is no void/unit type. Using string return as a workaround.

// Logger provides structured logging interface
trait Logger {
    // Log info-level message with context
    fn info(self, borrow message: string, borrow context: json) -> string;

    // Log warning-level message with context
    fn warn(self, borrow message: string, borrow context: json) -> string;

    // Log error-level message with context
    fn error(self, borrow message: string, borrow context: json) -> string;

    // Log debug-level message with context
    fn debug(self, borrow message: string, borrow context: json) -> string;
}

// StdoutLogger implements Logger interface using print
struct StdoutLogger {
    level: string,  // "debug", "info", "warn", "error"
}

impl Logger for StdoutLogger {
    fn info(self, borrow message: string, borrow context: json) -> string {
        print("[INFO] " + message);
        return message;
    }

    fn warn(self, borrow message: string, borrow context: json) -> string {
        print("[WARN] " + message);
        return message;
    }

    fn error(self, borrow message: string, borrow context: json) -> string {
        print("[ERROR] " + message);
        return message;
    }

    fn debug(self, borrow message: string, borrow context: json) -> string {
        print("[DEBUG] " + message);
        return message;
    }
}

// Create a new stdout logger
fn new_stdout_logger() -> StdoutLogger {
    return StdoutLogger {
        level: "info",
    };
}
