// Metrics Domain - Health Scoring
// Status: ✅ COMPILES AND RUNS
// Tests: Struct methods, floating point math, weighted calculations

struct HealthComponents {
    uptimeStability: number,
    errorRate: number,
    responseLatency: number,
    queueDepth: number,
    restartFrequency: number,
}

trait HealthScore {
    fn weightedScore(self) -> number;
}

impl HealthScore for HealthComponents {
    fn weightedScore(self) -> number {
        let score: number = 
            self.uptimeStability * 0.30 +
            self.errorRate * 0.25 +
            self.responseLatency * 0.20 +
            self.queueDepth * 0.15 +
            self.restartFrequency * 0.10;
        return score;
    }
}

fn newHealthComponents(borrow uptime: number, borrow errors: number, borrow latency: number, borrow queue: number, borrow restarts: number) -> HealthComponents {
    return HealthComponents {
        uptimeStability: uptime,
        errorRate: errors,
        responseLatency: latency,
        queueDepth: queue,
        restartFrequency: restarts,
    };
}

fn main() -> void {
    let health: HealthComponents = newHealthComponents(100, 95, 85, 90, 80);
    let score: number = health.weightedScore();
    print(`Overall health score: ${score}`);
}
