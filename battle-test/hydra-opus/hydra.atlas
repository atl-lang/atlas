// hydra.atlas - Consolidated Hydra MCP Supervisor
// Atlas port of the Go Hydra implementation
// ============================================================================
// AUDIT FRICTION NOTES (documented in audit/*.md):
// - Empty arrays need explicit type: `let arr: string[] = []`
// - dateTimeNow() deprecated → DateTime.now()
// - trim(s) deprecated → s.trim()
// - parseJSON(s) deprecated → Json.parse(s)
// - floor(n), min(a,b), max(a,b) deprecated → Math.floor(n), Math.min(a,b)
// - Variables reassigned must use `let mut`
// - Non-Copy types warn about ownership annotations
// ============================================================================

// ============================================================================
// CONFIG MODULE
// ============================================================================

struct Registry {
    version: string,
    defaults: Defaults,
    servers: HashMap<string, ServerConfig>
}

struct ServerConfig {
    command: string,
    args: string[],
    cwd: string,
    env_file: string,
    environment: HashMap<string, string>,
    watch: WatchConfig,
    behavior: BehaviorConfig,
    injectable_tools: InjectableToolsConfig,
    recorder: RecorderConfig,
    security: SecurityConfig
}

struct Defaults {
    debounce_ms: number,
    graceful_shutdown_ms: number,
    max_output_size_kb: number,
    log_rate_limit_per_second: number,
    restart_queue_max_messages: number,
    restart_queue_ttl_seconds: number,
    restart_timeout_seconds: number
}

struct WatchConfig {
    enabled: bool,
    paths: string[],
    extensions: string[],
    ignore_files: string[],
    ignore: string[]
}

struct BehaviorConfig {
    debounce_ms: number,
    restart_delay_ms: number,
    max_restarts: number,
    graceful_shutdown_ms: number,
    restart_window_seconds: number,
    pre_restart_command: string
}

struct InjectableToolsConfig {
    enabled: bool,
    tools: string[],
    on_collision: string
}

struct RecorderConfig {
    enabled: bool,
    buffer_size: number,
    include_request_bodies: bool,
    include_response_bodies: bool,
    export_on_crash: bool,
    export_path: string
}

struct SecurityConfig {
    redact_patterns: string[],
    redact_replacement: string
}

fn empty_string_array() : string[] {
    let arr: string[] = [];
    return arr;
}

fn default_registry() : Registry {
    return Registry {
        version: "1.0",
        defaults: Defaults {
            debounce_ms: 500,
            graceful_shutdown_ms: 2000,
            max_output_size_kb: 50,
            log_rate_limit_per_second: 10,
            restart_queue_max_messages: 100,
            restart_queue_ttl_seconds: 30,
            restart_timeout_seconds: 10
        },
        servers: hashMapNew()
    };
}

fn default_server_config() : ServerConfig {
    let empty_args: string[] = [];
    return ServerConfig {
        command: "",
        args: empty_args,
        cwd: "",
        env_file: "",
        environment: hashMapNew(),
        watch: WatchConfig {
            enabled: false,
            paths: ["."],
            extensions: [".py", ".js", ".ts", ".go"],
            ignore_files: [".gitignore"],
            ignore: [".git", "node_modules", "__pycache__", ".hydra"]
        },
        behavior: BehaviorConfig {
            debounce_ms: 500,
            restart_delay_ms: 0,
            max_restarts: 10,
            graceful_shutdown_ms: 2000,
            restart_window_seconds: 60,
            pre_restart_command: ""
        },
        injectable_tools: InjectableToolsConfig {
            enabled: true,
            tools: ["hydra_restart", "hydra_logs", "hydra_status", "hydra_force_restart"],
            on_collision: "error"
        },
        recorder: RecorderConfig {
            enabled: false,
            buffer_size: 50,
            include_request_bodies: false,
            include_response_bodies: false,
            export_on_crash: true,
            export_path: "/tmp/hydra-traffic-{timestamp}.json"
        },
        security: SecurityConfig {
            redact_patterns: [
                "sk-[A-Za-z0-9]{32,}",
                "API[_-]?KEY",
                "password",
                "Bearer [A-Za-z0-9._-]+",
                "ghp_[A-Za-z0-9]{36}",
                "xox[baprs]-[A-Za-z0-9-]+"
            ],
            redact_replacement: "[REDACTED by Hydra]"
        }
    };
}

// ============================================================================
// SUPERVISOR MODULE
// ============================================================================

enum ServerState {
    Stopped,
    Starting,
    Running,
    Restarting,
    Failed
}

fn server_state_to_string(borrow state: ServerState) : string {
    return match state {
        ServerState::Stopped => "stopped",
        ServerState::Starting => "starting",
        ServerState::Running => "running",
        ServerState::Restarting => "restarting",
        ServerState::Failed => "failed"
    };
}

struct SupervisorStatus {
    state: ServerState,
    pid: number,
    uptime_ms: number,
    last_error: Option<string>,
    restart_count: number
}

struct ProcessSupervisor {
    command: string,
    args: string[],
    cwd: string,
    environment: HashMap<string, string>,
    current_state: ServerState,
    current_pid: number,
    start_time_ms: number,
    error_message: Option<string>,
    restart_count: number,
    max_restarts: number,
    restart_window_seconds: number,
    graceful_shutdown_ms: number
}

fn new_supervisor(
    own command: string,
    own args: string[],
    own cwd: string,
    own env: HashMap<string, string>,
    own max_restarts: number,
    own restart_window_seconds: number,
    own graceful_shutdown_ms: number) : ProcessSupervisor {
    return ProcessSupervisor {
        command: command,
        args: args,
        cwd: cwd,
        environment: env,
        current_state: ServerState::Stopped,
        current_pid: 0,
        start_time_ms: 0,
        error_message: None,
        restart_count: 0,
        max_restarts: max_restarts,
        restart_window_seconds: restart_window_seconds,
        graceful_shutdown_ms: graceful_shutdown_ms
    };
}

fn get_timestamp_ms() : number {
    return dateTimeToTimestamp(DateTime.now());
}

fn supervisor_state(borrow sup: ProcessSupervisor) : ServerState {
    return sup.current_state;
}

fn supervisor_uptime_ms(borrow sup: ProcessSupervisor) : number {
    if sup.current_state != ServerState::Running {
        return 0;
    }
    let now = get_timestamp_ms();
    return now - sup.start_time_ms;
}

// ============================================================================
// SANITIZER MODULE
// ============================================================================

enum ChunkType {
    Empty,
    JSONRPC,
    Pollution
}

fn chunk_type_to_string(borrow ct: ChunkType) : string {
    return match ct {
        ChunkType::Empty => "empty",
        ChunkType::JSONRPC => "jsonrpc",
        ChunkType::Pollution => "pollution"
    };
}

struct DefaultSanitizer {
    strict_mode: bool
}

fn new_sanitizer(own strict: bool) : DefaultSanitizer {
    return DefaultSanitizer {
        strict_mode: strict
    };
}

fn sanitizer_classify(borrow _san: DefaultSanitizer, borrow chunk: string) : ChunkType {
    let trimmed = chunk.trim();

    if len(trimmed) == 0 {
        return ChunkType::Empty;
    }

    if !startsWith(trimmed, "{") {
        return ChunkType::Pollution;
    }

    let parse_result = Json.parse(trimmed);
    if is_err(parse_result) {
        return ChunkType::Pollution;
    }

    let obj = unwrap(parse_result);
    let jsonrpc_field = jsonGetString(obj, "jsonrpc");
    if is_none(jsonrpc_field) {
        return ChunkType::Pollution;
    }

    return ChunkType::JSONRPC;
}

// ============================================================================
// METRICS MODULE
// ============================================================================

struct MetricsSnapshot {
    requests_total: number,
    requests_success: number,
    requests_failed: number,
    restarts_total: number,
    queue_waits_total: number,
    avg_latency_ms: number,
    p50_latency_ms: number,
    p95_latency_ms: number,
    p99_latency_ms: number,
    max_latency_ms: number,
    avg_queue_wait_ms: number,
    max_queue_wait_ms: number,
    start_time_ms: number,
    uptime_ms: number,
    restart_reasons: HashMap<string, number>
}

struct HealthComponents {
    uptime_stability: number,
    error_rate: number,
    response_latency: number,
    queue_depth: number,
    restart_frequency: number
}

fn weighted_health_score(borrow h: HealthComponents) : number {
    let score = h.uptime_stability * 0.30 +
                h.error_rate * 0.25 +
                h.response_latency * 0.20 +
                h.queue_depth * 0.15 +
                h.restart_frequency * 0.10;
    return Math.floor(score);
}

struct DefaultMetricsCollector {
    requests_total: number,
    requests_success: number,
    requests_failed: number,
    restarts_total: number,
    queue_waits_total: number,
    latencies: number[],
    queue_waits: number[],
    max_latency_ms: number,
    max_queue_wait_ms: number,
    start_time_ms: number,
    restart_reasons: HashMap<string, number>
}

fn new_metrics_collector() : DefaultMetricsCollector {
    let empty_latencies: number[] = [];
    let empty_queue_waits: number[] = [];
    return DefaultMetricsCollector {
        requests_total: 0,
        requests_success: 0,
        requests_failed: 0,
        restarts_total: 0,
        queue_waits_total: 0,
        latencies: empty_latencies,
        queue_waits: empty_queue_waits,
        max_latency_ms: 0,
        max_queue_wait_ms: 0,
        start_time_ms: get_timestamp_ms(),
        restart_reasons: hashMapNew()
    };
}

fn metrics_record_request(own c: DefaultMetricsCollector, borrow duration_ms: number, borrow is_success: bool) : DefaultMetricsCollector {
    let new_total = c.requests_total + 1;
    let new_success = if is_success { c.requests_success + 1 } else { c.requests_success };
    let new_failed = if !is_success { c.requests_failed + 1 } else { c.requests_failed };
    let new_latencies = c.latencies.push(duration_ms);
    let new_max = if duration_ms > c.max_latency_ms { duration_ms } else { c.max_latency_ms };

    return DefaultMetricsCollector {
        requests_total: new_total,
        requests_success: new_success,
        requests_failed: new_failed,
        restarts_total: c.restarts_total,
        queue_waits_total: c.queue_waits_total,
        latencies: new_latencies,
        queue_waits: c.queue_waits,
        max_latency_ms: new_max,
        max_queue_wait_ms: c.max_queue_wait_ms,
        start_time_ms: c.start_time_ms,
        restart_reasons: c.restart_reasons
    };
}

fn metrics_record_restart(own c: DefaultMetricsCollector, borrow reason: string) : DefaultMetricsCollector {
    let current_count_opt = c.restart_reasons.get(reason);
    let new_count = match current_count_opt {
        Some(n) => n + 1,
        None => 1
    };
    let new_reasons = c.restart_reasons.set(reason, new_count);

    return DefaultMetricsCollector {
        requests_total: c.requests_total,
        requests_success: c.requests_success,
        requests_failed: c.requests_failed,
        restarts_total: c.restarts_total + 1,
        queue_waits_total: c.queue_waits_total,
        latencies: c.latencies,
        queue_waits: c.queue_waits,
        max_latency_ms: c.max_latency_ms,
        max_queue_wait_ms: c.max_queue_wait_ms,
        start_time_ms: c.start_time_ms,
        restart_reasons: new_reasons
    };
}

fn calculate_average(borrow nums: number[]) : number {
    if len(nums) == 0 {
        return 0;
    }
    let sum = reduce(nums, fn(borrow acc: number, borrow n: number) : number {
        return acc + n;
    }, 0);
    return sum / len(nums);
}

fn calculate_percentile(borrow nums: number[], borrow percentile: number) : number {
    if len(nums) == 0 {
        return 0;
    }
    let sorted = arraySort(nums);
    let index = Math.floor((percentile / 100) * len(sorted));
    let safe_index = Math.min(index, len(sorted) - 1);
    return sorted[safe_index];
}

fn metrics_snapshot(own c: DefaultMetricsCollector) : MetricsSnapshot {
    let now = get_timestamp_ms();
    let uptime = now - c.start_time_ms;

    return MetricsSnapshot {
        requests_total: c.requests_total,
        requests_success: c.requests_success,
        requests_failed: c.requests_failed,
        restarts_total: c.restarts_total,
        queue_waits_total: c.queue_waits_total,
        avg_latency_ms: calculate_average(c.latencies),
        p50_latency_ms: calculate_percentile(c.latencies, 50),
        p95_latency_ms: calculate_percentile(c.latencies, 95),
        p99_latency_ms: calculate_percentile(c.latencies, 99),
        max_latency_ms: c.max_latency_ms,
        avg_queue_wait_ms: calculate_average(c.queue_waits),
        max_queue_wait_ms: c.max_queue_wait_ms,
        start_time_ms: c.start_time_ms,
        uptime_ms: uptime,
        restart_reasons: c.restart_reasons
    };
}

fn metrics_health_score(borrow c: DefaultMetricsCollector) : number {
    let snap = metrics_snapshot(c);
    let uptime_hours = snap.uptime_ms / 3600000;
    let uptime_score = Math.min(100, uptime_hours * 100);

    let error_rate = if snap.requests_total > 0 {
        (snap.requests_failed / snap.requests_total) * 100
    } else {
        0
    };
    let error_score = Math.max(0, 100 - (error_rate * 10));
    let latency_score = Math.max(0, 100 - (snap.p95_latency_ms / 10));
    let queue_score = Math.max(0, 100 - (snap.avg_queue_wait_ms * 2));
    let restart_score = Math.max(0, 100 - (snap.restarts_total * 10));

    let components = HealthComponents {
        uptime_stability: Math.floor(uptime_score),
        error_rate: Math.floor(error_score),
        response_latency: Math.floor(latency_score),
        queue_depth: Math.floor(queue_score),
        restart_frequency: Math.floor(restart_score)
    };

    return weighted_health_score(components);
}

// ============================================================================
// ADAPTIVE MODULE
// ============================================================================

struct Suggestion {
    parameter: string,
    current: number,
    suggested: number,
    confidence: number,
    reason: string
}

struct Observation {
    timestamp_ms: number,
    event: string,
    context: HashMap<string, any>
}

struct Learner {
    observations: Observation[]
}

fn new_learner() : Learner {
    let empty_obs: Observation[] = [];
    return Learner {
        observations: empty_obs
    };
}

fn observe(own learner: Learner, own event: string, own ctx: HashMap<string, any>) : Learner {
    let obs = Observation {
        timestamp_ms: get_timestamp_ms(),
        event: event,
        context: ctx
    };

    return Learner {
        observations: learner.observations.push(obs)
    };
}

fn count_events(borrow observations: Observation[], borrow event_type: string) : number {
    let matching = filter(observations, fn(borrow obs: Observation) : bool {
        return obs.event == event_type;
    });
    return len(matching);
}

fn analyze(borrow _learner: Learner, borrow _snapshot: MetricsSnapshot, borrow _current_config: HashMap<string, number>) : Suggestion[] {
    let suggestions: Suggestion[] = [];
    return suggestions;
}

// ============================================================================
// INJECTABLE MODULE
// ============================================================================

struct ToolDefinition {
    name: string,
    description: string,
    input_schema: HashMap<string, any>
}

fn build_empty_schema() : HashMap<string, any> {
    let mut schema = hashMapNew();
    schema = schema.set("type", "object");
    schema = schema.set("properties", hashMapNew());
    return schema;
}

fn get_tool_definition(borrow name: string) : Option<ToolDefinition> {
    return match name {
        "hydra_restart" => Some(ToolDefinition {
            name: "hydra_restart",
            description: "Manually restart the supervised MCP server.",
            input_schema: build_empty_schema()
        }),
        "hydra_status" => Some(ToolDefinition {
            name: "hydra_status",
            description: "Get current Hydra supervisor status.",
            input_schema: build_empty_schema()
        }),
        "hydra_logs" => Some(ToolDefinition {
            name: "hydra_logs",
            description: "Retrieve recent child stderr logs.",
            input_schema: build_empty_schema()
        }),
        "hydra_metrics" => Some(ToolDefinition {
            name: "hydra_metrics",
            description: "Get comprehensive Hydra proxy metrics.",
            input_schema: build_empty_schema()
        }),
        "hydra_force_restart" => Some(ToolDefinition {
            name: "hydra_force_restart",
            description: "Force restart even if in FAILED state.",
            input_schema: build_empty_schema()
        }),
        _ => None
    };
}

fn default_tool_definitions() : ToolDefinition[] {
    return [
        unwrap(get_tool_definition("hydra_restart")),
        unwrap(get_tool_definition("hydra_status")),
        unwrap(get_tool_definition("hydra_logs")),
        unwrap(get_tool_definition("hydra_metrics")),
        unwrap(get_tool_definition("hydra_force_restart"))
    ];
}

// ============================================================================
// PROXY MODULE
// ============================================================================

enum ProxyState {
    Stopped,
    Starting,
    Running,
    Restarting,
    Failed
}

fn proxy_state_to_string(borrow state: ProxyState) : string {
    return match state {
        ProxyState::Stopped => "stopped",
        ProxyState::Starting => "starting",
        ProxyState::Running => "running",
        ProxyState::Restarting => "restarting",
        ProxyState::Failed => "failed"
    };
}

struct ProxyStatus {
    state: ProxyState,
    pid: number,
    uptime_ms: number,
    restarts_in_window: number,
    queue_size: number,
    can_recover: bool,
    last_restart_reason: string,
    last_error: string
}

struct ProxyOptions {
    queue_size: number,
    queue_ttl_ms: number,
    collision_policy: string,
    crash_export_path: string,
    crash_export_enabled: bool
}

fn default_proxy_options() : ProxyOptions {
    return ProxyOptions {
        queue_size: 100,
        queue_ttl_ms: 30000,
        collision_policy: "error",
        crash_export_path: "/tmp/hydra-traffic-crash.json",
        crash_export_enabled: true
    };
}

struct QueuedMessage {
    id: any,
    method: string,
    params: any,
    queued_at_ms: number
}

struct MessageQueue {
    messages: QueuedMessage[],
    max_size: number,
    ttl_ms: number
}

fn new_queue(own max_size: number, own ttl_ms: number) : MessageQueue {
    let empty_msgs: QueuedMessage[] = [];
    return MessageQueue {
        messages: empty_msgs,
        max_size: max_size,
        ttl_ms: ttl_ms
    };
}

fn queue_size(borrow q: MessageQueue) : number {
    return len(q.messages);
}

struct Proxy {
    state: ProxyState,
    queue: MessageQueue,
    options: ProxyOptions,
    hydra_tools: ToolDefinition[],
    last_restart_reason: string,
    last_error: string,
    started_ms: number,
    restarts_in_window: number,
    max_restarts: number
}

fn new_proxy(own options: ProxyOptions, own tools: ToolDefinition[]) : Proxy {
    return Proxy {
        state: ProxyState::Stopped,
        queue: new_queue(options.queue_size, options.queue_ttl_ms),
        options: options,
        hydra_tools: tools,
        last_restart_reason: "",
        last_error: "",
        started_ms: 0,
        restarts_in_window: 0,
        max_restarts: 10
    };
}

fn proxy_status(own p: Proxy) : ProxyStatus {
    let now = get_timestamp_ms();
    let uptime = if p.started_ms > 0 { now - p.started_ms } else { 0 };

    return ProxyStatus {
        state: p.state,
        pid: 0,
        uptime_ms: uptime,
        restarts_in_window: p.restarts_in_window,
        queue_size: queue_size(p.queue),
        can_recover: p.state == ProxyState::Failed,
        last_restart_reason: p.last_restart_reason,
        last_error: p.last_error
    };
}

fn proxy_start(own p: Proxy) : Result<Proxy, string> {
    if p.state == ProxyState::Running {
        return Err("proxy already running");
    }

    return Ok(Proxy {
        state: ProxyState::Running,
        queue: p.queue,
        options: p.options,
        hydra_tools: p.hydra_tools,
        last_restart_reason: p.last_restart_reason,
        last_error: "",
        started_ms: get_timestamp_ms(),
        restarts_in_window: p.restarts_in_window,
        max_restarts: p.max_restarts
    });
}

// ============================================================================
// MAIN
// ============================================================================

fn main() : void {
    print("Hydra MCP Supervisor - Atlas Port");
    print("==================================");
    print("");

    test_config();
    test_supervisor();
    test_sanitizer();
    test_metrics();
    test_adaptive();
    test_proxy();

    print("");
    print("All tests completed.");
}

fn test_config() : void {
    print("[Config] Testing...");
    let registry = default_registry();
    print(`  Version: ${registry.version}`);
    print(`  Default debounce_ms: ${registry.defaults.debounce_ms}`);
    let server = default_server_config();
    print(`  Default max_restarts: ${server.behavior.max_restarts}`);
    print("[Config] OK");
}

fn test_supervisor() : void {
    print("[Supervisor] Testing...");
    let state = ServerState::Running;
    print(`  State: ${server_state_to_string(state)}`);
    let sup = new_supervisor("python3", ["server.py"], "/tmp", hashMapNew(), 10, 60, 2000);
    print(`  Supervisor state: ${server_state_to_string(sup.current_state)}`);
    print("[Supervisor] OK");
}

fn test_sanitizer() : void {
    print("[Sanitizer] Testing...");
    let sanitizer = new_sanitizer(true);
    let valid_jsonrpc = "{\"jsonrpc\": \"2.0\", \"method\": \"test\", \"id\": 1}";
    let ct = sanitizer_classify(sanitizer, valid_jsonrpc);
    print(`  Valid JSON-RPC: ${chunk_type_to_string(ct)}`);
    let pollution = "DEBUG: Starting...";
    let pt = sanitizer_classify(sanitizer, pollution);
    print(`  Pollution: ${chunk_type_to_string(pt)}`);
    print("[Sanitizer] OK");
}

fn test_metrics() : void {
    print("[Metrics] Testing...");
    let mut collector = new_metrics_collector();
    collector = metrics_record_request(collector, 50, true);
    collector = metrics_record_request(collector, 100, true);
    collector = metrics_record_request(collector, 200, false);
    collector = metrics_record_restart(collector, "file_change");
    let snap = metrics_snapshot(collector);
    print(`  Requests total: ${snap.requests_total}`);
    print(`  Requests success: ${snap.requests_success}`);
    print(`  Avg latency: ${snap.avg_latency_ms}ms`);
    let health = metrics_health_score(collector);
    print(`  Health score: ${health}`);
    print("[Metrics] OK");
}

fn test_adaptive() : void {
    print("[Adaptive] Testing...");
    let mut learner = new_learner();
    let ctx = hashMapNew();
    learner = observe(learner, "restart", ctx);
    learner = observe(learner, "restart", ctx);
    print(`  Observations: ${len(learner.observations)}`);
    print("[Adaptive] OK");
}

fn test_proxy() : void {
    print("[Proxy] Testing...");
    let options = default_proxy_options();
    let tools = default_tool_definitions();
    let proxy = new_proxy(options, tools);
    print(`  State: ${proxy_state_to_string(proxy.state)}`);
    print(`  Tools: ${len(proxy.hydra_tools)}`);
    let start_result = proxy_start(proxy);
    if is_ok(start_result) {
        let running: Proxy = unwrap(start_result);
        print(`  After start: ${proxy_state_to_string(running.state)}`);
        let status = proxy_status(running);
        print(`  Queue size: ${status.queue_size}`);
    }
    print("[Proxy] OK");
}

main();
