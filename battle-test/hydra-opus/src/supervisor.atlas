// supervisor.atlas - Process lifecycle management
// Port of: internal/supervisor/supervisor.go

// ServerState represents the current state of the supervised process
enum ServerState {
    Stopped,
    Starting,
    Running,
    Restarting,
    Failed
}

// Converts ServerState to its string representation
fn server_state_to_string(borrow state: ServerState) -> string {
    return match state {
        ServerState::Stopped => "stopped",
        ServerState::Starting => "starting",
        ServerState::Running => "running",
        ServerState::Restarting => "restarting",
        ServerState::Failed => "failed"
    };
}

// SupervisorStatus holds runtime information about the supervisor
struct SupervisorStatus {
    state: ServerState,
    pid: number,
    uptime_ms: number,
    last_error: Option<string>,
    restart_count: number
}

// Supervisor trait defines the interface for process management
// NOTE: Atlas traits cannot hold state, so we use a struct-based approach
trait Supervisor {
    fn start(self) -> Result<void, string>;
    fn stop(self) -> Result<void, string>;
    fn restart(self) -> Result<void, string>;
    fn state(self) -> ServerState;
    fn pid(self) -> number;
    fn uptime_ms(self) -> number;
    fn last_error(self) -> Option<string>;
    fn reset_restart_counter(self) -> void;
}

// ProcessSupervisor manages a child process lifecycle
struct ProcessSupervisor {
    command: string,
    args: string[],
    cwd: string,
    environment: HashMap<string, string>,
    current_state: ServerState,
    current_pid: number,
    start_time_ms: number,
    error_message: Option<string>,
    restart_count: number,
    max_restarts: number,
    restart_window_seconds: number,
    graceful_shutdown_ms: number
}

// Creates a new ProcessSupervisor
fn new_supervisor(
    command: string,
    args: string[],
    cwd: string,
    env: HashMap<string, string>,
    max_restarts: number,
    restart_window_seconds: number,
    graceful_shutdown_ms: number
) -> ProcessSupervisor {
    return ProcessSupervisor {
        command: command,
        args: args,
        cwd: cwd,
        environment: env,
        current_state: ServerState::Stopped,
        current_pid: 0,
        start_time_ms: 0,
        error_message: None,
        restart_count: 0,
        max_restarts: max_restarts,
        restart_window_seconds: restart_window_seconds,
        graceful_shutdown_ms: graceful_shutdown_ms
    };
}

impl Supervisor for ProcessSupervisor {
    fn start(self) -> Result<void, string> {
        // Check if already running
        if self.current_state == ServerState::Running {
            return Err("supervisor already running");
        }

        // Build the spawn options
        let spawn_result = spawn(self.command, self.args);

        return match spawn_result {
            Ok(proc) => {
                // NOTE: Atlas spawn returns a Process handle
                // We'd need to extract PID from it
                self.current_state = ServerState::Running;
                self.start_time_ms = dateTimeToTimestamp(dateTimeNow());
                self.error_message = None;
                Ok(null)
            },
            Err(e) => {
                self.current_state = ServerState::Failed;
                self.error_message = Some(e);
                Err(e)
            }
        };
    }

    fn stop(self) -> Result<void, string> {
        if self.current_state == ServerState::Stopped {
            return Ok(null);
        }

        // Would need to kill the process
        // Atlas: processKill(pid)
        self.current_state = ServerState::Stopped;
        self.current_pid = 0;
        return Ok(null);
    }

    fn restart(self) -> Result<void, string> {
        self.current_state = ServerState::Restarting;
        self.restart_count = self.restart_count + 1;

        // Check crash loop protection
        if self.restart_count > self.max_restarts {
            self.current_state = ServerState::Failed;
            self.error_message = Some("crash loop detected: exceeded max restarts");
            return Err("crash loop detected");
        }

        let stop_result = self.stop();
        if is_err(stop_result) {
            return stop_result;
        }

        // Brief delay before restart (would use sleep)
        return self.start();
    }

    fn state(self) -> ServerState {
        return self.current_state;
    }

    fn pid(self) -> number {
        return self.current_pid;
    }

    fn uptime_ms(self) -> number {
        if self.current_state != ServerState::Running {
            return 0;
        }
        let now = dateTimeToTimestamp(dateTimeNow());
        return now - self.start_time_ms;
    }

    fn last_error(self) -> Option<string> {
        return self.error_message;
    }

    fn reset_restart_counter(self) -> void {
        self.restart_count = 0;
    }
}

// Creates a SupervisorStatus snapshot
fn supervisor_status(borrow sup: ProcessSupervisor) -> SupervisorStatus {
    return SupervisorStatus {
        state: sup.current_state,
        pid: sup.current_pid,
        uptime_ms: sup.uptime_ms(),
        last_error: sup.error_message,
        restart_count: sup.restart_count
    };
}
