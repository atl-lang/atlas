// statestore.atlas - Session state persistence
// Port of: internal/statestore/store.go, statestore.go

// StateStore trait for managing session state
trait StateStore {
    fn set_initialize(self, borrow params: any) -> void;
    fn get_initialize(self) -> Option<any>;
    fn add_subscription(self, borrow uri: string) -> void;
    fn remove_subscription(self, borrow uri: string) -> void;
    fn get_subscriptions(self) -> string[];
    fn update_subscription_id(self, borrow uri: string, borrow id: string) -> void;
    fn clear(self) -> void;
}

// DefaultStateStore implements StateStore
struct DefaultStateStore {
    initialize_params: Option<any>,
    subscriptions: HashMap<string, string>  // uri -> subscriptionID
}

// Creates a new state store
fn new_state_store() -> DefaultStateStore {
    return DefaultStateStore {
        initialize_params: None,
        subscriptions: hashMapNew()
    };
}

impl StateStore for DefaultStateStore {
    fn set_initialize(self, borrow params: any) -> void {
        self.initialize_params = Some(params);
    }

    fn get_initialize(self) -> Option<any> {
        return self.initialize_params;
    }

    fn add_subscription(self, borrow uri: string) -> void {
        // Only add if not already present
        if !hashMapHas(self.subscriptions, uri) {
            self.subscriptions = hashMapPut(self.subscriptions, uri, "");
        }
    }

    fn remove_subscription(self, borrow uri: string) -> void {
        self.subscriptions = hashMapRemove(self.subscriptions, uri);
    }

    fn get_subscriptions(self) -> string[] {
        return hashMapKeys(self.subscriptions);
    }

    fn update_subscription_id(self, borrow uri: string, borrow id: string) -> void {
        if hashMapHas(self.subscriptions, uri) {
            self.subscriptions = hashMapPut(self.subscriptions, uri, id);
        }
    }

    fn clear(self) -> void {
        self.initialize_params = None;
        self.subscriptions = hashMapNew();
    }
}

// Creates a state snapshot for debugging
struct StateSnapshot {
    has_initialize: bool,
    subscription_count: number,
    subscriptions: string[]
}

fn state_snapshot(borrow store: DefaultStateStore) -> StateSnapshot {
    return StateSnapshot {
        has_initialize: is_some(store.initialize_params),
        subscription_count: len(hashMapKeys(store.subscriptions)),
        subscriptions: hashMapKeys(store.subscriptions)
    };
}
