// security.atlas - Security primitives (redaction, rate limiting, size limiting)
// Port of: internal/security/security.go, redact.go, ratelimit.go, sizelimit.go

// JSONRPCResponse represents a JSON-RPC response structure
struct JSONRPCResponse {
    jsonrpc: string,
    id: Option<any>,
    result: Option<any>,
    error: Option<any>
}

// Redactor trait - redacts sensitive information from strings
trait Redactor {
    fn redact(self, borrow content: string, borrow patterns: string[]) : string;
}

// RateLimiter trait - controls the rate of operations
trait RateLimiter {
    fn allow(self) : bool;
}

// SizeLimiter trait - limits payload sizes
trait SizeLimiter {
    fn limit(self, own response: JSONRPCResponse, borrow max_kb: number) : JSONRPCResponse;
}

// DefaultRedactor implements pattern-based redaction
struct DefaultRedactor {
    replacement: string
}

// Creates a new DefaultRedactor
fn new_redactor(own replacement: string) : DefaultRedactor {
    return DefaultRedactor {
        replacement: replacement
    };
}

impl Redactor for DefaultRedactor {
    fn redact(self, borrow content: string, borrow patterns: string[]) : string {
        let result = content;

        // Apply each redaction pattern
        for i in 0..len(patterns) {
            let pattern = patterns[i];
            let regex_result = regexNew(pattern);

            if is_ok(regex_result) {
                let regex = unwrap(regex_result);
                result = regexReplaceAll(regex, result, self.replacement);
            }
        }

        return result;
    }
}

// TokenBucketLimiter implements token bucket rate limiting
struct TokenBucketLimiter {
    max_tokens: number,
    current_tokens: number,
    refill_rate_per_second: number,
    last_refill_ms: number
}

// Creates a new rate limiter
fn new_rate_limiter(own rate_per_second: number) : TokenBucketLimiter {
    return TokenBucketLimiter {
        max_tokens: rate_per_second,
        current_tokens: rate_per_second,
        refill_rate_per_second: rate_per_second,
        last_refill_ms: dateTimeToTimestamp(dateTimeNow())
    };
}

impl RateLimiter for TokenBucketLimiter {
    fn allow(self) : bool {
        // Refill tokens based on elapsed time
        let now = dateTimeToTimestamp(dateTimeNow());
        let elapsed_ms = now - self.last_refill_ms;
        let elapsed_seconds = elapsed_ms / 1000;

        let tokens_to_add = elapsed_seconds * self.refill_rate_per_second;
        self.current_tokens = min(self.max_tokens, self.current_tokens + tokens_to_add);
        self.last_refill_ms = now;

        // Try to consume a token
        if self.current_tokens >= 1 {
            self.current_tokens = self.current_tokens - 1;
            return true;
        }

        return false;
    }
}

// DefaultSizeLimiter truncates large payloads
struct DefaultSizeLimiter {
    truncation_message: string
}

// Creates a new size limiter
fn new_size_limiter() : DefaultSizeLimiter {
    return DefaultSizeLimiter {
        truncation_message: "[TRUNCATED by Hydra: output exceeds size limit]"
    };
}

impl SizeLimiter for DefaultSizeLimiter {
    fn limit(self, own response: JSONRPCResponse, borrow max_kb: number) : JSONRPCResponse {
        // Serialize to check size
        let result_str = match response.result {
            Some(r) => str(r),
            None => ""
        };

        let size_kb = len(result_str) / 1024;

        if size_kb > max_kb {
            // Truncate result
            let max_chars = max_kb * 1024;
            let truncated = substring(result_str, 0, max_chars);

            return JSONRPCResponse {
                jsonrpc: response.jsonrpc,
                id: response.id,
                result: Some(truncated + self.truncation_message),
                error: response.error
            };
        }

        return response;
    }
}

// Convenience function to redact common patterns
fn redact_secrets(borrow content: string) : string {
    let redactor = new_redactor("[REDACTED]");
    let patterns = [
        "sk-[A-Za-z0-9]{32,}",
        "API[_-]?KEY",
        "Bearer [A-Za-z0-9._-]+",
        "ghp_[A-Za-z0-9]{36}"
    ];
    return redactor.redact(content, patterns);
}
