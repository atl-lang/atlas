// sanitizer.atlas - Validate and clean output from child process
// Port of: internal/sanitizer/sanitizer.go, classifier.go

// ChunkType represents the classification of a data chunk
enum ChunkType {
    Empty,       // No data
    JSONRPC,     // Valid JSON-RPC message
    Pollution    // Random text, logs, stack traces
}

fn chunk_type_to_string(borrow ct: ChunkType) -> string {
    return match ct {
        ChunkType::Empty => "empty",
        ChunkType::JSONRPC => "jsonrpc",
        ChunkType::Pollution => "pollution"
    };
}

// Sanitizer trait - validates and cleans output from child process
// Ensures only valid JSON-RPC reaches the AI client
trait Sanitizer {
    // Classify determines if a byte slice is valid JSON-RPC or garbage
    fn classify(self, borrow chunk: string) -> ChunkType;

    // ValidateUTF8 ensures valid UTF-8, replacing invalid sequences
    fn validate_utf8(self, borrow data: string) -> string;
}

// DefaultSanitizer implements the Sanitizer trait
struct DefaultSanitizer {
    strict_mode: bool
}

// Creates a new DefaultSanitizer
fn new_sanitizer(own strict: bool) -> DefaultSanitizer {
    return DefaultSanitizer {
        strict_mode: strict
    };
}

impl Sanitizer for DefaultSanitizer {
    fn classify(self, borrow chunk: string) -> ChunkType {
        let trimmed = trim(chunk);

        // Empty check
        if len(trimmed) == 0 {
            return ChunkType::Empty;
        }

        // Quick heuristic: JSON-RPC must start with {
        if !startsWith(trimmed, "{") {
            return ChunkType::Pollution;
        }

        // Try to parse as JSON
        let parse_result = parseJSON(trimmed);
        if is_err(parse_result) {
            return ChunkType::Pollution;
        }

        let obj = unwrap(parse_result);

        // Check for JSON-RPC required field
        let jsonrpc_field = jsonGetString(obj, "jsonrpc");
        if is_err(jsonrpc_field) {
            return ChunkType::Pollution;
        }

        // Must have either id+method (request) or id+result/error (response)
        // or just method (notification)
        let has_method = is_ok(jsonGetString(obj, "method"));
        let has_id = is_ok(jsonGetString(obj, "id")) || is_ok(jsonGetNumber(obj, "id"));
        let has_result = hasField(obj, "result");
        let has_error = hasField(obj, "error");

        // Valid patterns:
        // 1. Request: has method and id
        // 2. Notification: has method, no id
        // 3. Response: has id and (result or error)
        let is_request = has_method && has_id;
        let is_notification = has_method && !has_id;
        let is_response = has_id && (has_result || has_error);

        if is_request || is_notification || is_response {
            return ChunkType::JSONRPC;
        }

        return ChunkType::Pollution;
    }

    fn validate_utf8(self, borrow data: string) -> string {
        // Atlas strings are always valid UTF-8 (Rust guarantees)
        // This is effectively a no-op in Atlas, but we keep for API compat
        return data;
    }
}

// is_valid_jsonrpc - quick check without full parsing
fn is_valid_jsonrpc(borrow chunk: string) -> bool {
    let trimmed = trim(chunk);
    if len(trimmed) == 0 {
        return false;
    }

    // Must be object
    if !startsWith(trimmed, "{") || !endsWith(trimmed, "}") {
        return false;
    }

    // Must contain "jsonrpc"
    return includes(trimmed, "\"jsonrpc\"");
}

// classify_quick - lightweight classification (no JSON parsing)
fn classify_quick(borrow chunk: string) -> ChunkType {
    let trimmed = trim(chunk);

    if len(trimmed) == 0 {
        return ChunkType::Empty;
    }

    if is_valid_jsonrpc(trimmed) {
        return ChunkType::JSONRPC;
    }

    return ChunkType::Pollution;
}
