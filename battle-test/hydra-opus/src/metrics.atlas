// metrics.atlas - Performance metrics collection
// Port of: internal/metrics/types.go, collector.go

// Snapshot represents a point-in-time view of all metrics
struct MetricsSnapshot {
    // Basic counters
    requests_total: number,
    requests_success: number,
    requests_failed: number,
    restarts_total: number,
    queue_waits_total: number,

    // Latency metrics (milliseconds)
    avg_latency_ms: number,
    p50_latency_ms: number,
    p95_latency_ms: number,
    p99_latency_ms: number,
    max_latency_ms: number,

    // Queue metrics
    avg_queue_wait_ms: number,
    max_queue_wait_ms: number,

    // Timing
    start_time_ms: number,
    uptime_ms: number,

    // Restart reasons (reason -> count)
    restart_reasons: HashMap<string, number>
}

// HealthComponents contains individual health dimension scores (0-100)
struct HealthComponents {
    uptime_stability: number,     // 30% weight
    error_rate: number,           // 25% weight
    response_latency: number,     // 20% weight
    queue_depth: number,          // 15% weight
    restart_frequency: number     // 10% weight
}

// Calculates weighted overall health score from components
fn weighted_health_score(h: HealthComponents) -> number {
    let score = h.uptime_stability * 0.30 +
                h.error_rate * 0.25 +
                h.response_latency * 0.20 +
                h.queue_depth * 0.15 +
                h.restart_frequency * 0.10;
    return floor(score);
}

// MetricsCollector trait for collecting and reporting proxy metrics
trait MetricsCollector {
    fn record_request(self, duration_ms: number, success: bool) -> void;
    fn record_queue_wait(self, duration_ms: number) -> void;
    fn record_restart(self, reason: string) -> void;
    fn snapshot(self) -> MetricsSnapshot;
    fn health_score(self) -> number;
    fn health_breakdown(self) -> HealthComponents;
}

// DefaultMetricsCollector implements MetricsCollector
struct DefaultMetricsCollector {
    requests_total: number,
    requests_success: number,
    requests_failed: number,
    restarts_total: number,
    queue_waits_total: number,

    latencies: number[],
    queue_waits: number[],

    max_latency_ms: number,
    max_queue_wait_ms: number,

    start_time_ms: number,
    restart_reasons: HashMap<string, number>
}

// Creates a new metrics collector
fn new_metrics_collector() -> DefaultMetricsCollector {
    return DefaultMetricsCollector {
        requests_total: 0,
        requests_success: 0,
        requests_failed: 0,
        restarts_total: 0,
        queue_waits_total: 0,
        latencies: [],
        queue_waits: [],
        max_latency_ms: 0,
        max_queue_wait_ms: 0,
        start_time_ms: dateTimeToTimestamp(dateTimeNow()),
        restart_reasons: hashMapNew()
    };
}

impl MetricsCollector for DefaultMetricsCollector {
    fn record_request(self, duration_ms: number, success: bool) -> void {
        self.requests_total = self.requests_total + 1;

        if success {
            self.requests_success = self.requests_success + 1;
        } else {
            self.requests_failed = self.requests_failed + 1;
        }

        self.latencies = arrayPush(self.latencies, duration_ms);

        if duration_ms > self.max_latency_ms {
            self.max_latency_ms = duration_ms;
        }
    }

    fn record_queue_wait(self, duration_ms: number) -> void {
        self.queue_waits_total = self.queue_waits_total + 1;
        self.queue_waits = arrayPush(self.queue_waits, duration_ms);

        if duration_ms > self.max_queue_wait_ms {
            self.max_queue_wait_ms = duration_ms;
        }
    }

    fn record_restart(self, reason: string) -> void {
        self.restarts_total = self.restarts_total + 1;

        let current_count = hashMapGet(self.restart_reasons, reason);
        let new_count = match current_count {
            Some(n) => n + 1,
            None => 1
        };
        self.restart_reasons = hashMapPut(self.restart_reasons, reason, new_count);
    }

    fn snapshot(self) -> MetricsSnapshot {
        let now = dateTimeToTimestamp(dateTimeNow());
        let uptime = now - self.start_time_ms;

        return MetricsSnapshot {
            requests_total: self.requests_total,
            requests_success: self.requests_success,
            requests_failed: self.requests_failed,
            restarts_total: self.restarts_total,
            queue_waits_total: self.queue_waits_total,
            avg_latency_ms: calculate_average(self.latencies),
            p50_latency_ms: calculate_percentile(self.latencies, 50),
            p95_latency_ms: calculate_percentile(self.latencies, 95),
            p99_latency_ms: calculate_percentile(self.latencies, 99),
            max_latency_ms: self.max_latency_ms,
            avg_queue_wait_ms: calculate_average(self.queue_waits),
            max_queue_wait_ms: self.max_queue_wait_ms,
            start_time_ms: self.start_time_ms,
            uptime_ms: uptime,
            restart_reasons: self.restart_reasons
        };
    }

    fn health_score(self) -> number {
        let components = self.health_breakdown();
        return weighted_health_score(components);
    }

    fn health_breakdown(self) -> HealthComponents {
        let snap = self.snapshot();

        // Uptime stability: 100 if uptime > 1hr, scales down
        let uptime_hours = snap.uptime_ms / 3600000;
        let uptime_score = min(100, uptime_hours * 100);

        // Error rate: 100 if 0%, 0 if > 10%
        let error_rate = if snap.requests_total > 0 {
            (snap.requests_failed / snap.requests_total) * 100
        } else {
            0
        };
        let error_score = max(0, 100 - (error_rate * 10));

        // Latency: 100 if p95 < 100ms, scales down
        let latency_score = max(0, 100 - (snap.p95_latency_ms / 10));

        // Queue depth: simplified - 100 if avg wait < 50ms
        let queue_score = max(0, 100 - (snap.avg_queue_wait_ms * 2));

        // Restart frequency: 100 if 0 restarts, -10 per restart
        let restart_score = max(0, 100 - (snap.restarts_total * 10));

        return HealthComponents {
            uptime_stability: floor(uptime_score),
            error_rate: floor(error_score),
            response_latency: floor(latency_score),
            queue_depth: floor(queue_score),
            restart_frequency: floor(restart_score)
        };
    }
}

// Calculate average of an array of numbers
fn calculate_average(nums: number[]) -> number {
    if len(nums) == 0 {
        return 0;
    }
    let sum = reduce(nums, fn(acc: number, n: number) -> number {
        return acc + n;
    }, 0);
    return sum / len(nums);
}

// Calculate percentile (simplified - uses sorted array position)
fn calculate_percentile(nums: number[], percentile: number) -> number {
    if len(nums) == 0 {
        return 0;
    }

    let sorted = sort(nums);
    let index = floor((percentile / 100) * len(sorted));
    let safe_index = min(index, len(sorted) - 1);

    return sorted[safe_index];
}
