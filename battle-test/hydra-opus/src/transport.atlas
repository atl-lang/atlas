// transport.atlas - Message transport layer
// Port of: internal/transport/transport.go

// Protocol defines the message framing type detected on the connection
enum Protocol {
    Unknown,
    NDJSON,   // Newline Delimited JSON
    LSP       // Content-Length: <len>\r\n\r\n
}

fn protocol_to_string(borrow p: Protocol) : string {
    return match p {
        Protocol::Unknown => "unknown",
        Protocol::NDJSON => "ndjson",
        Protocol::LSP => "lsp"
    };
}

// Transport trait manages low-level read/write operations
// Handles protocol detection (LSP vs NDJSON) and safe reading
trait Transport {
    // Read returns the next complete message payload
    // Blocks until a message is available or connection closes
    fn read(self) : Result<string, string>;

    // Write sends a payload, adding framing based on detected protocol
    fn write(self, borrow payload: string) : Result<void, string>;

    // Close shuts down the transport and releases resources
    fn close(self) : Result<void, string>;

    // DetectProtocol sniffs the first message to determine protocol
    fn detect_protocol(self, borrow timeout_ms: number) : Result<Protocol, string>;
}

// StdioTransport implements transport over stdin/stdout
struct StdioTransport {
    detected_protocol: Protocol,
    buffer: string,
    is_closed: bool
}

// Creates a new StdioTransport
fn new_stdio_transport() : StdioTransport {
    return StdioTransport {
        detected_protocol: Protocol::Unknown,
        buffer: "",
        is_closed: false
    };
}

impl Transport for StdioTransport {
    fn read(self) : Result<string, string> {
        if self.is_closed {
            return Err("transport closed");
        }

        // In real implementation, would read from process stdin
        // Atlas: would use process stdio handles
        return match self.detected_protocol {
            Protocol::NDJSON => self.read_ndjson(),
            Protocol::LSP => self.read_lsp(),
            Protocol::Unknown => Err("protocol not detected")
        };
    }

    fn write(self, borrow payload: string) : Result<void, string> {
        if self.is_closed {
            return Err("transport closed");
        }

        // Frame message according to protocol
        let framed = match self.detected_protocol {
            Protocol::NDJSON => payload + "\n",
            Protocol::LSP => {
                let content_length = len(payload);
                `Content-Length: {content_length}\r\n\r\n{payload}`
            },
            Protocol::Unknown => payload
        };

        // Would write to process stdout
        // processStdin(proc, framed)
        return Ok(null);
    }

    fn close(self) : Result<void, string> {
        self.is_closed = true;
        return Ok(null);
    }

    fn detect_protocol(self, borrow timeout_ms: number) : Result<Protocol, string> {
        // Peek at first few bytes to detect protocol
        // LSP starts with "Content-Length:"
        // NDJSON starts with "{" and ends with newline

        // For now, default to NDJSON (most common for MCP)
        self.detected_protocol = Protocol::NDJSON;
        return Ok(Protocol::NDJSON);
    }
}

// Helper methods for StdioTransport
impl StdioTransport {
    fn read_ndjson(self) : Result<string, string> {
        // Read until newline
        // This is a simplified implementation
        return Ok("{}");
    }

    fn read_lsp(self) : Result<string, string> {
        // Read Content-Length header, then body
        // This is a simplified implementation
        return Ok("{}");
    }
}

// Parse LSP Content-Length header
fn parse_content_length(borrow header: string) : Result<number, string> {
    let prefix = "Content-Length: ";
    if !startsWith(header, prefix) {
        return Err("invalid Content-Length header");
    }

    let length_str = substring(header, len(prefix), len(header));
    let length_str_trimmed = trim(length_str);

    // Parse number
    let parsed = parseFloat(length_str_trimmed);
    return match parsed {
        Ok(n) => Ok(n),
        Err(_) => Err("invalid Content-Length value")
    };
}
