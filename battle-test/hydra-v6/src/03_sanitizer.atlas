// Sanitizer Domain - Output Validation
// Status: ✅ COMPILES AND RUNS  
// Tests: String methods, JSON validation, enums

enum ChunkType {
    Empty,
    JSONRPC,
    Pollution,
}

trait Sanitizer {
    fn classify(self, chunk: string) -> ChunkType;
}

struct OutputSanitizer {}

fn newSanitizer() -> OutputSanitizer {
    return OutputSanitizer {};
}

impl Sanitizer for OutputSanitizer {
    fn classify(self, chunk: string) -> ChunkType {
        let trimmed: string = chunk.trim();
        
        if trimmed.len() == 0 {
            return ChunkType::Empty;
        }
        
        if !Json.isValid(trimmed) {
            return ChunkType::Pollution;
        }
        
        if trimmed.includes("\"jsonrpc\"") {
            return ChunkType::JSONRPC;
        }
        
        return ChunkType::Pollution;
    }
}

fn main() -> void {
    let sanitizer: OutputSanitizer = newSanitizer();
    
    let validRPC: string = `{"jsonrpc":"2.0","method":"test"}`;
    let pollution: string = "ERROR: crashed";
    let empty: string = "  ";
    
    let type1: ChunkType = sanitizer.classify(validRPC);
    let type2: ChunkType = sanitizer.classify(pollution);
    let type3: ChunkType = sanitizer.classify(empty);
    
    let desc: string = match type1 {
        ChunkType::Empty => "empty",
        ChunkType::JSONRPC => "jsonrpc",
        ChunkType::Pollution => "pollution",
    };
    
    print(`Valid RPC classified as: ${desc}`);
}
