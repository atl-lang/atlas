// Config Domain - Data Structures
// Status: ✅ COMPILES AND RUNS
// Tests: Nested structs, default values, constructors

struct Defaults {
    debounceMs: number,
    gracefulShutdownMs: number,
    maxOutputSizeKb: number,
}

struct WatchConfig {
    enabled: bool,
    paths: string[],
    extensions: string[],
}

struct ServerConfig {
    command: string,
    args: string[],
    watch: WatchConfig,
}

struct Registry {
    version: string,
    defaults: Defaults,
}

fn defaultDefaults() -> Defaults {
    return Defaults {
        debounceMs: 500,
        gracefulShutdownMs: 2000,
        maxOutputSizeKb: 50,
    };
}

fn defaultWatchConfig() -> WatchConfig {
    let emptyPaths: string[] = [];
    let emptyExts: string[] = [];
    return WatchConfig {
        enabled: true,
        paths: emptyPaths,
        extensions: emptyExts,
    };
}

fn defaultRegistry() -> Registry {
    return Registry {
        version: "1.0",
        defaults: defaultDefaults(),
    };
}

fn main() -> void {
    let registry: Registry = defaultRegistry();
    print(`Version: ${registry.version}`);
    print(`Debounce: ${registry.defaults.debounceMs}ms`);
    
    let watch: WatchConfig = defaultWatchConfig();
    print(`Watch enabled: ${watch.enabled}`);
}
