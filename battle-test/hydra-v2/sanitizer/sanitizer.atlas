let CHUNK_EMPTY = "empty";
let CHUNK_JSONRPC = "jsonrpc";
let CHUNK_POLLUTION = "pollution";

export fn classify_chunk(chunk: string) -> string {
    let trimmed: string = trim(chunk);
    let is_empty: bool = len(trimmed) == 0;
    if (is_empty) {
        return CHUNK_EMPTY;
    }
    let valid: bool = isValidJSON(trimmed);
    if (!valid) {
        return CHUNK_POLLUTION;
    }
    let is_array: bool = startsWith(trimmed, "[");
    if (is_array) {
        return CHUNK_JSONRPC;
    }
    let parsed = unwrap(parseJSON(trimmed));
    let ver = parsed["jsonrpc"];
    let has_ver: bool = !jsonIsNull(ver);
    if (has_ver) {
        let ver_str = jsonAsString(ver);
        if (ver_str == "2.0") {
            return CHUNK_JSONRPC;
        }
    }
    return CHUNK_POLLUTION;
}

export fn validate_utf8(data: string) -> string {
    // Atlas strings are UTF-8; if invalid bytes are present upstream,
    // the runtime already normalized. No-op here.
    return data;
}

fn test_classify_empty() -> bool {
    assertEqual(classify_chunk(""), CHUNK_EMPTY);
    assertEqual(classify_chunk("   \n"), CHUNK_EMPTY);
    return true;
}

fn test_classify_invalid_json() -> bool {
    assertEqual(classify_chunk("{not json}"), CHUNK_POLLUTION);
    return true;
}

fn test_classify_jsonrpc_object() -> bool {
    let msg = "{\"jsonrpc\":\"2.0\",\"id\":1,\"method\":\"ping\"}";
    assertEqual(classify_chunk(msg), CHUNK_JSONRPC);
    return true;
}

fn test_classify_jsonrpc_array() -> bool {
    let msg = "[{\"jsonrpc\":\"2.0\"}]";
    assertEqual(classify_chunk(msg), CHUNK_JSONRPC);
    return true;
}

fn test_classify_valid_json_non_rpc() -> bool {
    let msg = "{\"foo\":\"bar\"}";
    assertEqual(classify_chunk(msg), CHUNK_POLLUTION);
    return true;
}
