// Standalone integration demo (no imports supported)

let PROTOCOL_NDJSON = "ndjson";
let PROTOCOL_LSP = "lsp";

fn detect_protocol(peek: string) -> string {
    let trimmed: string = trim(peek);
    let is_lsp: bool = starts_with(trimmed, "Content-Length");
    if is_lsp {
        return PROTOCOL_LSP;
    }
    return PROTOCOL_NDJSON;
}

fn lsp_frame(payload: string) -> string {
    let header = "Content-Length: " + str(len(payload)) + "\r\n\r\n";
    return header + payload;
}

fn read_lsp(buffer: string) -> string[] {
    let parts: string[] = split(buffer, "\r\n\r\n");
    let has_body: bool = len(parts) >= 2;
    if !has_body {
        return ["false", "", buffer];
    }
    let header = parts[0];
    let body = join(slice(parts, 1, len(parts)), "\r\n\r\n");
    let has_prefix: bool = starts_with(header, "Content-Length");
    if !has_prefix {
        return ["false", "", body];
    }
    return ["true", body, ""];
}

// Minimal state store for initialize params

type StateStore = HashMap<string, string>;

fn state_new() -> StateStore {
    let mut store = hash_map_new();
    store = hash_map_put(store, "initialize", "");
    return store;
}

fn state_set_initialize(store: StateStore, params: json) -> StateStore {
    return hash_map_put(store, "initialize", to_json(params));
}

fn state_get_initialize(borrow store: StateStore) -> json {
    let raw = unwrap(hash_map_get(store, "initialize"));
    if raw == "" {
        return unwrap(parse_json("null"));
    }
    return unwrap(parse_json(raw));
}

fn proxy_new() -> HashMap<string, string> {
    let mut p = hash_map_new();
    p = hash_map_put(p, "state", "running");
    return p;
}

fn proxy_handle_client(store: StateStore, message: string) -> StateStore {
    let parsed = unwrap(parse_json(message));
    let method_val = parsed["method"];
    let has_method: bool = !json_is_null(method_val);
    if has_method {
        let method = json_as_string(method_val);
        if method == "initialize" {
            let params = parsed["params"];
            let has_params: bool = !json_is_null(params);
            if has_params {
                return state_set_initialize(store, params);
            }
        }
    }
    return store;
}

export fn integration_demo() -> bool {
    let mut store = state_new();
    let _proxy = proxy_new();
    let msg = "{\"jsonrpc\":\"2.0\",\"method\":\"initialize\",\"params\":{\"root\":\"/tmp\"}}";
    store = proxy_handle_client(store, msg);
    let init = state_get_initialize(store);
    return json_as_string(init["root"]) == "/tmp";
}

fn test_integration_protocol_and_proxy() -> bool {
    let framed = lsp_frame("hello");
    assert_equal(detect_protocol("Content-Length: 5"), PROTOCOL_LSP);
    let res = read_lsp(framed);
    assert_equal(res[1], "hello");
    assert_equal(integration_demo(), true);
    return true;
}
