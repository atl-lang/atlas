let PROTOCOL_UNKNOWN = "unknown";
let PROTOCOL_NDJSON = "ndjson";
let PROTOCOL_LSP = "lsp";

let RESULT_OK = 0;
let RESULT_MESSAGE = 1;
let RESULT_REST = 2;
let RESULT_ERROR = 3;

fn make_result(ok: bool, message: string, rest: string, error: string) -> string[] {
    let mut flag = "false";
    if (ok) {
        flag = "true";
    }
    return [flag, message, rest, error];
}

export fn detect_protocol(peek: string) -> string {
    let trimmed: string = trim(peek);
    let is_empty: bool = len(trimmed) == 0;
    if (is_empty) {
        return PROTOCOL_UNKNOWN;
    }
    let is_lsp: bool = startsWith(trimmed, "Content-Length");
    if (is_lsp) {
        return PROTOCOL_LSP;
    }
    return PROTOCOL_NDJSON;
}

export fn ndjson_frame(payload: string) -> string {
    let is_empty: bool = len(payload) == 0;
    if (is_empty) {
        return "\n";
    }
    let has_newline: bool = endsWith(payload, "\n");
    if (has_newline) {
        return payload;
    }
    return payload + "\n";
}

export fn lsp_frame(payload: string) -> string {
    let header = "Content-Length: " + str(len(payload)) + "\r\n\r\n";
    return header + payload;
}

fn parse_content_length(header_line: string) -> number {
    let has_prefix: bool = startsWith(header_line, "Content-Length:");
    if (!has_prefix) {
        return 0;
    }
    let value = trim(substring(header_line, len("Content-Length:"), len(header_line)));
    return unwrap(toNumber(value));
}

export fn read_ndjson(buffer: string) -> string[] {
    let parts: string[] = split(buffer, "\n");
    let empty_parts: bool = len(parts) == 0;
    if (empty_parts) {
        return make_result(false, "", "", "empty");
    }
    let message = trim(parts[0]);
    let mut rest = "";
    let has_rest: bool = len(parts) > 1;
    if (has_rest) {
        rest = join(slice(parts, 1, len(parts)), "\n");
    }
    let has_message: bool = len(message) > 0;
    return make_result(has_message, message, rest, "");
}

export fn read_lsp(buffer: string) -> string[] {
    let parts: string[] = split(buffer, "\r\n\r\n");
    let has_header: bool = len(parts) >= 2;
    if (!has_header) {
        return make_result(false, "", buffer, "missing header");
    }
    let header = parts[0];
    let body = join(slice(parts, 1, len(parts)), "\r\n\r\n");

    let header_lines: string[] = split(header, "\r\n");
    let mut content_length: number = 0;
    for line in header_lines {
        let candidate = parse_content_length(line);
        if (candidate > 0) {
            content_length = candidate;
        }
    }

    let missing_length: bool = content_length == 0;
    if (missing_length) {
        return make_result(false, "", body, "missing content-length");
    }

    let incomplete: bool = len(body) < content_length;
    if (incomplete) {
        return make_result(false, "", body, "incomplete body");
    }

    let message = substring(body, 0, content_length);
    let rest = substring(body, content_length, len(body));

    return make_result(true, message, rest, "");
}

fn test_detect_protocol_lsp() -> bool {
    assertEqual(detect_protocol("Content-Length: 5"), PROTOCOL_LSP);
    return true;
}

fn test_detect_protocol_ndjson() -> bool {
    assertEqual(detect_protocol("{\"jsonrpc\":\"2.0\"}"), PROTOCOL_NDJSON);
    return true;
}

fn test_read_ndjson() -> bool {
    let res = read_ndjson("a\nb\n");
    assertEqual(res[RESULT_OK], "true");
    assertEqual(res[RESULT_MESSAGE], "a");
    assertEqual(res[RESULT_REST], "b\n");
    return true;
}

fn test_read_lsp_basic() -> bool {
    let framed = lsp_frame("hello");
    let res = read_lsp(framed);
    assertEqual(res[RESULT_OK], "true");
    assertEqual(res[RESULT_MESSAGE], "hello");
    assertEqual(res[RESULT_REST], "");
    return true;
}

fn test_read_lsp_rest() -> bool {
    let framed = lsp_frame("hello") + "MORE";
    let res = read_lsp(framed);
    assertEqual(res[RESULT_OK], "true");
    assertEqual(res[RESULT_MESSAGE], "hello");
    assertEqual(res[RESULT_REST], "MORE");
    return true;
}

fn test_ndjson_frame() -> bool {
    assertEqual(ndjson_frame("x"), "x\n");
    assertEqual(ndjson_frame("x\n"), "x\n");
    return true;
}
