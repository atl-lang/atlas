#!/bin/bash
# ══════════════════════════════════════════════════════════════════════════════
# ATLAS PRE-COMMIT GUARDIAN v4.0 — Static Analysis Only
# ══════════════════════════════════════════════════════════════════════════════
#
# Tier 1: Fast pre-commit gate (< 15 seconds)
# - cargo fmt --check
# - cargo clippy --workspace -- -D warnings
# - Dead code detection (no #[allow(dead_code)] additions)
# - Doc drift detector
# - Skill file protection
#
# Tier 2: Full validation runs nightly via launchd at 2am
# - Full corpus, nextest workspace, parity sweep, battle tests
# - Results in tracking/ci-status.json
# - atlas-track go shows CI status
#
# Activated by: git config core.hooksPath .githooks
# ══════════════════════════════════════════════════════════════════════════════

set -e

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
MAGENTA='\033[0;35m'
NC='\033[0m'
BOLD='\033[1m'

# Project root
PROJECT_ROOT="$(git rev-parse --show-toplevel)"

# ══════════════════════════════════════════════════════════════════════════════
# PHASE 0: Gather staged files
# ══════════════════════════════════════════════════════════════════════════════

STAGED=$(git diff --cached --name-only)
if [ -z "$STAGED" ]; then
  exit 0
fi

# Categorize files
SOURCE_FILES=$(echo "$STAGED" | grep -E '^crates/.*\.rs$' || true)
SKILL_FILES=$(echo "$STAGED" | grep -E '^\.claude/' || true)

# ══════════════════════════════════════════════════════════════════════════════
# SKILL FILE PROTECTION
# ══════════════════════════════════════════════════════════════════════════════

if [ -n "$SKILL_FILES" ]; then
  if [ ! -f "/tmp/atlas-skill-unlock" ]; then
    echo ""
    echo -e "${RED}${BOLD}BLOCKED: Skill files require explicit unlock${NC}"
    echo ""
    echo -e "Staged skill files:"
    echo "$SKILL_FILES" | while read f; do echo "  - $f"; done
    echo ""
    echo -e "To unlock: ${CYAN}touch /tmp/atlas-skill-unlock${NC}"
    echo -e "After commit: ${CYAN}rm /tmp/atlas-skill-unlock${NC}"
    echo ""
    exit 1
  else
    echo -e "${YELLOW}Skill file unlock active — proceeding${NC}"
  fi
fi

# If only docs/config/skills staged (no Rust source), fast exit after skill check
if [ -z "$SOURCE_FILES" ]; then
  echo -e "${CYAN}pre-commit:${NC} No Rust source files staged. Static checks skipped."
  exit 0
fi

echo ""
echo -e "${BOLD}══════════════════════════════════════════════════════════════════${NC}"
echo -e "${BOLD}            ATLAS PRE-COMMIT GUARDIAN v4.0${NC}"
echo -e "${BOLD}══════════════════════════════════════════════════════════════════${NC}"
echo -e "${MAGENTA}    \"Fast gates. Nightly CI handles the rest.\"${NC}"
echo ""

# ══════════════════════════════════════════════════════════════════════════════
# PHASE 1: Dead Code Detection
# ══════════════════════════════════════════════════════════════════════════════

echo -e "${BLUE}[PHASE 1]${NC} Dead Code Detection"

DEAD_CODE_ISSUES=""

# Check for new #[allow(dead_code)] additions
DEAD_CODE_ALLOWS=$(git diff --cached -U0 | grep -E '^\+.*#\[allow\(dead_code\)\]' || true)
if [ -n "$DEAD_CODE_ALLOWS" ]; then
  DEAD_CODE_ISSUES="${DEAD_CODE_ISSUES}\n   - Adding #[allow(dead_code)] annotations (hiding problems)"
fi

# Check for new #[allow(unused)] additions
UNUSED_ALLOWS=$(git diff --cached -U0 | grep -E '^\+.*#\[allow\(unused' || true)
if [ -n "$UNUSED_ALLOWS" ]; then
  DEAD_CODE_ISSUES="${DEAD_CODE_ISSUES}\n   - Adding #[allow(unused*)] annotations (hiding problems)"
fi

# Check for files being deleted that might leave orphans
DELETED_FILES=$(git diff --cached --name-only --diff-filter=D | grep -E '\.rs$' || true)
if [ -n "$DELETED_FILES" ]; then
  echo -e "   ${YELLOW}Warning:${NC} Files being deleted - verify no orphaned references"
  for f in $DELETED_FILES; do
    echo -e "      - $f"
  done
fi

# Check for new files that might duplicate existing
NEW_FILES=$(git diff --cached --name-only --diff-filter=A | grep -E '\.rs$' || true)
if [ -n "$NEW_FILES" ]; then
  for f in $NEW_FILES; do
    BASENAME=$(basename "$f" .rs)
    SIMILAR=$(find "$PROJECT_ROOT/crates" -name "*${BASENAME}*" -type f -name "*.rs" 2>/dev/null | grep -v "$f" | head -3 || true)
    if [ -n "$SIMILAR" ]; then
      DEAD_CODE_ISSUES="${DEAD_CODE_ISSUES}\n   - New file '$f' may overlap with existing: $(echo $SIMILAR | tr '\n' ' ')"
    fi
  done
fi

if [ -n "$DEAD_CODE_ISSUES" ]; then
  echo -e "${YELLOW}   Warnings found:${NC}"
  echo -e "$DEAD_CODE_ISSUES"
  echo ""
else
  echo -e "   ${GREEN}No dead code markers detected${NC}"
fi
echo ""

# ══════════════════════════════════════════════════════════════════════════════
# PHASE 2: Static Checks (fmt + clippy — the ONLY gates)
# ══════════════════════════════════════════════════════════════════════════════

echo -e "${BLUE}[PHASE 2]${NC} Static Checks"

echo -n "   cargo fmt --check... "
if cargo fmt --check --quiet 2>/dev/null; then
  echo -e "${GREEN}PASS${NC}"
else
  echo -e "${RED}FAIL${NC}"
  echo ""
  echo -e "${RED}ERROR: Code is not formatted. Run 'cargo fmt' first.${NC}"
  exit 1
fi

echo -n "   cargo clippy... "
CLIPPY_OUTPUT=$(cargo clippy --workspace --quiet -- -D warnings 2>&1) || {
  echo -e "${RED}FAIL${NC}"
  echo ""
  echo -e "${RED}ERROR: Clippy warnings found:${NC}"
  echo "$CLIPPY_OUTPUT" | head -30
  exit 1
}
echo -e "${GREEN}PASS${NC}"
echo ""

# ══════════════════════════════════════════════════════════════════════════════
# PHASE 3: Doc Drift Warning (non-blocking)
# ══════════════════════════════════════════════════════════════════════════════

DOC_FILES=$(echo "$STAGED" | grep -E '\.md$' || true)
CHANGED_DOMAINS=""

for file in $SOURCE_FILES; do
  case "$file" in
    crates/atlas-runtime/src/stdlib/*) CHANGED_DOMAINS="${CHANGED_DOMAINS}stdlib " ;;
    crates/atlas-runtime/src/vm/*) CHANGED_DOMAINS="${CHANGED_DOMAINS}vm " ;;
    crates/atlas-runtime/src/interpreter/*) CHANGED_DOMAINS="${CHANGED_DOMAINS}interpreter " ;;
    crates/atlas-runtime/src/typechecker/*) CHANGED_DOMAINS="${CHANGED_DOMAINS}typechecker " ;;
    crates/atlas-runtime/src/parser/*) CHANGED_DOMAINS="${CHANGED_DOMAINS}parser " ;;
  esac
done

if [ -n "$CHANGED_DOMAINS" ] && [ -z "$DOC_FILES" ]; then
  echo -e "${YELLOW}[INFO]${NC} Source changed in: ${CHANGED_DOMAINS}"
  echo -e "${YELLOW}       If behavior changed, update docs/ accordingly.${NC}"
  echo ""
fi

# ══════════════════════════════════════════════════════════════════════════════
# DONE
# ══════════════════════════════════════════════════════════════════════════════

echo -e "${GREEN}${BOLD}✓ STATIC CHECKS PASSED${NC}"
echo -e "${CYAN}   Full validation: 'atlas-track run-ci' or nightly CI at 2am${NC}"
echo ""
exit 0
