{
  "permissions": {
    "allow": [
      "Bash(cargo test:*)",
      "Bash(cargo run:*)",
      "Bash(pt go:*)",
      "Bash(bash:*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/proxikal/.claude/hooks/atlas/path-guard.sh"
          },
          {
            "type": "command",
            "command": "/Users/proxikal/.claude/hooks/protect-atlas-skill.sh"
          },
          {
            "type": "command",
            "command": "/Users/proxikal/.claude/hooks/atlas/memory-protect.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/proxikal/.claude/hooks/atlas/validate.sh",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "/Users/proxikal/.claude/hooks/atlas/auto-fmt.sh",
            "timeout": 15
          },
          {
            "type": "command",
            "command": "/Users/proxikal/.claude/hooks/atlas/cargo-check.sh",
            "timeout": 30
          },
          {
            "type": "command",
            "command": "/Users/proxikal/.claude/hooks/atlas/clippy-check.sh",
            "timeout": 45
          },
          {
            "type": "command",
            "command": "/Users/proxikal/.claude/hooks/atlas/doc-drift-check.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "/Users/proxikal/.claude/hooks/atlas/new-file-auditor-check.sh",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Edit|Write|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/proxikal/.claude/hooks/atlas/context-guard.sh",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/proxikal/.claude/hooks/atlas/doc-patch-trigger.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUseFailure": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/proxikal/.claude/hooks/atlas/hook-block-notify.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/Users/proxikal/.claude/hooks/atlas/pre-compact-save.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/Users/proxikal/.claude/hooks/atlas/test-gate.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "/Users/proxikal/.claude/hooks/atlas/dead-file-check.sh",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "/Users/proxikal/.claude/hooks/atlas-git-stop-check.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "/Users/proxikal/.claude/hooks/atlas/doc-patch-stop-check.sh",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
