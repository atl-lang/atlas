          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/Users/proxikal/.claude/hooks/atlas-git-stop-check.sh"
          }
        ]
      }
    ]
  }
}
