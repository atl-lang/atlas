// B15: Tuple match patterns

fn classify(own pair: (number, number)): string {
    match pair {
        (0, 0) => "origin",
        (x, 0) => "x-axis",
        (0, y) => "y-axis",
        (x, y) => "quadrant"
    }
}

console.log(classify((0, 0)));
console.log(classify((5, 0)));
console.log(classify((0, 3)));
console.log(classify((2, 4)));

// Wildcard in tuple
match (42, "hello") {
    (_, s) => console.log(s)
}

// Nested destructuring via match + let
let (a, b) = (100, 200);
match (a, b) {
    (x, y) => console.log(x + y)
}
