// B15: Tuple basics — literal, access, destructure

// Literal creation
let point = (3, 4);
console.log(point.0);
console.log(point.1);

// String elements
let pair = ("hello", "world");
console.log(pair.0);
console.log(pair.1);

// Three elements
let triple = (1, 2, 3);
console.log(triple.0 + triple.1 + triple.2);

// Let destructuring
let (x, y) = (10, 20);
console.log(x);
console.log(y);
console.log(x + y);

// Unit tuple
let u = ();
console.log("ok");
