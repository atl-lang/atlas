// B15: Fibonacci using (prev, curr) tuple pairs

fn fib_pair(n: number) : (number, number) {
    if n == 0 {
        return (0, 1);
    }
    let (prev, curr) = fib_pair(n - 1);
    return (curr, prev + curr);
}

// Print first 8 Fibonacci numbers
let mut i = 0;
while i < 8 {
    let (a, _b) = fib_pair(i);
    console.log(a);
    i = i + 1;
}
