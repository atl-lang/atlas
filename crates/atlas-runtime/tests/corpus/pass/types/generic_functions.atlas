fn identity<T>(own x: T) : T {
    return x;
}

fn wrap_in_option<T>(borrow x: T) : Option<T> {
    return Some(x);
}

let n: number = identity(42);
let s: string = identity("hello");
console.log(n);
console.log(s);

let opt: Option<number> = wrap_in_option(99);
console.log(is_some(opt));
console.log(unwrap(opt));
