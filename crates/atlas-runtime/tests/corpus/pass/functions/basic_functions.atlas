fn add(borrow x: number, borrow y: number) : number {
    return x + y;
}

fn greet(borrow name: string) : string {
    return "Hello, " + name + "!";
}

fn is_even(borrow n: number) : bool {
    return n % 2 == 0;
}

console.log(add(3, 4));
console.log(greet("World"));
console.log(is_even(4));
console.log(is_even(7));
