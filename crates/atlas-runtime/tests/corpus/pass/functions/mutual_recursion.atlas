fn is_even_r(borrow n: number) : bool {
    if n == 0 {
        return true;
    }
    return is_odd_r(n - 1);
}

fn is_odd_r(borrow n: number) : bool {
    if n == 0 {
        return false;
    }
    return is_even_r(n - 1);
}

console.log(is_even_r(4));
console.log(is_even_r(7));
console.log(is_odd_r(3));
console.log(is_odd_r(6));
