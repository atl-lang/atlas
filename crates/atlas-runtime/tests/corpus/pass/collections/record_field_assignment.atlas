let mut cfg = record {
  host: "localhost",
  port: 8080,
  nested: record { port: 1 }
};

cfg.port = 9000;
cfg.host = "0.0.0.0";
cfg.nested.port = 7000;

print(unwrap(hash_map_get(cfg, "host")));
print(unwrap(hash_map_get(cfg, "port")));
let nested = unwrap(hash_map_get(cfg, "nested"));
print(unwrap(hash_map_get(nested, "port")));
