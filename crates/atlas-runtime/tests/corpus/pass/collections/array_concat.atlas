let nums: number[] = [1, 2];
let more_nums: number[] = [3, 4];
let combined_nums = nums + more_nums;
console.log(len(combined_nums));
console.log(combined_nums[0]);
console.log(combined_nums[3]);

let strings: string[] = ["a", "b"];
let more_strings: string[] = ["c"];
let combined_strings = strings + more_strings;
console.log(len(combined_strings));
console.log(combined_strings[2]);

let bools: bool[] = [true, false];
let more_bools: bool[] = [false, true];
let combined_bools = bools + more_bools;
console.log(len(combined_bools));
console.log(combined_bools[0]);
console.log(combined_bools[3]);

let nested: number[][] = [[1], [2, 3]];
let nested_more: number[][] = [[4]];
let combined_nested = nested + nested_more;
console.log(len(combined_nested));
console.log(combined_nested[1][1]);
console.log(combined_nested[2][0]);
